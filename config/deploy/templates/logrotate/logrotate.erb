<%= File.join(fetch(:deploy_to), '/shared/log/appsignal*.log') %>
<%= File.join(fetch(:deploy_to), '/shared/log/delayed_*.log') %>
<%= File.join(fetch(:deploy_to), '/shared/log/download*.log') %>
<%= File.join(fetch(:deploy_to), '/shared/log/export*.log') %>
<%= File.join(fetch(:deploy_to), '/shared/log/import*.log') %>
<%= File.join(fetch(:deploy_to), '/shared/log/production*.log') %>
<%= File.join(fetch(:deploy_to), '/shared/log/puma*.log') %>
{
        su <%= fetch(:deploy_user) %> <%= fetch(:deploy_user) %>
        weekly
        missingok
        rotate 12
        copytruncate
}

<%= File.join(fetch(:deploy_to), '/shared/log/nginx*.log') %>
{
        su root root
        weekly
        missingok
        rotate 12
        create 0644 root www-data
        sharedscripts
        prerotate
                if [ -d /etc/logrotate.d/httpd-prerotate ]; then \
                        run-parts /etc/logrotate.d/httpd-prerotate; \
                fi \
        endscript
        postrotate
                invoke-rc.d nginx rotate >/dev/null 2>&1
        endscript
}
