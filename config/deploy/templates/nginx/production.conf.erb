proxy_cache_path /var/cache/nginx/<%= fetch(:application) %>_<%= fetch(:rails_env) %> levels=1:2 keys_zone=<%= fetch(:application) %>_<%= fetch(:rails_env) %>:100m inactive=1y max_size=100m;

upstream puma_<%= fetch(:application) %>_<%= fetch(:rails_env) %> {
  server unix:<%= File.join(fetch(:deploy_to), 'shared/tmp/sockets/puma.sock') %> fail_timeout=0;
}

# enable for https
#server {
#  listen 80;
#  listen [::]:80;
#  server_name <%= fetch(:server_name) %>;
#  return 301 https://$host$request_uri;
#}

server {
  # change to 443 to use https
  listen 80;
  listen [::]:80;
  #listen 443 ssl; # managed by Certbot
  #listen [::]:443 ssl;
  #ssl_certificate /etc/letsencrypt/live/<%= fetch(:server_name) %>/fullchain.pem; # managed by Certbot
  #ssl_certificate_key /etc/letsencrypt/<%= fetch(:server_name) %>/privkey.pem; # managed by Certbot

  server_name <%= fetch(:server_name) %>;
  root <%= File.join(fetch(:deploy_to), 'current/public') %>;
  try_files $uri/index.html $uri @puma_<%= fetch(:application) %>_<%= fetch(:rails_env) %>;

  client_max_body_size 4G;
  keepalive_timeout 90;

  error_page 500 502 504 /500.html;
  error_page 503 @503;

  location ^~ /.well-known {
    root /var/www/<%= fetch(:application) %>/production/shared/public;
  }

  location @puma_<%= fetch(:application) %>_<%= fetch(:rails_env) %> {
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header Host $http_host;

    # enable for https
    # proxy_set_header X-Forwarded-Proto https;

    proxy_redirect off;
    proxy_read_timeout 300;
    proxy_pass http://puma_<%= fetch(:application) %>_<%= fetch(:rails_env) %>;
    # limit_req zone=one;
    access_log <%= File.join(fetch(:deploy_to), 'shared/log/nginx.access.log') %>;
    error_log <%= File.join(fetch(:deploy_to), 'shared/log/nginx.error.log') %>;
  }

  location ^~ /assets/ {
   try_files $uri @puma_<%= fetch(:application) %>_<%= fetch(:rails_env) %>;
    gzip_static on;
    expires max;
    add_header Cache-Control public;
  }

  location /cable {
    proxy_pass http://puma_<%= fetch(:application) %>_<%= fetch(:rails_env) %>;
    proxy_http_version 1.1;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "Upgrade";

    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header Host $http_host;
    proxy_set_header X-Real-IP $remote_addr;
    # required for https
    # proxy_set_header X-Forwarded-Proto https;
    proxy_redirect off;
  }

  location = /50x.html {
    root html;
  }

  location = /404.html {
    root html;
  }

  location @503 {
    error_page 405 = /system/maintenance.html;
    if (-f $document_root/system/maintenance.html) {
      rewrite ^(.*)$ /system/maintenance.html break;
    }
    rewrite ^(.*)$ /503.html break;
  }

  if ($request_method !~ ^(GET|HEAD|PUT|PATCH|POST|DELETE|OPTIONS)$ ){
    return 405;
  }

  if (-f $document_root/system/maintenance.html) {
    return 503;
  }

  set $no_cache 1;

  # if ($request_uri ~* '/api/') {
  #   set $no_cache 0;
  # }

  # Don't cache or serve pages specified above
  proxy_cache_bypass $no_cache;
  proxy_no_cache $no_cache;

  proxy_cache <%= fetch(:application) %>_<%= fetch(:rails_env) %>;
  proxy_cache_lock on;
  proxy_cache_valid 200 10s;
  proxy_cache_use_stale updating;
  proxy_cache_background_update on;
  add_header X-Cache $upstream_cache_status;
}
