<div class="glass home-container reset-password">
    <div class="home-container-content">
        <!--[if lt IE 9]>
        <div class="legacy-ie-fix"></div>
        <![endif]-->
        <div class="columns">
            <%= render 'logo' %>
        </div>

        <main class="columns">
            <h1><%= t('devise.passwords.edit.change_your_password', locale: DataCycleCore.ui_language) %></h1>

            <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
                <%= f.input :reset_password_token, as: :hidden %>

                <% if resource.errors.any? %>
                    <ul class="errors">
                        <% resource.errors.messages.values.flatten.each do |message| %>
                            <li><%= message %></li>
                        <% end %>
                    </ul>
                <% end %>

                <div class="row">
                    <div class="small-5 columns">
                        <label for="user_password" class="text-right middle">
                          <%= t('activerecord.attributes.user.password', locale: DataCycleCore.ui_language) %>:
                        </label>
                    </div>
                    <div class="small-6 columns end">
                        <%= f.input :password, required: false, label: false %>
                    </div>
                </div>

                <div class="row">
                    <div class="small-5 columns">
                        <label for="user_password_confirmation" class="text-right middle">
                          <%= t('activerecord.attributes.user.password_confirmation', locale: DataCycleCore.ui_language) %>:
                        </label>
                    </div>
                    <div class="small-6 columns end">
                        <%= f.input :password_confirmation, required: false, label: false %>
                    </div>
                </div>

                <div class="row">
                    <div class="small-7 small-offset-5 columns end">
                        <div class="form-actions">
                            <%= f.button :button, class: 'button', type: 'submit' do %>
                                <%= t('devise.passwords.edit.change_your_password', locale: DataCycleCore.ui_language) %>
                            <% end %>
                        </div>
                    </div>
                </div>
            <% end %>
        </div>
    </div>
</div>
