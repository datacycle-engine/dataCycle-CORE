<div class="glass home-container reset-password">
    <div class="home-container-content">
        <!--[if lt IE 9]>
        <div class="legacy-ie-fix"></div>
        <![endif]-->
        <div class="columns">
            <%= render 'logo' %>
        </div>

        <main class="columns">
            <h1><%= t('devise.registrations.new.sign_up', locale: DataCycleCore.ui_language) %></h1>

            <%= simple_form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
                <% if resource.errors.any? %>
                    <ul class="errors">
                        <% resource.errors.full_messages.each do |message| %>
                            <li><%= message %></li>
                        <% end %>
                    </ul>
                <% end %>

                <div class="row">
                    <div class="small-3 columns">
                        <label for="user_email" class="text-right middle">E-Mail:</label>
                    </div>
                    <div class="small-8 columns end">
                        <%= f.input :email, required: true, autofocus: true, label: false %>
                    </div>
                </div>

                <div class="row">
                    <div class="small-3 columns">
                        <label for="user_password" class="text-right middle">Passwort:</label>
                    </div>
                    <div class="small-8 columns end">
                        <%= f.input :password, required: true, label: false %>
                    </div>
                </div>

                <div class="row">
                    <div class="small-3 columns">
                        <label for="user_password_confirmation" class="text-right middle">Passwort wiederholen:</label>
                    </div>
                    <div class="small-8 columns end">
                        <%= f.input :password_confirmation, required: true, label: false %>
                    </div>
                </div>

                <div class="row">
                    <div class="small-4 columns">&nbsp;
                    </div>
                    <div class="small-7 columns end">
                        <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
                            <%= link_to t('devise.shared.links.didn_t_receive_confirmation_instructions'),
                                        new_confirmation_path(resource_name),
                                        class: 'forgotten_password_link' %>
                        <% end -%>
                    </div>
                </div>

                <div class="row">
                    <div class="small-8 small-offset-3 columns end">
                        <div class="form-actions">
                            <%= f.button :button, class: 'button', type: 'submit' do %>
                                <%= t('devise.registrations.new.sign_up', locale: DataCycleCore.ui_language) %>
                            <% end %>
                        </div>
                    </div>
                </div>
            <% end %>
        </main>
    </div>
</div>

