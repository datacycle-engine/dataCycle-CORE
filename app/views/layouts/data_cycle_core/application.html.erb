<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title><%= full_title %></title>

  <%= stylesheet_link_tag    "data_cycle_core/application", media: "all" %>
  <%= javascript_include_tag "data_cycle_core/application" %>
  <%= csrf_meta_tags %>
</head>
<body>

  <%= render 'data_cycle_core/shared/header' %>

  <%= display_flash_messages_new %>
  
  <div class="expanded row">
    <div class="column">
      <%= yield %>
    </div>
  </div>

  <%= render 'data_cycle_core/shared/footer' %>

</body>
</html>
