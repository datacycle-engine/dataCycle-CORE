<% if !language.nil? && language == "de" %>

    <% german = dataCycleObject.translations.select{|l| l['locale'] == language}.first %>
    <%= render 'data_cycle_core/places/partials/show/translation/translation_item', translation: german, dataCycleObject: dataCycleObject %>

<% else %>

    <% languages = dataCycleObject.translations.select{|l| l['locale'] != 'de'} %>

    <% if languages.count > 0 %>

        <div class="type translations">
            <div class="header">
                <span class="icon"><i class="fa fa-comment" aria-hidden="true"></i></span>
                <span class="title">Übersetzungen</span>
            </div>

        <% languages.each do |translation| %>

            <div class="row">
                <div class="large-2 columns">
                    <h5><%= "#{available_locales_with_names[translation.locale]} (#{translation.locale})" %></h5>
                </div>

                <div class="large-10 columns">
                    <%= render 'data_cycle_core/places/partials/show/translation/translation_item', translation: translation, dataCycleObject: dataCycleObject %>
                </div>
            </div>
            <hr>

        <% end %>
        </div>

    <% end %>

<% end %>
