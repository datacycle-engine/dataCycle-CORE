<% breadcrumb @place %>

<% content_for :top_content do %>

    <div class="column detail-header-wrapper">

        <div class="detail-header">

            <div class="detail-header-functions">
                <ul class="no-bullet">
                    <li>
                        <a id="show-history-link" data-toggle="show-history"><i class="fa fa-history" aria-hidden="true"></i> Versionen</a>
                        <ul class="dropdown-pane no-bullet bottom" id="show-history" data-dropdown data-hover="true" data-hover-pane="true">
                            <li>
                            Aktuelle Version von Admin<br><i>vor 1 Monat (8. Jul @ 09:18)</i>
                            </li>
                            <li>
                            <a href="#">Revision von Admin</a><br><i>vor 1 Monat (4. Jul @ 15:46)</i>
                            </li>
                            <li>
                            <a href="#">Revision von Admin</a><br><i>vor 1 Monat (4. Jul @ 15:46)</i>
                            </li>
                        </ul>
                    </li>
                    <li>
                        <a id="send-link-link" data-toggle="send-link"><i class="fa fa-share" aria-hidden="true"></i><i class="fa fa-user" aria-hidden="true"></i> versenden</span></a>
                        <ul class="dropdown-pane no-bullet bottom" id="send-link" data-dropdown data-hover="true" data-hover-pane="true">
                            <li>
                                <h5>Link versenden</h5>
                                <input type="email" placeholder="E-Mail Adresse" style="">
                            </li>
                            <li><button id="sendlinkButton" class="button small">Link versenden</button></li>
                            <li>
                                <input readonly="readonly" id="copyTarget" type="text" style="" value="http://10.0.0.82:3000/creative_works/c98379b4-8023-4efd-9556-1721fac3e16c">
                            </li>
                            <li><button id="copyButton" class="button small">In die Zwischenablage kopieren</button></li>
                        </ul>
                    </li>
                    <li>
                        <a id="subscribe-link" data-toggle="subscribe"><i class="fa fa-bell-o" aria-hidden="true"></i> abonnieren</span></a>
                        <ul class="dropdown-pane no-bullet bottom" id="subscribe" data-dropdown data-hover="true" data-hover-pane="true">
                            <li>

                            Klicken Sie hier um regelmäßig über Änderungen informiert zu werden.
                            </li>
                        </ul>
                    </li>
                    <li><%= render 'data_cycle_core/watch_lists/partials/add_to_watchlist', dataCycleObject: @place %></li>
                    <li><a href="<%= breadcrumbs[-2].url %>" class="hascontent"><i aria-hidden="true" class="fa fa-times"></i></a></li>
                </ul>
            </div>

            <div class="detail-header-info">
                <div class="type <%= @place.metadata['validation']['name'].downcase %>">
                    <%= render 'data_cycle_core/shared/icon', icon_type: @place.metadata['validation']['name'].downcase %>
                    <!--<span class="title"><%= @place.metadata['validation']['name'] %></span>-->
                    <span class="title">Ort</span>
                </div>
                <%= render 'data_cycle_core/creative_works/partials/metaData', dataCycleObject: @place %>
            </div>

            <!--<a class="bookmark marked" href="#">-->
            <!--<span class="bookmarkinfo">zur Recherche hinzugefügt</span>-->
            <!--<i class="fa fa-bookmark-o" aria-hidden="true"></i>-->
            <!--</a>-->

            <div class="title">

                <% if !@place.nil? && !@place.name.nil? %>
                    <%= @place.name %>
                <% end %>

            </div>

            <%= render 'data_cycle_core/creative_works/partials/show/top_content/classificationAliases', dataCycleObject: @place, dataCycleObjectSchema: @dataSchema %>

            <%= render 'data_cycle_core/creative_works/partials/show/top_content/validityPeriod', dataCycleObject: @place %>

            <% if !@place.metadata['validation']['permissions'].nil? && is_writable(@place.metadata['validation']['permissions']) %>

                <div class="edit">
                    <%= link_to edit_place_path(@place, trail: breadcrumb_trail), class:'button-prime small' do %>
                        <i class="fa fa-pencil" aria-hidden="true"></i><span>Bearbeiten</span>
                    <% end %>
                </div>

            <% end %>

        </div>

    </div>

<% end %>

<section>
    <br /><br />
</section>

<div class="detail-content place">

    <div class="row">

        <%= render 'data_cycle_core/places/partials/show/place', dataCycleObject: @place, dataCycleObjectSchema: @dataSchema %>

        <%= render 'data_cycle_core/places/partials/show/translation/translations', language: nil, dataCycleObject: @place %>

    </div>

</div>
