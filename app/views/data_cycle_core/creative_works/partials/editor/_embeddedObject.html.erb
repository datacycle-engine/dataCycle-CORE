
<% unless internal_object.nil? %>

	<div class="contentObject">
		<% embedded_object_key = key %>

		<h2>Zitat</h2>

		<% if !internal_object.metadata.nil? && !internal_object.metadata['validation'].nil? %>

			<% validation = internal_object.metadata['validation'] %>
			<% validation_properties = get_ordered_validation_properties(internal_object.metadata['validation']) %>

			<%#= @creativeWork.get_data_hash %>

			<% if !validation_properties.nil? %>

				<% validation_properties.each do |key, prop| %>

					<% if prop['type'] == 'object' && !prop['properties'].nil? %>

						<% object_options = !prop['editor'].nil? && !prop['editor']['options'].nil? ? prop['editor']['options'] : nil %>
						<%= content_tag :div, object_options do %>
							<!--<div class="object-title"><strong><%= prop['label'] %></strong></div>-->

							<% prop['properties'].each do |object_key, object_property| %>

								<% object_value = @dataSchema[key].nil? ? "" : @dataSchema[key][object_key] %>

								<%= data_cycle_field object_key, object_property, object_value, {class: 'form-control'}, [embedded_object_key, key] %>

							<% end %>

						<% end %>

					<% else %>

						<% object_value = !@dataSchema[embedded_object_key].nil? && !@dataSchema[embedded_object_key].empty? && !@dataSchema[embedded_object_key].first[key].nil? ? @dataSchema[embedded_object_key].first[key] : "" %>
						<%= data_cycle_field key, prop, object_value, {class: 'form-control'}, [embedded_object_key,''] %>

					<% end %>

				<% end %>

			<% end %>
		<% end %>
	</div>

<% end %>