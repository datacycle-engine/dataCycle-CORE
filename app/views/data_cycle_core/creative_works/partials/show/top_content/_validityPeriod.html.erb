<% if !dataCycleObject.metadata.nil? && !dataCycleObject.metadata['validityPeriod'].nil? && !dataCycleObject.metadata['validityPeriod'].empty? %>

    <% if (!dataCycleObject.metadata['validityPeriod']['validFrom'].nil? && !dataCycleObject.metadata['validityPeriod']['validFrom'].blank?) || (!dataCycleObject.metadata['validityPeriod']['validUntil'].nil? && !dataCycleObject.metadata['validityPeriod']['validUntil'].blank?) %>

    <div class="gueltigkeit">

        <span class="icon">
            <i class="fa fa-clock-o" aria-hidden="true"></i> Gültigkeit:
        </span>

        <% if !dataCycleObject.metadata['validityPeriod']['validFrom'].nil? && !dataCycleObject.metadata['validityPeriod']['validFrom'].blank? %>
            <%= dataCycleObject.metadata['validityPeriod']['validFrom'].to_datetime.to_s(:german_date_format) %>
        <% end %>

        <% if !dataCycleObject.metadata['validityPeriod']['validUntil'].nil? && !dataCycleObject.metadata['validityPeriod']['validUntil'].blank? %>
            <span class="bis">bis</span>
            <%= dataCycleObject.metadata['validityPeriod']['validUntil'].to_datetime.to_s(:german_date_format) %>
        <% end %>

        / <span class="status">Status: <strong><%= @release_status.release_text %></strong></span>

    </div>

    <% end %>

<% end %>