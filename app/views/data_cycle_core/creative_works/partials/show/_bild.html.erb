<% unless dataCycleObject.metadata.nil? %>
    <div class="image">

        <% unless dataCycleObject.metadata['content_url'].nil? %>
            <div class="image-container stripes">
                <img src="<%= dataCycleObject.metadata['content_url'] %>" alt="<%= dataCycleObject.headline unless dataCycleObject.headline.blank? %>" />
            </div>
        <% end %>

        <div class="image-data">
            <h5>Details</h5>

            <%= render 'data_cycle_core/creative_works/partials/show/translation/translations', language: 'de', dataCycleObject: dataCycleObject %>

            <% unless dataCycleObject.metadata['comment'].nil? %>
                <%= render_attribute_viewer key: 'comment',
                                            definition: dataCycleObject.metadata['validation']['properties']['comment'],
                                            value: normalize_value(dataCycleObject.metadata['comment']),
                                            parameters: { options: {} } %>
            <% end %>

            <dl>

                <% unless dataCycleObject.metadata['creator'].nil? %>
                    <dt><%= dataCycleObject.metadata['validation']['properties']['creator']['label'] %></dt>
                    <dd><%= dataCycleObject.metadata['creator'] %></dd>
                <% end %>

                <% unless dataCycleObject.metadata['license'].nil? %>
                    <dt><i class="fa fa-copyright" aria-hidden="true"></i> <%= dataCycleObject.metadata['validation']['properties']['license']['label'] %></dt>
                    <dd><%= dataCycleObject.metadata['license'] %>

                        <% unless dataCycleObject.metadata['mandatory_license'].nil? %><br>
                            <%= render_attribute_viewer key: 'mandatory_license',
                                                        definition: dataCycleObject.metadata['validation']['properties']['mandatory_license'],
                                                        value: normalize_value(dataCycleObject.metadata['mandatory_license']),
                                                        parameters: { options: {} } %>
                        <% end %>

                    </dd>
                <% end %>

                <% unless dataCycleObject.metadata['photographer'].nil? %>
                    <%= render_attribute_viewer key: 'photographer',
                                                definition: dataCycleObject.metadata['validation']['properties']['photographer'],
                                                value: normalize_value(dataCycleObject.metadata['photographer']),
                                                parameters: { options: {} } %>
                <% end %>

                <!-- todo: check only for empty string -->
                <% if !dataCycleObject.metadata['restrictions'].nil? && dataCycleObject.metadata['restrictions'] != 'Keine Einschränkung;' && !dataCycleObject.metadata['restrictions'].blank? %>
                    <dt><i class="fa fa-info-circle" aria-hidden="true"></i> <%= dataCycleObject.metadata['validation']['properties']['restrictions']['label'] %></dt>
                    <dd>
                        <%= render_attribute_viewer key: 'restrictions',
                                                    definition: dataCycleObject.metadata['validation']['properties']['restrictions'],
                                                    value: normalize_value(dataCycleObject.metadata['restrictions']),
                                                    parameters: { options: {hide_label: true}} %>
                    </dd>
                <% end %>

                <% unless dataCycleObject.metadata['width'].nil? %>
                    <dt><i class="fa fa-info-circle" aria-hidden="true"></i> Bildinformationen</dt>
                    <dd><%= dataCycleObject.metadata['width'] %>px/<%= dataCycleObject.metadata['height'] %>px, <%= dataCycleObject.metadata['content_size'] %>Bytes<br />
                        <strong>Format:</strong> <%= dataCycleObject.metadata['file_format'] %>

                        <% unless dataCycleObject.metadata['date_created'].nil? %>
                            <%= render_attribute_viewer key: 'date_created',
                                                        definition: dataCycleObject.metadata['validation']['properties']['date_created'],
                                                        value: normalize_value(dataCycleObject.metadata['date_created']),
                                                        parameters: { options: {} } %>
                        <% end %>

                        <% unless dataCycleObject.metadata['date_modified'].nil? %>
                            <%= render_attribute_viewer key: 'date_modified',
                                                        definition: dataCycleObject.metadata['validation']['properties']['date_modified'],
                                                        value: normalize_value(dataCycleObject.metadata['date_modified']),
                                                        parameters: { options: {} } %>
                        <% end %>

                    </dd>
                <% end %>

                <dt><i class="fa fa-external-link-square" aria-hidden="true"></i> Bild-URLs</dt>
                <dd>

                    <% unless dataCycleObject.metadata['content_url'].nil? %>
                        <%= render_attribute_viewer key: 'content_url',
                                                    definition: dataCycleObject.metadata['validation']['properties']['content_url'],
                                                    value: normalize_value(dataCycleObject.metadata['content_url']),
                                                    parameters: { options: {} } %>
                    <% end %>

                    <% unless dataCycleObject.metadata['thumbnail_url'].nil? %>
                        <%= render_attribute_viewer key: 'thumbnail_url',
                                                    definition: dataCycleObject.metadata['validation']['properties']['thumbnail_url'],
                                                    value: normalize_value(dataCycleObject.metadata['thumbnail_url']),
                                                    parameters: { options: {} } %>
                    <% end %>

                    <% unless dataCycleObject.metadata['url'].nil? %>
                        <%= render_attribute_viewer key: 'url',
                                                    definition: dataCycleObject.metadata['validation']['properties']['url'],
                                                    value: normalize_value(dataCycleObject.metadata['url']),
                                                    parameters: { options: {} } %>
                    <% end %>

                </dd>
            </dl>

            <% unless dataCycleObject.metadata['content_location'].nil? %>
                <%= render_attribute_viewer key: 'content_location',
                                            definition: dataCycleObject.metadata['validation']['properties']['content_location'],
                                            value: normalize_value(dataCycleObject.metadata['content_location']),
                                            parameters: { options: {} } %>
            <% end %>

            <% unless dataCycleObject.metadata['source'].nil? %>
                <%= render_attribute_viewer key: 'source',
                                            definition: dataCycleObject.metadata['validation']['properties']['source'],
                                            value: normalize_value(dataCycleObject.metadata['source']),
                                            parameters: { options: {} } %>
            <% end %>

            <% unless dataCycleObject.metadata['image_id'].nil? %>
                <%= render_attribute_viewer key: 'image_id',
                                            definition: dataCycleObject.metadata['validation']['properties']['image_id'],
                                            value: normalize_value(dataCycleObject.metadata['image_id']),
                                            parameters: { options: {} } %>
            <% end %>

            <% unless dataCycleObject.metadata['visibility'].nil? %>
                <%= render_attribute_viewer key: 'visibility',
                                            definition: dataCycleObject.metadata['validation']['properties']['visibility'],
                                            value: normalize_value(dataCycleObject.metadata['visibility']),
                                            parameters: { options: {} } %>
            <% end %>

            <% unless dataCycleObject.metadata['access'].nil? %>
                <%= render_attribute_viewer key: 'access',
                                            definition: dataCycleObject.metadata['validation']['properties']['access'],
                                            value: normalize_value(dataCycleObject.metadata['access']),
                                            parameters: { options: {} } %>
            <% end %>

        </div>

    </div>

    <hr>

<% end %>
