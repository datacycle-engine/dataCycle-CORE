
    <% object = ("DataCycleCore::"+("#{prop['type_name']}".classify)).constantize %>

    <% unless value.blank? || (value.is_a?(Hash) && value['value'].blank?) %>
    <div class="detail-type media" data-label="<%= prop['label'] %>" data-editor="objectBrowser" data-id="<%= value.is_a?(Hash) ? value['value'] : value %>">

        <span class="detail-label"><%= label %></span>

        <% if prop['releasable'] && value.is_a?(Hash) %>
            <div class="release-status">
                <span class="status-information"><%= DataCycleCore::Release.find(value['release_id']).release_text %></span>
                <% unless value['release_comment'].blank? %>
                    <span class="status-comment" data-open="release_comment_<%= label %>"><i class="fa fa-comment" aria-hidden="true"></i></span>
                    <div class="reveal release-comment" id="release_comment_<%= label %>" data-reveal>
                        <p class="lead">Kommentar</p>
                        <div class="release-comment"><%= value['release_comment'] %></div>
                        <button class="close-button" data-close aria-label="Close modal" type="button">
                        <span aria-hidden="true">&times;</span>
                        </button>
                    </div>
                <% end %>
            </div>
            <% value = value['value'] unless value.blank? %>
        <% end %>

        <div class="media-thumbs">

            <!-- todo: remove when videos are available -->
            <% if prop['label'] != 'Videos' %>

                <% unless value.blank? %>

                    <% value.each do |item| %>

                        <% image = object.where(id: item).first %>

                        <% unless image.blank? %>

                            <a data-open="media-reveal-<%= image.id %>">
                                <div class="thumbnail <%= 'has-restrictions' if !image.metadata['restrictions'].nil? && !image.metadata['restrictions'].blank? && image.metadata['restrictions'] != 'Keine Einschränkung;' %>"
                                     style="background-image: url(<%= image.metadata['thumbnailUrl'] %>)">
                                    <% unless image.title.blank? %>
                                        <div class="description">
                                            <%= image.title %>
                                        </div>
                                    <% end %>
                                </div>
                            </a>

                            <div class="large reveal media-preview" id="media-reveal-<%= image.id %>" data-reveal>
                                <button class="close-button" data-close aria-label="Close modal" type="button">
                                    <span aria-hidden="true">&times;</span>
                                </button>
                                <span class="preview-title"><%= image.title %></span>
                                <div class="image">
                                    <img src="<%= image.metadata['contentUrl'] %>" />
                                </div>
                                <div class="description">

                                    <!-- todo: check only for empty string -->
                                    <% if !image.metadata['restrictions'].nil? && !image.metadata['restrictions'].blank? && image.metadata['restrictions'] != 'Keine Einschränkung;' %>
                                        <strong>Einschränkungen:</strong> <%= image.metadata['restrictions'].html_safe %><br /><br />
                                    <% end %>

                                    <%= link_to image do %>
                                        zur Detailansicht
                                    <% end %> |
                                    <% unless image.metadata['url'].nil? && image.metadata['url'].blank? %>
                                        <a href="<%= image.metadata['url'] %>" target="_blank">im Medienarchiv öffnen</a>
                                    <% end %>
                                </div>
                            </div>

                        <% end %>

                    <% end %>

                <% end %>

            <% end %>

        </div>

    </div>
    <% end %>
