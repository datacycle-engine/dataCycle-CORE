<% set_key_prefix keyPrefix %>

<%= form_for dataObject, builder: DataCycleCore::DataHashHelper::DataCycleFormBuilder do |f| %>
	<%= hidden_field_tag 'uuid', dataObject.id %>

	<section class="edit-header">
		<div class="row expanded">
			<div class="column">
				<div class="edit-headline">
					<i class="fa fa-pencil" aria-hidden="true"></i> <%= dataObject.content_type %> bearbeiten
				</div>
				<ul>
					<!--<li>-->
					<!--<button type="button" class="button delete top" data-tooltip aria-haspopup="true" data-disable-hover="false" title="Löschen"><i class="fa fa-trash" aria-hidden="true"></i></button>-->
					<!--</li>-->
					<li>
						<%= link_to breadcrumbs[-2].url do %>
							<button type="button" class="button discard top" data-tooltip aria-haspopup="true" data-disable-hover="false"  title="Änderungen verwerfen"><i class="fa fa-times" aria-hidden="true"></i></button>
						<% end %>
					</li>
					<li class="submit">
						<button class="button-prime" data-tooltip aria-haspopup="true" data-disable-hover="false"  title="Änderungen speichern"><i class="fa fa-check" aria-hidden="true"></i></button>
					</li>
				</ul>
			</div>
		</div>
	</section>

	<% unless @splitSource.nil? %>
		<% I18n.with_locale(@splitSource.first_available_locale) do %>
			<div class="flex-box">
				<div class="split-content detail-content">
					<% if can?(:subscribe, @splitSource) && @splitSource.subscriptions.by_user(current_user).count == 0 %>
						<div class="subscribe-parent notice"><p>Sie sollten diesen Inhalt (<%=@splitSource.metadata['validation']['name']%>) abonnieren, um Ihren neu erstellten Inhalt (<%=dataObject.metadata['validation']['name']%>) aktuell halten zu können.</p>
							<%= link_to "Abonnieren", subscriptions_path(subscribable_id: @splitSource.id, subscribable_type: @splitSource.class.name), method: :post %>

							<button name="button" type="button" class="close-subscribe-notice" data-close="" aria-label="Dismiss Notice"><span aria-hidden="true">×</span></button>
						</div>
					<% end %>
					<div class="show-content">
						<div class="detail-header-info">
							<div class="type <%= @splitSource.metadata['validation']['name'].downcase %>">
								<%= render_content_partial 'icon', content: @splitSource %>

								<span class="title"><%= @splitSource.metadata['validation']['name'] %></span>
								<% unless @splitSource.translated_locales.count > 1 %>
									<span class="language">(<%= I18n.locale %>)</span>
								<% end %>
							</div>
							<%= render 'data_cycle_core/creative_works/partials/metaData', dataCycleObject: @splitSource, dataCycleObjectSchema: @splitSchema %>
						</div>

						<%= render_content_partial 'details', content: @splitSource, schema: @splitSchema, options: {force_render: true} %>

					</div>
				</div>
		<% end %>
	<% end %>

	<div class="row<%= ' split-content edit-content' unless @splitSource.nil? %>">
		<div class="column">
			<div class="detail-header editor">

				<div class="detail-header-info">
					<div class="type <%= dataObject.metadata['validation']['name'].downcase %>">
						<%= render_content_partial 'icon', content: dataObject %>

						<span class="title"><%= dataObject.metadata['validation']['name'] %></span>
						<% unless dataObject.translated_locales.count > 1 %>
							<span class="language">(<%= I18n.locale %>)</span>
						<% end %>
					</div>
					<%= render 'data_cycle_core/creative_works/partials/metaData', dataCycleObject: dataObject, dataCycleObjectSchema: dataSchema %>
				</div>

				<a class="bookmark" href="#">
					<span class="bookmarkinfo">zur Recherche hinzufügen</span>
					<i class="fa fa-bookmark-o" aria-hidden="true"></i>
				</a>

				<div id="validation_errors">

				</div>

				<% if !dataObject.metadata.nil? && !dataObject.metadata['validation'].nil? %>

					<% validation_properties = get_ordered_validation_properties(dataObject.metadata['validation']) %>

					<%= render 'data_cycle_core/contents/editors/metadata/releasable_editor', value: {'release_id' => dataObject.release_id, 'release_comment' => dataObject.release_comment}, key: 'creative_work', definition: {'type' => 'releasable'}, options:{} %>

					<% if !validation_properties.nil? %>

						<% validation_properties.each do |key, prop| %>

							<% value = prop.dig('type') == "object" ? dataObject.try(key.to_sym) : dataSchema[key] %>

							<%= render_attribute_editor key: "#{keyPrefix}[#{key}]", definition: prop, value: value, parameters: { options: prop.dig('editor', 'options') || {} } unless dataSchema.nil? %>

						<% end %>

					<% end %>

				<% end %>

			</div>
		</div>
	</div>

	<% unless @splitSource.nil? %>
		</div>
	<% end %>

<% end %>
