<% object = ("DataCycleCore::"+("#{prop['storage_location']}".classify)).constantize %>
<div class="form-element validation-container <%= key.split('[').last[0...-1] %>">
	<div class="object-browser" id="<%= sanitize_to_id(key) %>">
		<%= label_tag(key, prop['label']) %>
		<input type="text" disabled="disabled" />
		<div class="media-thumbs">
			<% existing = [] %>
			<% unless value.blank? %>
				<% value.each do |item| %>
					<% data_object = object.where(id: item['id']).first %>
					<% existing << data_object %>
				<% end %>
			<% end %>
			<% create = prop['name'].downcase == "person" ? true : false %>
			
			<object-browser :existing="<%= existing.to_json %>" :object-type="'<%= prop['editor']['options']['data-type'].downcase %>'" :object-label="'<%= prop['label'] %>'" :max="1" :create-item="<%= create %>" hidden-name="<%= key %>[]">
				<template scope="props" slot="item">
					<div v-if="props.item != undefined" class="media person">
						<a slot="remove" class="delete-thumbnail" href="#" @click.prevent="props.remove(props.item)"><i aria-hidden="true" class="fa fa-times"></i></a>

						<% if prop['storage_location'] == 'persons' %>

							<i class="fa fa-user" aria-hidden="true"></i>
							<span class="name">{{ props.item.givenName }} <strong>{{ props.item.familyName }}</strong></span>

						<% elsif prop['storage_location'] == 'places' %>

							<i class="fa fa-map-marker" aria-hidden="true"></i>
							<span class="name">{{ props.item.name }} {{ props.item.address }} </span>
							{{ props.objectType }}
					<% end %>
						<input type="hidden" name="<%= key %>[][id]" :value="props.item.id">
					</div>
				</template>

				<template slot="new-item" scope="newItem">
					<div id="newPerson">
						<h3>Neue Person erstellen</h3>
						<% @person = DataCycleCore::Person.new %>
						<%= form_for(@person) do |f| %>

							<%= hidden_field_tag 'template', 'Person' %>
							<div class="validation-container form-element">
								<%= label_tag 'person[datahash][givenName]', 'Vorname' %>
								<%= text_field_tag 'person[datahash][givenName]', 'Vorname', class: 'form-control', value:'' %>
							</div>
							<div class="validation-container form-element">
								<%= label_tag 'person[datahash][familyName]', 'Nachname' %>
								<%= text_field_tag 'person[datahash][familyName]', '', class: 'form-control', value:'' %>
							</div>
							<div class="validation-container form-element">
								<%= label_tag 'person[datahash][jobTitle]', 'Berufsbezeichnung' %>
								<%= text_field_tag 'person[datahash][jobTitle]', '', class: 'form-control no-validation' %>
							</div>
							<%= f.submit "Erstellen", class: "button primary" %>

						<% end %>

						<button class="close-button" data-close aria-label="Close modal" type="button">
							<span aria-hidden="true">&times;</span>
						</button>
					</div>
				</template>

			</object-browser>
		</div>
	</div>
</div>
