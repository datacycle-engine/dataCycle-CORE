<% value = value.nil? ? {} : value %>
<div class="release-status" id="release_container_<%= sanitize_to_id(key) %>">
  <%= collection_select key, :release_id, DataCycleCore::Release.all, :id, :release_text, {selected: value['release_id']}, class: "release-select" %>
  <%= hidden_field_tag key + "[release_comment]", value['release_comment'], placeholder: "Kommentar", class: "release-comment" %>

  <span class="button" data-open="release_comment_<%= sanitize_to_id(key) %>">Kommentar</span>
  <div class="reveal release-comment" id="release_comment_<%= sanitize_to_id(key) %>" data-reveal>
    <p class="lead">Kommentar</p>
    <%= text_area_tag key + "[release_comment]", value['release_comment'], placeholder: "Kommentar", class: "release-comment" %>
    <button class="button save" data-close aria-label="Ok" type="button">Ok</button>
    <button class="close-button" data-close aria-label="Close modal" type="button">
      <span aria-hidden="true">&times;</span>
    </button>
  </div>

</div>

<% key += "[value]" %>
<% value = value['value'] unless value.blank? %>
<% options ||= options %>
<% parent_object_keys ||= parent_object_keys %>

<%= send('render_'+ prop['type'] +'_field', key, prop, value, options, parent_object_keys) %>