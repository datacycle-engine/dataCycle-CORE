<%# @classification_tree_label = get_classifications_for_name prop['type_name'] unless prop['type_name'].nil? %>

<% types = DataCycleCore::ClassificationAlias.joins(classification_tree: [:classification_tree_label]).where("classification_tree_labels.name = ?", prop['type_name']).where("classification_trees.parent_classification_alias_id IS NULL") %>

<% select_options = get_custom_select_values(types) %>

<% unless select_options.nil? %>

    <% readonly = options['readonly'] ? true : false %>

    <%# select_options = @classification_tree_label.classification_trees.map { |classification| {:value => classification.sub_classification_alias.classifications.ids.first , :label => classification.sub_classification_alias.name }} %>
    <div <%= !prop['editor']['options'].nil? && !prop['editor']['options']['data-validate'].nil? ? "data-validate=#{prop['editor']['options']['data-validate']}" : '' %>>

        <% selected_values = get_selected_values_for_classification select_options, value %>

        <div class="custom-select-title"><%= prop['label'] %></div>
        <%= label_tag(key, prop['label']) %>
        <custom-select hidden-field-id="<%= key %>[]" :custom-options="<%= select_options.to_json %>" :selected-values="<%= selected_values.to_json %>" :read-only="<%= readonly %>"></custom-select>
    </div>
<% end %>
