<% breadcrumb :show_compare, @creativeWork, @watch_list %>

<% content_for :top_content do %>

    <div class="reveal-blur">

        <div id="edit-form">
            <section class="edit-header">
                <div class="row expanded">
                    <div class="column edit-header-functions">
                      <div class="edit-headline">
                          <i class="fa fa-columns" aria-hidden="true"></i> <%= @creativeWork.content_type %> <%= t('common.compare', locale: DataCycleCore.ui_language) %>
                      </div>
                      <ul>
                        <li class="has-dropdown right">
                          <%= render 'split_sources', contents: @creativeWork.siblings.select{|s| s.metadata.dig('validation', 'name') == @creativeWork.metadata.dig('validation', 'name') }, selected: @source, url: compare_creative_work_path(@creativeWork), title_text: t('common.choose_splitsource', locale: DataCycleCore.ui_language) %>
                        </li>
                        <li class="buttons"></li>
                      </ul>
                    </div>
                </div>
            </section>

            <div class="flex-box">

                <% I18n.with_locale(@source.first_available_locale) do %>
                    <div class="row split-content detail-content">
                        <div class="show-content">
                            <div class="detail-header-info">
                              <%= render 'meta_data', content: @source %>
                            </div>

                            <%= render 'data_cycle_core/contents/viewers/metadata/releasable_viewer',
                                       value: @source.get_releasable_hash,
                                       key: 'creative_work',
                                       definition: {'type' => 'releasable'},
                                       options:{compare: true, force_render: true} if @source.metadata['validation'].dig('releasable') == true %>

                            <%= render_content_partial 'history', content: @source, schema: @sourceSchema, options: {force_render: true, compare: true} %>

                        </div>
                    </div>

                <% end %>

                <% I18n.with_locale(@creativeWork.first_available_locale) do %>

                    <div class="row split-content detail-content">

                        <div class="show-content">
                            <div class="detail-header-info">
                              <%= render 'meta_data', content: @creativeWork %>
                            </div>

                            <%= render 'data_cycle_core/contents/viewers/metadata/releasable_viewer',
                                       value: @creativeWork.get_releasable_hash,
                                       key: 'creative_work',
                                       definition: {'type' => 'releasable'},
                                       options:{force_render: true} if @creativeWork.metadata['validation'].dig('releasable') == true %>

                            <%= render_content_partial 'details', content: @creativeWork, schema: @dataSchema, options: {force_render: true} %>

                        </div>

                    </div>

                <% end %>

            </div>

        </div>

    </div>

<% end %>
