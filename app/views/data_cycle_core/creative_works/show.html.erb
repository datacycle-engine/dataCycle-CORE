<% breadcrumb @creativeWork %>

<% content_for :top_content do %>

    <div class="column detail-header-wrapper">

        <div class="detail-header">

            <div class="detail-header-functions">
                <ul class="no-bullet">
                    <li>
                        <a id="show-history-link" data-toggle="show-history"><i class="fa fa-history" aria-hidden="true"></i> <strong>Version 3</strong>, 8. Jul @ 09:18</a>
                        <ul class="dropdown-pane no-bullet bottom" id="show-history" data-dropdown data-hover="true" data-hover-pane="true">
                            <li>
                            Aktuelle Version von Admin<br><i>vor 1 Monat (8. Jul @ 09:18)</i>
                            </li>
                            <li>
                            <a href="#">Revision von Admin</a><br><i>vor 1 Monat (4. Jul @ 15:46)</i>
                            </li>
                            <li>
                            <a href="#">Revision von Admin</a><br><i>vor 1 Monat (4. Jul @ 15:46)</i>
                            </li>
                        </ul>
                    </li>
                    <li>
                        <a id="send-link-link" data-toggle="send-link"><i class="fa fa-share" aria-hidden="true"></i><i class="fa fa-user" aria-hidden="true"></i> versenden</span></a>
                        <ul class="dropdown-pane no-bullet bottom" id="send-link" data-dropdown data-hover="true" data-hover-pane="true">
                            <li>
                                <h5>Link versenden</h5>
                                <input type="email" placeholder="E-Mail Adresse" style="">
                            </li>
                            <li><button id="sendlinkButton" class="button small">Link versenden</button></li>
                            <li>
                                <input readonly="readonly" id="copyTarget" type="text" style="" value="http://10.0.0.82:3000/creative_works/c98379b4-8023-4efd-9556-1721fac3e16c">
                            </li>
                            <li><button id="copyButton" class="button small">In die Zwischenablage kopieren</button></li>
                        </ul>
                    </li>
                    <li>
                        <a id="subscribe-link" data-toggle="subscribe"><i class="fa fa-bell-o" aria-hidden="true"></i> abonnieren</span></a>
                        <ul class="dropdown-pane no-bullet bottom" id="subscribe" data-dropdown data-hover="true" data-hover-pane="true">
                            <li>

                            Klicken Sie hier um regelmäßig über Änderungen informiert zu werden.
                            </li>
                        </ul>
                    </li>
                    <li><%= render 'data_cycle_core/watch_lists/partials/add_to_watchlist', dataCycleObject: @creativeWork %></li>
                    <li><a href="<%= breadcrumbs[-2].url %>" class="hascontent"><i aria-hidden="true" class="fa fa-times"></i></a></li>
                </ul>
            </div>
                        

            <div class="detail-header-info">
                <div class="type <%= @creativeWork.metadata['validation']['name'].downcase %>">
                    <%= render 'data_cycle_core/shared/icon', icon_type: @creativeWork.metadata['validation']['name'].downcase %>
                    <span class="title"><%= @creativeWork.metadata['validation']['name'] %></span>
                </div>
                <%= render 'data_cycle_core/creative_works/partials/metaData', dataCycleObject: @creativeWork %>
            </div>

            <!--<a class="bookmark marked" href="#">-->
            <!--<span class="bookmarkinfo">zur Recherche hinzugefügt</span>-->
            <!--<i class="fa fa-bookmark-o" aria-hidden="true"></i>-->
            <!--</a>-->

            <div class="title">
                <!--todo: check if name is allready in use-->
                <% if !@creativeWork.content.nil? && !@creativeWork.content['headline'].blank? %>
                    <%= @creativeWork.content['headline'] %>
                <% elsif  !@creativeWork.content.nil? && !@creativeWork.content['name'].blank? %>
                    <%= @creativeWork.content['name'] %>
                <% end %>

            </div>

            <!--todo: only use description field ?-->
            <div class="description">
                <% if !@creativeWork[:description].nil? %>
                    <%= @creativeWork.description.html_safe %>
                <% end %>
                <% if !@creativeWork.content.nil? && !@creativeWork.content['text'].nil? %>
                    <%= @creativeWork.content['text'].html_safe %>
                <% end %>
            </div>


            <% if @creativeWork.metadata['validation']['name'] == "Bild" %>
                <% unless @creativeWork.display_classification_aliases.empty? %>
                    <div class="tags">
                        <div class="tag-group-wrapper">
                            <span class="icon"><i class="fa fa-tags" aria-hidden="true"></i></span>
                            <% @creativeWork.display_classification_aliases.each do |classificationAlias| %>
                                <span class="tag"><%= classificationAlias.name %></span>
                            <% end %>
                        </div>
                    </div>
                <% end %>
            <% else %>
                <%= render 'data_cycle_core/creative_works/partials/show/top_content/classificationAliases', dataCycleObject: @creativeWork, dataCycleObjectSchema: @dataSchema %>
            <% end %>

            <%= render 'data_cycle_core/creative_works/partials/show/top_content/validityPeriod', dataCycleObject: @creativeWork %>

            <% if !@creativeWork.metadata['validation']['permissions'].nil? && is_writable(@creativeWork.metadata['validation']['permissions']) %>

                <div class="edit">
                    <%= link_to edit_creative_work_path(@creativeWork, trail: breadcrumb_trail), class:'button-prime small' do %>
                        <i class="fa fa-pencil" aria-hidden="true"></i><span>Bearbeiten</span>
                    <% end %>
                </div>

            <% end %>

        </div>

        <!--<%= render 'data_cycle_core/creative_works/partials/filter' if user_signed_in? %>-->

    </div>

    <% if @creativeWork.metadata['validation']['content_type'] == 'entity' %>

        <%= render 'data_cycle_core/backend/views' if user_signed_in? %>

    <% end %>

<% end %>

<section>

    <% if @creativeWork.metadata['validation']['content_type'] == 'entity' %>

        <% contentData = [] %>

        <% @creativeWork.walk_tree do |content, level| %>

            <% if content.metadata['validation']['content_type'] != 'embedded' %>
                <% contentData.push(content) %>
            <% end %>

        <% end %>

        <% if @mode == 'list' %>
            <%= render 'data_cycle_core/backend/partials/list', dataCycleObjects: contentData %>
        <% else %>
            <%= render 'data_cycle_core/backend/partials/grid', dataCycleObjects: contentData %>
        <% end %>

    <% end %>

</section>

<% if @creativeWork.metadata['validation']['content_type'] == 'variant' %>

    <div class="detail-content <%= @creativeWork.metadata['validation']['description'].downcase if !@creativeWork.metadata.nil? && !@creativeWork.metadata['validation'].nil? && !@creativeWork.metadata['validation']['description'].nil? %>">

        <div class="row align-center">

            <%= render 'data_cycle_core/creative_works/partials/show/'+@creativeWork.metadata['validation']['name'].downcase, dataCycleObject: @creativeWork, dataCycleObjectSchema: @dataSchema rescue render "data_cycle_core/creative_works/partials/show/default", dataCycleObject: @creativeWork, dataCycleObjectSchema: @dataSchema  %>
            <%= render 'data_cycle_core/creative_works/partials/show/translation/translations', language: nil, dataCycleObject: @creativeWork %>

        </div>

    </div>

<% end %>
