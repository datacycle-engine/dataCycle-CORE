
<% content_for :top_content do %>

    <% if @creativeWork.metadata['validation']['name'] == "Bild" %>

        <div class="column detail-header-wrapper">

            <div class="detail-header">

                <div class="type bild">
                    <span class="icon">
                        <i class="fa fa-picture-o" aria-hidden="true"></i>
                    </span>
                    <span class="title">Bild</span>
                </div>

                <!--<a class="bookmark marked" href="#">-->
                    <!--<span class="bookmarkinfo">zur Recherche hinzugefügt</span>-->
                    <!--<i class="fa fa-bookmark-o" aria-hidden="true"></i>-->
                <!--</a>-->

                <div class="title">

                    <% if !@creativeWork.content.nil? && !@creativeWork.content['name'].blank? %>
                        <%= @creativeWork.content['name'] %>
                    <% elsif  !@creativeWork.content.nil? && !@creativeWork.content['headline'].blank? %>
                        <%= @creativeWork.content['headline'] %>
                    <% end %>

                </div>


                <div class="description">
                    <% if !@creativeWork[:description].nil? %>
                        <%= @creativeWork.description.html_safe %>
                    <% end %>
                </div>

                <%= render 'data_cycle_core/creative_works/partials/render/validityPeriod' %>

                <% unless @creativeWork.classification_aliases.empty? %>
                    <div class="tags">
                        <span class="icon"><i class="fa fa-tags" aria-hidden="true"></i> </span>

                        <% @creativeWork.classification_aliases.each do |classificationAlias| %>
                            <span class="tag"><a href="#"><%= classificationAlias.name %></a></span>
                        <% end %>
                    </div>
                <% end %>

            </div>

            <!--<%= render 'data_cycle_core/creative_works/filter' if user_signed_in? %>-->

        </div>


    <% else %>

        <div class="column detail-header-wrapper">

            <div class="detail-header">

                <div class="type thema">
                    <span class="icon">
                        <i class="fa fa-folder-open" aria-hidden="true"></i>
                    </span>
                    <span class="title"><%= @creativeWork.metadata['validation']['name'] %></span>
                </div>

                <!--<a class="bookmark marked" href="#">-->
                    <!--<span class="bookmarkinfo">zur Recherche hinzugefügt</span>-->
                    <!--<i class="fa fa-bookmark-o" aria-hidden="true"></i>-->
                <!--</a>-->

                <div class="title">

                    <% if !@creativeWork.content.nil? && !@creativeWork.content['name'].blank? %>
                        <%= @creativeWork.content['name'] %>
                    <% elsif  !@creativeWork.content.nil? && !@creativeWork.content['headline'].blank? %>
                        <%= @creativeWork.content['headline'] %>
                    <% end %>

                </div>

                <div class="description">
                    <% if !@creativeWork[:description].nil? %>
                        <%= @creativeWork.description.html_safe %>
                    <% end %>
                </div>

                <%= render 'data_cycle_core/creative_works/partials/render/validityPeriod' %>

                <% unless @creativeWork.classification_aliases.empty? %>
                    <div class="tags">
                        <span class="icon"><i class="fa fa-tags" aria-hidden="true"></i></span>

                        <% @creativeWork.classification_aliases.each do |classificationAlias| %>
                            <span class="tag"><a href="#"><%= classificationAlias.name %></a></span>
                        <% end %>
                    </div>
                <% end %>

                <div class="edit">
                    <%= link_to edit_creative_work_path(@creativeWork), class:'button-prime small' do %>
                        <i class="fa fa-pencil" aria-hidden="true"></i><span>Bearbeiten</span>
                    <% end %>
                </div>

            </div>

            <!--<%= render 'data_cycle_core/creative_works/filter' if user_signed_in? %>-->

        </div>


        <!--<%= render 'data_cycle_core/backend/views' if user_signed_in? %>-->

    <% end %>

<% end %>

