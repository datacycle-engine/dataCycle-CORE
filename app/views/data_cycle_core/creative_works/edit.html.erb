
<% content_for :top_content do %>

<div class="reveal-blur">

    <div id="edit-form">

        <%= form_for @creativeWork, builder: DataCycleCore::CreativeWorksHelper::DataCycleFormBuilder do |f| %>
            <%= hidden_field_tag 'uuid', @creativeWork.id %>

            <section class="edit-header">
                <div class="row expanded">
                    <div class="column">
                        <div class="edit-headline">
                            <i class="fa fa-pencil" aria-hidden="true"></i> <%=@creativeWork.metadata['validation']['name']%> bearbeiten
                        </div>
                        <ul>
                            <!--<li>-->
                                <!--<button type="button" class="button delete top" data-tooltip aria-haspopup="true" data-disable-hover="false" title="Löschen"><i class="fa fa-trash" aria-hidden="true"></i></button>-->
                            <!--</li>-->
                            <li>
                                <%= link_to @creativeWork do %>
                                    <button type="button" class="button discard top" data-tooltip aria-haspopup="true" data-disable-hover="false"  title="Änderungen verwerfen"><i class="fa fa-times" aria-hidden="true"></i></button>
                                <% end %>
                            </li>
                            <li class="submit">
                                <button class="button-prime" data-tooltip aria-haspopup="true" data-disable-hover="false"  title="Änderungen speichern"><i class="fa fa-check" aria-hidden="true"></i></button>
                            </li>
                        </ul>
                    </div>
                </div>
            </section>

            <div class="row">
                <div class="column">
                    <div class="detail-header editor">
                    
                        <div class="topleftinfo">
                            <div class="type thema">
                                <span class="icon">
                                    <i class="fa fa-folder-open" aria-hidden="true"></i>
                                </span>
                                <span class="title"><%=@creativeWork.metadata['validation']['name']%></span>
                            </div>
                            <%= render 'data_cycle_core/creative_works/partials/render/metaData' %>
                        </div>

                        <a class="bookmark" href="#">
                            <span class="bookmarkinfo">zur Recherche hinzufügen</span>
                            <i class="fa fa-bookmark-o" aria-hidden="true"></i>
                        </a>

                        <div id="validation_errors">

                        </div>

                        <% if !@creativeWork.metadata.nil? && !@creativeWork.metadata['validation'].nil? %>

                            <% validation = @creativeWork.metadata['validation'] %>
                            <% validation_properties = get_ordered_validation_properties(@creativeWork.metadata['validation']) %>

                            <!--<h2><%= "#{validation['name']} - #{validation['description']} - #{validation['type']}" %></h2>-->
                            <%#= @creativeWork.get_data_hash %>
                            <% if !validation_properties.nil? %>

                                <% validation_properties.each do |key, prop| %>

                                    <% if prop['type'] == 'object' && !prop['properties'].nil? %>

                                        <% object_options = !prop['editor'].nil? && !prop['editor']['options'].nil? ? prop['editor']['options'] : nil %>
                                        <%= content_tag :div, object_options do %>
                                            <!--<div class="object-title"><strong><%= prop['label'] %></strong></div>-->

                                            <% prop['properties'].each do |object_key, object_property| %>

                                                <% object_value = @dataSchema[key].nil? ? "" : @dataSchema[key][object_key] %>

                                                <%= data_cycle_field object_key, object_property, object_value, {class: 'form-control'}, [key] %>
                                            <% end %>
                                        <% end %>

                                    <% else %>

                                        <%= data_cycle_field key, prop, @dataSchema[key], class: 'form-control' %>

                                    <% end %>

                                <% end %>

                            <% end %>

                        <% end %>

                    </div>
                </div>
            </div>

        <% end %>

        <div class="reveal full" id="mediabrowser" data-reveal data-overlay="false">
          <h4>
            <i class="fa fa-files-o" aria-hidden="true"></i>Medien hinzufügen
            <button class="close-button" data-close aria-label="Close reveal" type="button"><span aria-hidden="true"><i aria-hidden="true" class="fa fa-times"></i></span></button>
          </h4>
          <div id="media-content"></div>
          <div id="media-info">
               <h5>Details</h5>
                <dl>
                  <dt></dt>
                  <dd class="add-metadata" id="thumb-url"></dd>

                  <dt>Datei URL</dt>
                  <dd class="add-metadata" id="media-file-url"></dd>

                  <dt>Caption</dt>
                  <dd class="add-metadata" id="media-name"></dd>

                  <dt>Format</dt>
                  <dd class="add-metadata" id="media-format"></dd>

                  <dt>Abmessungen</dt>
                  <dd class="add-metadata" id="media-dimensions"></dd>

                  <dt>Dateigröße</dt>
                  <dd class="add-metadata" id="media-size"></dd>

                  <dt>Lizenz</dt>
                  <dd class="add-metadata" id="media-license"></dd>

                  <dt>Erstellt</dt>
                  <dd class="add-metadata" id="media-date-created"></dd>

                  <dt>Bearbeitet</dt>
                  <dd class="add-metadata" id="media-date-modified"></dd>
                </dl>
          </div>
        </div>

    </div>
</div>

<% end %>

