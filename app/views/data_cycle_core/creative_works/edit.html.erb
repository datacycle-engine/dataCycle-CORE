
<% content_for :top_content do %>

    <div id="edit-form">

        <%= form_for @creativeWork, builder: DataCycleCore::CreativeWorksHelper::DataCycleFormBuilder do |f| %>
            <%= hidden_field_tag 'uuid', @creativeWork.id %>

            <section class="edit-header">
                <div class="row expanded">
                    <div class="column">
                        <div class="edit-headline">
                            <i class="fa fa-pencil" aria-hidden="true"></i> Thema bearbeiten
                        </div>
                        <ul>
                            <!--<li>-->
                            <!--<button class="button delete top" data-tooltip aria-haspopup="true" data-disable-hover="false" title="Löschen"><i class="fa fa-trash" aria-hidden="true"></i></button>-->
                            <!--</li>-->
                            <!--<li>-->
                            <!--<button class="button discard top" data-tooltip aria-haspopup="true" data-disable-hover="false"  title="Änderungen verwerfen"><i class="fa fa-times" aria-hidden="true"></i></button>-->
                            <!--</li>-->
                            <!--<li>-->
                            <!--<%= f.submit "Update", class: "button primary", :data => { disable_with: false } %>-->
                            <!--</li>-->
                            <li class="submit">
                                <button class="button-prime"  data-tooltip aria-haspopup="true" data-disable-hover="false"  title="Änderungen speichern"><i class="fa fa-check" aria-hidden="true"></i></button>
                            </li>
                        </ul>
                    </div>
                </div>
            </section>

            <div class="row">
                <div class="column">
                    <div class="detail-header editor">
                        <div class="type thema">
                            <span class="icon">
                                <i class="fa fa-folder-open" aria-hidden="true"></i>
                            </span>
                            <span class="title">Thema</span>
                        </div>

                        <a class="bookmark" href="#">
                            <span class="bookmarkinfo">zur Recherche hinzufügen</span>
                            <i class="fa fa-bookmark-o" aria-hidden="true"></i>
                        </a>

                        <!--<div class="tags">-->
                        <!--<% @creativeWork.classification_aliases.each do |classificationAlias| %>-->
                            <!--<span class="tag"><a href="#"><%= classificationAlias.name %></a></span>-->
                            <!--<% end %>-->
                        <!--</div>-->

                        <div id="validation_errors">

                        </div>

                        <% if !@creativeWork.metadata.nil? && !@creativeWork.metadata['validation'].nil? %>

                            <% validation = @creativeWork.metadata['validation'] %>
                            <!--<h2><%= "#{validation['name']} - #{validation['description']} - #{validation['type']}" %></h2>-->

                            <% if !validation['properties'].nil? %>

                                <% validation['properties'].each do |key, prop| %>

                                    <% if prop['type'] == 'object' && !prop['properties'].nil? %>
                                        <div class="data-object">
                                            <!--<div class="object-title"><strong><%= prop['label'] %></strong></div>-->
                                            <div class="object-inner row expanded">
                                                <% prop['properties'].each do |object_key, object_property| %>
                                                    <div class="columns medium-12 large-6">
                                                        <% object_value = @dataSchema[key].nil? ? "" : @dataSchema[key][object_key] %>
                                                        <div class="form-element">
                                                            <%= data_cycle_field object_key, object_property, object_value, {class: 'form-control'}, [key] %>
                                                        </div>
                                                    </div>
                                                <% end %>
                                            </div>
                                        </div>
                                    <% else %>
                                        <div class="form-element <%= key %>">
                                            <%= data_cycle_field key, prop, @dataSchema[key], class: 'form-control' %>
                                        </div>
                                    <% end %>

                                <% end %>

                            <% end %>

                        <% end %>

        <% end %>

        <!--<div class="dateModified">-->
        <!--<span class="icon"><i class="fa fa-clock-o" aria-hidden="true"></i> Gültigkeit</span>-->
        <!--<div class="form-element">-->
        <!--<label for="validFrom">Gültig von</label>-->
        <!--<input type="date" name="creative_work[datahash][validityPeriod][validFrom]" id="creative_work_datahash_validityPeriod_validFrom" value="2017-01-03" class="form-control" data-type="datepicker">-->
        <!--</div>-->
        <!--<span class="bis">bis</span>-->
        <!--<div class="form-element">-->
        <!--<label for="validFrom">Gültig von</label>-->
        <!--<input type="date" name="creative_work[datahash][validityPeriod][validFrom]" id="creative_work_datahash_validityPeriod_validFrom" value="2017-01-03" class="form-control" data-type="datepicker">-->
        <!--</div>-->
        <!--</div>-->

        </div>
        </div>
        </div>

    </div>

<% end %>

