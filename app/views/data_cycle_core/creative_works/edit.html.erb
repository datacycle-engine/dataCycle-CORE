
<% content_for :top_content do %>
   <div class="top-content text-center">
     <h2><%= @creativeWork.headline%></h2>
     <div class="description">
       <%= @creativeWork.description %>
     </div>
     <div class="tags">
       <% @creativeWork.classification_aliases.each do |classificationAlias| %>
           <span class="tag"><a href="#"><%= classificationAlias.name %></a></span>
       <% end %>
     </div>
     <%= link_to 'edit', edit_creative_work_path(@creativeWork) %>
   </div>
<% end %>

<%= form_for(@creativeWork) do |f| %>

    <%= f.text_field :headline, class: 'form-control' %>

    <%= f.text_area :description, class: 'form-control' %>

    <!--<div class="quill-editor" data-hidden-field-id="creative_work_description">-->

    <!--</div>-->

    <%= f.submit "Update", class: "button primary" %>
<% end %>
