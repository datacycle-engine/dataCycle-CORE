<% breadcrumb :show_history, @creativeWork, @watch_list %>

<% content_for :top_content do %>

    <div class="reveal-blur">

        <div id="edit-form">
            <section class="edit-header">
                <div class="row expanded">
                    <div class="column small-6">
                        <div class="edit-headline">
                            <i class="fa fa-history" aria-hidden="true"></i> <%= @creativeWork.content_type %> vergleichen
                        </div>
                    </div>
                    <div class="column small-6 text-overflow-hidden">
                      <% I18n.with_locale(@creativeWork.first_available_locale) do %>
                        <span class="type <%= @historySource.metadata['validation']['name'].downcase %>">
                        <%= render 'data_cycle_core/shared/icon', icon_type: @historySource.metadata['validation']['name'].downcase %>
                        <span class="title"><%= @creativeWork.content_type %></span>
                        <span class="language">(<%= I18n.locale %>)</span>
                        <%= render 'data_cycle_core/creative_works/partials/metaData', dataCycleObject: @creativeWork %>
                        </span>
                      <% end %>
                    </div>
                </div>
            </section>

            <div class="flex-box">

                <% I18n.with_locale(@historySource.first_available_locale) do %>

                    <div class="split-content detail-content">
                        <div class="show-content">
                            <div class="detail-header-info">
                                <div class="type <%= @historySource.metadata['validation']['name'].downcase %>">
                                    <span>Unterschiede zu Version: </span>
                                </div>
                                <%#= render 'data_cycle_core/creative_works/partials/history/metaData', dataCycleObject: @creativeWork, historyObject: @historySource, history: true %>
                                <%= render 'data_cycle_core/shared/history_links', dataCycleObject: @creativeWork, historyObject: @historySource, history: true %>

                            </div>

                            <%= render 'data_cycle_core/contents/viewers/metadata/releasable_viewer',
                                       value: @historySource.get_releasable_hash,
                                       key: 'creative_work',
                                       definition: {'type' => 'releasable'},
                                       options:{compare: true, force_render: true} if @historySource.metadata['validation'].dig('releasable') == true %>

                            <%= render_content_partial 'history', content: @historySource, schema: @historySchema, options: {force_render: true, compare: true} %>

                        </div>
                    </div>

                <% end %>

                <% I18n.with_locale(@creativeWork.first_available_locale) do %>

                    <div class="row split-content detail-content">

                        <div class="show-content">
                            <div class="detail-header-info">
                                <div class="type <%= @historySource.metadata['validation']['name'].downcase %>">
                                    <span>Aktuelle Version: </span>
                                </div>
                                <%= render 'data_cycle_core/creative_works/partials/history/metaData', dataCycleObject: @creativeWork, historyObject: @historySource %>
                            </div>

                            <%= render 'data_cycle_core/contents/viewers/metadata/releasable_viewer',
                                       value: @creativeWork.get_releasable_hash,
                                       key: 'creative_work',
                                       definition: {'type' => 'releasable'},
                                       options:{force_render: true} if @creativeWork.metadata['validation'].dig('releasable') == true %>

                            <%= render_content_partial 'history_details', content: @creativeWork, schema: @dataSchema, options: {force_render: true} %>

                        </div>

                    </div>

                <% end %>

            </div>

        </div>

    </div>

<% end %>
