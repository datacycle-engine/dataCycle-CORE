<% breadcrumb :show_history, @creativeWork %>

<% content_for :top_content do %>

    <div class="reveal-blur">

        <div id="edit-form">

            <section class="edit-header">
                <div class="row expanded">
                    <div class="column small-6">
                        <div class="edit-headline">
                            <i class="fa fa-history" aria-hidden="true"></i> <%= @creativeWork.content_type %> vergleichen
                        </div>
                    </div>
                    <div class="column small-6 text-right">
                        <div class="history-switcher">
                            <%= render 'data_cycle_core/shared/history_links', dataCycleObject: @creativeWork %>
                        </div>
                    </div>
                </div>
            </section>

            <div class="flex-box">

                <% I18n.with_locale(@creativeWork.first_available_locale) do %>

                    <div class="row split-content detail-content">

                        <div class="show-content">
                            <div class="detail-header-info">
                                <div class="type thema">
                                    <span class="icon">
                                        <i class="fa fa-folder-open" aria-hidden="true"></i>
                                    </span>
                                    <span class="title"><%= @creativeWork.content_type %></span>
                                    <span class="language">(<%= I18n.locale %>)</span>
                                </div>
                                <%= render 'data_cycle_core/creative_works/partials/history/metaData', dataCycleObject: @creativeWork, dataCycleObjectSchema: @dataSchema %>
                            </div>

                            <%= render_content_partial 'details', content: @creativeWork, schema: @dataSchema, options: {force_render: true} %>

                        </div>

                    </div>

                <% end %>

                <% I18n.with_locale(@historySource.first_available_locale) do %>

                    <div class="split-content detail-content">
                        <div class="show-content">
                            <div class="detail-header-info">
                                <div class="type thema">
                                    <span class="icon">
                                        <i class="fa fa-folder-open" aria-hidden="true"></i>
                                    </span>
                                    <span class="title"><%= @historySource.content_type %></span>
                                    <span class="language">(<%= I18n.locale %>)</span>
                                </div>
                                <%= render 'data_cycle_core/creative_works/partials/history/metaData', dataCycleObject: @historySource, dataCycleObjectSchema: @historySchema %>
                            </div>

                            <%= render_content_partial 'history', content: @historySource, schema: @historySchema, options: {force_render: true, compare: true} %>

                        </div>
                    </div>

                <% end %>

            </div>

        </div>

    </div>

<% end %>
