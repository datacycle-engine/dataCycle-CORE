$('<%= params[:new_overlay_id] %>').foundation('close');
$('<%= params[:overlay_id] %> .items .no-results').remove();

$('<%= params[:overlay_id] %>').find('.items .loading').before('<%= j render_object_browser_partial(key: params[:key] + (params[:definition]['type'] == "object" ? '[][id]' : '[]'), definition: params[:definition], parameters: {object: @organization, options: params[:options], objects: params[:objects], editable: params[:editable]}) if !@organization.nil? %>');

$('<%= params[:overlay_id] %>').find('.item-info').html('<%= escape_javascript(render_object_browser_partial(partial: 'detail', key: params[:key], definition: params[:definition], parameters: {object: @organization, options: params[:options]})) %>');

$('<%= params[:overlay_id] %>').trigger('import-complete', {id: '<%= @organization.id %>'});
