<% I18n.with_locale(params[:language] || I18n.locale) do %>
  $('#object_browser_<%= sanitize_to_id(params[:key]) %> .item-info').html('<%= escape_javascript(render_object_browser_partial(partial: 'detail', key: params[:key], definition: params[:definition], parameters: {object: @object, options: params[:options]})) %>');
<% end %>
