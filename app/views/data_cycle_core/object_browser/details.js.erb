$('#object_browser_<%= sanitize_to_id(params[:key]) %> .item-info-scrollable .has-tip').each(function(){
  $('#' + $(this).data('toggle')).remove();
});

<% I18n.with_locale(params[:locale] || I18n.locale) do %>
  $('#object_browser_<%= sanitize_to_id(params[:key]) %> .item-info-scrollable').html('<%= j render_object_browser_partial(partial: 'detail', key: params[:key], definition: params[:definition], parameters: {object: @object, options: params[:options]}) %>');
<% end %>

$('#object_browser_<%= sanitize_to_id(params[:key]) %> .item-info-scrollable').foundation().trigger('details-changed');
