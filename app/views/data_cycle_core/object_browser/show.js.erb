$('<%= params[:overlay_id] %>').data("total", <%= @total || 0 %>);
$('<%= params[:overlay_id] %>').find('.object-browser-header .item-count').text(<%= @total || 0 %>);
$('<%= params[:overlay_id] %>').find('.items .loading').hide();

<% content_for :rendered_items do %>
  <% @results.each do |content| %>
    <%= render_object_browser_partial(key: params[:key] + (params[:definition]['type'] == "object" ? '[][id]' : '[]'), definition: params[:definition], parameters: {object: content, options: params[:options], objects: params[:objects]}) %>
  <% end %>
<% end %>

$('<%= params[:overlay_id] %>').find('.items .loading').before('<%= (@total.nil? || @total.zero?) ? t('common.no_results') : j(yield :rendered_items) %>');
