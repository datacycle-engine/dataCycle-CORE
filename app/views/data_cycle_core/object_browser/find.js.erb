<% content_for :rendered_items, flush: true do %>
  <% I18n.with_locale(params[:language] || I18n.locale) do %>
    <% @objects.each do |content| %>
      <%= render_object_browser_partial(key: params[:key] + (params[:definition]['type'] == "object" ? '[][id]' : '[]'), definition: params[:definition], parameters: { object: content, options: params[:options], objects: params[:objects], editable: params[:editable] }) %>
    <% end %>
  <% end %>
<% end %>

var html_content = '<%= j yield :rendered_items %>';

$('#<%= sanitize_to_id(params[:key]) %> .object-thumbs').append(html_content);
$('#object_browser_<%= sanitize_to_id(params[:key]) %> .chosen-items-container').append(html_content);

$('#<%= sanitize_to_id(params[:key]) %> > .media-thumbs > .buttons > button.load-more-linked-contents').data('page', <%= params.fetch(:page, 1).to_i + 1 %>);
