<% I18n.with_locale(params[:language] || I18n.locale) do %>
  <% content_for :rendered_items do %>
    <% @objects.each do |content| %>
      <%= render_object_browser_partial(key: params[:key] + (params[:definition]['type'] == "object" ? '[][id]' : '[]'), definition: params[:definition], parameters: { object: content, options: params[:options], objects: params[:objects], editable: params[:editable] }) unless params[:objects].include?(content.id) %>
    <% end %>
  <% end %>

  $('<%= params[:object_browser_id] %>').find('.object-thumbs').append('<%= j yield :rendered_items %>');
  $('<%= params[:object_browser_id] %>').trigger('update-chosen', { chosen: <%== @objects.ids.to_json %> });
<% end %>
