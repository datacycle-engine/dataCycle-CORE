# frozen_string_literal: true

key_new = attribute_key(key, definition)

json ||= {}

classification_aliases = content.send(key).includes(:classification_aliases).map(&:classification_aliases).flatten.uniq
classification_string = classification_aliases
  .presence.map { |classification_alias| classification_alias.uri || classification_alias.name || classification_alias.internal_name }
  .join(',')

json = { key_new => classification_string } if classification_string.present?
json
