# frozen_string_literal: true

json ||= {}
key_new = attribute_key(key, definition)

data_value = load_value_object(content, key, value, options[:languages])

formated_value =
  ((definition.dig('api', 'format', 'prepend') unless definition.dig('api', 'format', 'prepend').nil?) || '') +
  value.to_s +
  ((definition.dig('api', 'format', 'append') unless definition.dig('api', 'format', 'append').nil?) || '')

json = { key_new.camelize(:lower) => formated_value } if data_value.present?
json
