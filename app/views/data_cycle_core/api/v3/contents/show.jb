# frozen_string_literal: true

Rails.cache.fetch("api_v3_#{@content.class}_#{@content.id}_#{@content.first_available_locale(@language)}_#{@content.updated_at}_#{@include_parameters.join('_')}_#{@mode_parameters.join('_')}", expires_in: 1.year + Random.rand(7.days)) do
  I18n.with_locale(@content.first_available_locale(@language)) do
    render 'content_details', content: @content
  end
end
