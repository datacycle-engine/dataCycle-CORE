<%
  default_options = {
    header_type: :full
  }

options = default_options.merge(defined?(options) ? options || {} : {})
%>

<schema:thing>

  <%= render *content_partial('context', content: content) %>
  <schema:id><%=xml_v1_thing_url(id: content)%></schema:id>
  <schema:identifier><%=content.id%></schema:identifier>
  <schema:url><%=send("#{content.class.class_name.tableize.singularize}_url", content, @language != I18n.available_locales.first.to_s ? { locale: @language } : {})%></schema:url>
