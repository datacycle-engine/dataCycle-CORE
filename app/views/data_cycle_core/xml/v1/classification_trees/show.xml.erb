<?xml version="1.0"?>

<rdf:RDF
  xmlns:rdf="http://schema.org"
  xmlns:ct="http://schema.org/rdf/">

  <rdf:ClassificationTree
    rdf:about="<%=classification_tree_label_url(id: @classification_tree_label.id)%>">
    <ct:id><%=@classification_tree_label.id%></ct:id>
    <ct:name><%=@classification_tree_label.name%></ct:name>
    <ct:url><%=xml_v1_classification_tree_url(@classification_tree_label, language: @language, api_subversion: @api_subversion)%></ct:url>
  </rdf:ClassificationTree>
</rdf:RDF>
