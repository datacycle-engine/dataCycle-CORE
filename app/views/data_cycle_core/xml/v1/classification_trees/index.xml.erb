<?xml version="1.0"?>

<rdf:RDF
  xmlns:rdf="http://schema.org"
  xmlns:ct="http://schema.org/rdf/">

<% @classification_tree_labels.each do |tree_label|%>
  <rdf:ClassificationTree
    rdf:about="<%=classification_tree_label_url(id: tree_label.id)%>">
    <ct:id><%=tree_label.id%></ct:id>
    <ct:name><%=tree_label.name%></ct:name>
    <ct:url><%=xml_v1_classification_tree_url(tree_label, language: @language, api_subversion: @api_subversion)%></ct:url>
  </rdf:ClassificationTree>
<% end %>
</rdf:RDF>
