<% if @assets.present? %>
  $('#<%= @html_target %>').html($('<%= j render 'data_cycle_core/assets/asset_list', assets: @assets, class: 'selectable', selected: @selected %>').find('li, h4.list-title'));
<% else %>
  $('#<%= @html_target %>').html('<%= t('common.contents', count: 0, locale: DataCycleCore.ui_language) %>');
<% end %>

