<%= form_with url: polymorphic_path([:download_indesign, content]),
              method: :get,
              local: true do %>

    <div class="form-crumbs"></div>

    <fieldset class="active template">
        <legend><%= t('common.choose_language', locale: DataCycleCore.ui_language) %></legend>
        <div class="form-element">
            <div class="v-select white">
                <%= select_tag('language[]',
                               options_for_select(
                                   available_locales_for_select(content),
                                   I18n.locale
                               ),
                               {
                                   multiple: false,
                                   class: 'multi-select'
                               }
                    ) %>
            </div>
        </div>
    </fieldset>

    <fieldset class="active serialize_formats">
        <legend><%= t('common.download.available_formats', locale: DataCycleCore.ui_language) %></legend>
        <div class="form-element">
            <% available_download_serializers(content).each_key.with_index do |serializer_key, i| %>
                <% next unless serializer_key == 'indesign' %>
                <div>
                    <%= radio_button_tag "serialize_format", serializer_key, true %>
                    <%= label_tag "serialize_format[#{serializer_key}]", "#{t("common.download.#{serializer_key}", locale: DataCycleCore.ui_language)}" %>
                </div>
            <% end %>
        </div>
    </fieldset>

    <div class="buttons">
        <%= button_tag 'download',
                       type: :submit,
                       class: "button submit" %>
    </div>

<% end %>

