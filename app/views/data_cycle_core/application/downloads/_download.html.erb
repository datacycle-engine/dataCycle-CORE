<a data-toggle="download_<%= content.id %>" class="button-prime small download-content-link" title="<%= t('actions.download_content', locale: DataCycleCore.ui_language) %>" data-tooltip>
    <i class="fa fa-download" aria-hidden="true"></i>
</a>

<div class="reveal download-content-reveal"
     id="download_<%= content.id %>"
     data-reveal>
    <h3 class="new_content_form_title"><%= t('actions.download_content', locale: DataCycleCore.ui_language) %></h3>

    <% available_download_serializers(content).each_key do |serializer_key| %>

        <%= link_to polymorphic_path([:download, content], serialize_format: serializer_key), class:'small download-content-link', title: "#{t('common.download.' + serializer_key, locale: DataCycleCore.ui_language)} #{t('actions.download', locale: DataCycleCore.ui_language)}" do %>
            <i class="fa fa-download" aria-hidden="true"></i>
            <span><%= t("common.download.#{serializer_key}", locale: DataCycleCore.ui_language) %></span>
        <% end %>

    <% end %>

    <button class="close-button" data-close aria-label="Close modal" type="button">
        <span aria-hidden="true">&times;</span>
    </button>
</div>