<% set_key_prefix keyPrefix %>

<%= render_content_partial 'edit_header_functions', content: content %>

<%= form_for content, url: polymorphic_path(content, watch_list_id: @watch_list), html: {class: 'edit-content-form'}, builder: DataCycleCore::DataHashHelper::DataCycleFormBuilder do |f| %>
	<%= hidden_field_tag 'uuid', content.id %>
  <%= hidden_field_tag 'locale', I18n.locale %>

	<% unless @splitSource.nil? %>
		<% I18n.with_locale(@splitSource.first_available_locale) do %>
			<div class="flex-box">
				<div class="split-content detail-content">
          <%= hidden_field_tag 'splitview', true %>
					<% if can?(:subscribe, @splitSource) && @splitSource.subscriptions.by_user(current_user).size == 0 %>
						<div class="subscribe-parent notice"><p>Sie sollten diesen Inhalt (<%=@splitSource.metadata['validation']['name']%>) abonnieren, um Ihren neu erstellten Inhalt (<%=content.metadata['validation']['name']%>) aktuell halten zu können.</p>
							<%= link_to "Abonnieren", subscriptions_path(subscribable_id: @splitSource.id, subscribable_type: @splitSource.class.name), method: :post %>

							<button name="button" type="button" class="close-subscribe-notice" data-close="" aria-label="Dismiss Notice"><span aria-hidden="true">×</span></button>
						</div>
					<% end %>
					<div class="show-content">
						<div class="detail-header-info">
							<div class="type <%= @splitSource.metadata['validation']['name'].downcase %>">
								<%= render_content_partial 'icon', content: @splitSource %>

								<span class="title"><%= @splitSource.metadata['validation']['name'] %></span>
								<% unless @splitSource.translated_locales.size > 1 %>
									<span class="language">(<%= I18n.locale %>)</span>
								<% end %>
							</div>
							<%= render 'data_cycle_core/creative_works/partials/metaData', dataCycleObject: @splitSource, dataCycleObjectSchema: @splitSchema %>
						</div>

						<%= render_content_partial 'details', content: @splitSource, schema: @splitSchema, options: {force_render: true} %>

					</div>
				</div>
		<% end %>
	<% end %>

	<div class="row<%= ' split-content edit-content' unless @splitSource.nil? %>">
		<div class="column">
			<div class="detail-header editor">

				<div class="detail-header-info">
					<div class="type <%= content.content_type.downcase %>">
						<%= render_content_partial 'icon', content: content %>

						<span class="title"><%= content.content_type %></span>
            <span class="language">(<%= I18n.locale %>)</span>
					</div>
					<%= render 'data_cycle_core/creative_works/partials/metaData', dataCycleObject: content, dataCycleObjectSchema: dataSchema %>
				</div>

				<a class="bookmark" href="#">
					<span class="bookmarkinfo">zur Recherche hinzufügen</span>
					<i class="fa fa-bookmark-o" aria-hidden="true"></i>
				</a>

				<div id="validation_errors">

				</div>

				<% if !content.metadata.nil? && !content.metadata['validation'].nil? %>

					<% validation_properties = get_ordered_validation_properties(content.metadata['validation']) %>

					<%= render 'data_cycle_core/contents/editors/metadata/releasable_editor',
							   value: {'release_id' => content.release_id, 'release_comment' => content.release_comment},
							   key: 'creative_work',
							   definition: {'type' => 'releasable'},
							   options:{} if content.metadata['validation'].dig('releasable') == true %>

					<% if !validation_properties.nil? %>

						<% validation_properties.each do |key, prop| %>

							<% value = prop.dig('type') == "object" ? content.try(key.to_sym) : dataSchema[key] %>

              <%== '<span class="translated"><i class="fa fa-language" aria-hidden="true"></i></span>' if (content.translated_attributes.keys&.include?(key) || content.translated_attributes['content']&.keys&.include?(key)) && DataCycleCore.translatable_types.include?(content.class.name) %>

							<%= render_attribute_editor key: "#{keyPrefix}[#{key}]", definition: prop, value: value, parameters: { options: prop.dig('editor', 'options') || {} } unless dataSchema.nil? %>

						<% end %>

					<% end %>

				<% end %>

			</div>
		</div>
	</div>

	<% unless @splitSource.nil? %>
		</div>
	<% end %>

<% end %>
