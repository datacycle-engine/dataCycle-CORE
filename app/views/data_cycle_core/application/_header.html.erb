<header>
    <div class="top-bar">
        <div class="top-bar-title">
            <%= link_to '/' do %>
              <%= render 'logo' %>
              <%= yield :menu_title %>
            <% end %>
        </div>
        <div class="top-bar-right" id="main-menu">
            <ul class="menu">
                <% if DataCycleCore.asset_objects.any? { |a| can?(:create, a.classify.constantize) } %>
                  <li>
                    <a class="content-upload-link" data-open="asset-upload-reveal-default">
                      <i class="fa fa-upload" aria-hidden="true"></i>
                      <%= t('data_cycle_core.upload', locale: DataCycleCore.ui_language) %>
                    </a>
                    <%= render 'asset_upload' %>
                  </li>
                <% end %>
                <li>
                    <% if can?(:read, DataCycleCore::WatchList) %>
                        <%= render 'watch_lists' %>
                    <% end %>
                </li>
                <li>
                    <%= link_to '/info' do %>
                        <i class="fa fa-question" aria-hidden="true"></i><span>Info</span>
                    <% end %>
                </li>
                <% if user_signed_in? %>
                    <li>
                        <button type="button" class="button show-sidebar" data-toggle="settings-off-canvas">
                            <span><%= current_user.email %></span><i class="fa fa-smile-o icon-right" aria-hidden="true"></i>
                        </button>
                    </li>
                <% else %>
                    <li>
                        <%= link_to data_cycle_core.new_user_session_path do %>
                            <span>Login</span><i class="fa fa-smile-o icon-right" aria-hidden="true"></i>
                        <% end %>
                    </li>
                <% end %>
            </ul>
        </div>
    </div>
</header>
