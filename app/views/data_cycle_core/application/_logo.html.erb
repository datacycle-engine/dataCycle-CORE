<span class="logo">
    <%= image_tag 'logo.svg', { alt: 'dataCycle Logo', class: 'hide-for-print', style: 'height: 3rem;' }.merge(local_assigns[:options] || {}) %>
    <%= image_tag 'logo.png', { alt: 'dataCycle Logo', style: 'height: 3rem;', class: 'show-for-print' }.merge(local_assigns[:options] || {}) unless local_assigns[:email] %>
</span>
