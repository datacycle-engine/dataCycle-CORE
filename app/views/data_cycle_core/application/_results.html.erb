<section class="search-results">
  <% if @total.presence&.positive? %>

    <ul class="grid no-bullet no-format <%= @mode %>">
      <%= render 'data_cycle_core/application/presentation/grid', contents: contents %>
    </ul>

  <% else %>

    <div class="row">
      <div class="small-12">
        <span class="no-results"><%= t('common.no_results', locale: DataCycleCore.ui_language) %></span>
      </div>
    </div>

  <% end %>
</section>
