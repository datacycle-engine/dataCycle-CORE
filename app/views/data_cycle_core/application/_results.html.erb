<section class="search-results">

    <% if contents&.size&.positive? %>

        <div class="row">
            <div class="small-12">
                <%= paginate @paginateObject %>
            </div>
        </div>

        <%# if @mode == 'list' %>
            <%#= render 'data_cycle_core/backend/partials/list', dataCycleObjects: contents %>
        <%# else %>
        <%# end %>

        <%= render 'data_cycle_core/application/presentation/grid', contents: contents %>

        <div class="row">
            <div class="small-12">
                <%= paginate @paginateObject %>
            </div>
        </div>

    <% else %>

        <div class="row">
            <div class="small-12">
                <span class="no-results"><%= t('common.no_results', locale: DataCycleCore.ui_language) %></span>
            </div>
        </div>

    <% end %>

</section>
