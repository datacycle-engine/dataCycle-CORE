<section class="search-results" id="search-results">
  <% @mode ||= 'grid' %>

  <div class="mode-container">
    <span class="result-count">
      <span class="count-full remote-render"
        id="count-full-results"
        data-remote-render-params="<%= to_query_params(request.params.slice(:language, :f, :stored_filter, :watch_list_id, :id, :q, :roles, :user_groups).merge({ action: controller.action_name, controller: controller.controller_name, mode: @mode, count_only: true, ctl_id: @classification_tree_label&.id, content_class: local_assigns[:content_class] || 'things', count_mode: @classification_tree_label.nil? ? nil : 'classification_tree_label' })).to_json %>"
        >-</span>
    </span>

    <% if content_for?(:sortable) || local_assigns[:sortable].present? %>
      <%= yield :sortable %>
      <span class="filter-sortable">
        <span class="filter-sortable-select-wrapper">
          <%= select_tag(
                        "s[v][m]",
                        options_for_select(
                            sortable.map { |s|
                              [
                                  s.dig(:label),
                                  s.dig(:method)
                              ]
                            }, @sort_params.presence&.first&.dig('m')
                        ),
                        {:include_blank => I18n.t('sortable.default', default: 'default', locale: DataCycleCore.ui_language)}
                    ) %>
        </span>
        <span class="filter-sortable-checkbox-wrapper">
          <%= check_box nil,
                              "s[v][o]",
                              {
                                  checked: @sort_params.presence&.first&.dig('o') == 'ASC'
                              },
                              'ASC',
                              'DESC' %>
          <label for="s[v][o]">&nbsp;</label>
        </span>
      </span>
    <% end %>

    <% if DataCycleCore::Feature::ViewMode.enabled? %>
      <div class="mode-switcher">
        <% Array(local_assigns[:modes] || 'grid').each do |mode| %>
          <%= mode_link(mode, @mode == mode, request.params) %>
        <% end %>
      </div>
    <% end %>
  </div>

  <% if @mode == 'tree' || contents.present? %>

    <ul class="no-bullet no-format <%= @mode %>">
      <%= render "data_cycle_core/application/presentation/#{valid_mode(@mode)}", contents: contents %>
    </ul>

  <% else %>

    <div class="row">
      <div class="small-12">
        <span class="no-results"><%= t('common.no_results', locale: DataCycleCore.ui_language) %></span>
      </div>
    </div>

  <% end %>
</section>
