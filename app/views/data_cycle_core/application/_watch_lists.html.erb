<% content ||= nil %>
<% if content && !@watch_list&.id.nil? && @watch_list.persisted? && controller_name == 'watch_lists' %>

  <%= link_to remove_item_watch_list_path(@watch_list, hashable_type: content&.class&.name, hashable_id: content&.id), class: 'remove-from-watchlist-link watch-lists-link', method: :delete, data: { confirm: "Inhalt (#{content&.title}) von<br>Merkliste (#{@watch_list&.headline}) entfernen?" } do %>
      <i aria-hidden="true" class="fa fa-times"></i>
  <% end if can?(:remove_item, @watch_list) %>

<% elsif content %>

  <%= render 'data_cycle_core/application/watch_lists/editable_links', content: content %>

<% else %>

  <%= render 'data_cycle_core/application/watch_lists/non_editable_links' %>

<% end %>
