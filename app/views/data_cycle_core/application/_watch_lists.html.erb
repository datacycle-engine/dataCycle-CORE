<% content ||= nil %>
<% if content && !@watch_list&.id.nil? && @watch_list.persisted? && controller_name == 'watch_lists' %>

  <%= button_to tag.i(class: 'fa fa-times-circle'),
    remove_item_watch_list_path(@watch_list, thing_id: content&.id, load_more: true),
    class: 'button icon warning',
    method: :delete,
    data: {
      dc_tooltip: t('actions.remove_from', collection: @watch_list.name, locale: active_ui_locale),
    },
    form: {
      class: 'remove-from-watchlist-link watch-lists-link',
      data: {
        turbo: true,
        turbo_stream: true
      }.merge(@watch_list.my_selection ? {} : {
        turbo_confirm: t('actions.remove_content_from', name: I18n.with_locale(content&.first_available_locale){ content&.title }, collection: @watch_list.name, locale: active_ui_locale)
      })
    } if can?(:remove_item, @watch_list) %>

   <i class="fa fa-check watch-list-tile-checkbox hidden" aria-hidden="true"></i>
<% elsif content %>

  <%= render 'data_cycle_core/application/watch_lists/editable_links', content: content, prefix: local_assigns[:prefix] %>

<% else %>

  <%= render 'data_cycle_core/application/watch_lists/readable_links' %>

<% end %>
