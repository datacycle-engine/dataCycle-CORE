<div class="settings-row">
  <div class="row columns">
    <h5><%= t('data_cycle_core.user_details', locale: DataCycleCore.ui_language) %></h5>
  </div>
  <div class="row columns">
    <span class="icon"><i class="fa fa-smile-o" aria-hidden="true"></i></span>
    <span class="title"><%= current_user&.full_name %></span>
  </div>
  <% if current_user.access_token.present? %>
    <div class="row columns access-token">
      <span class="icon"><i class="fa fa-key" aria-hidden="true"></i></span>
      <span class="title copy-to-clipboard with-shadow" title="<%= DataCycleCore::User.human_attribute_name(:access_token, locale: DataCycleCore.ui_language) %>" data-value="<%= current_user.access_token %>"><%= current_user.access_token %></span>
    </div>
  <% end %>
</div>
