<div class="settings-row">
  <div class="row columns">
    <h5><%= t('data_cycle_core.user_links', locale: DataCycleCore.ui_language) %></h5>
  </div>
  <% if user_signed_in? && current_user.role&.rank&.positive? %>
    <div class="row columns">
      <%= link_to subscriptions_path, class: 'user-subscriptions-link' do %>
        <span class="icon"><i class="fa fa-bell" aria-hidden="true"></i></span>
        <span class="title"><%= DataCycleCore::Subscription.model_name.human(count: 2, locale: DataCycleCore.ui_language) %></span>
      <% end %>
    </div>
  <% end %>
  <% if DataCycleCore::Feature::PublicationSchedule.enabled? && can?(:index, :publication) %>
    <div class="row columns">
        <%= link_to publications_path, class: 'publications-link' do %>
          <span class="icon"><i class="fa fa-calendar" aria-hidden="true"></i></span>
          <span class="title"><%= t('data_cycle_core.publications_calendar', locale: DataCycleCore.ui_language) %></span>
        <% end %>
      </div>
  <% end %>
  <% if user_signed_in? && current_user.role&.rank&.positive? && DataCycleCore::ClassificationTreeLabel.find_by(name: 'Themenbereiche').present? %>
    <div class="row columns">
      <%= link_to classification_tree_label_path(DataCycleCore::ClassificationTreeLabel.find_by(name: 'Themenbereiche')), class: 'themenbereiche-contents-list-link' do %>
        <span class="icon"><i class="fa fa-list-ul" aria-hidden="true"></i></span>
        <span class="title"><%= t('data_cycle_core.classification_tree_label', locale: DataCycleCore.ui_language) %></span>
      <% end %>
    </div>
  <% end %>
  <% if DataCycleCore.asset_objects.any? { |a| can?(:create, a.classify.constantize) } %>
    <div class="row columns">
      <a class="asset-selector-button-second" data-open="asset-selector-default">
        <span class="icon"><i class="fa fa-files-o" aria-hidden="true"></i></span>
        <span class="title"><%= t('common.my_assets', locale: DataCycleCore.ui_language) %></span>
      </a>
    </div>
  <% end %>
  <%= yield :additional_user_links %>
</div>
