<%# SECURITY (DC-01): only callers allowed to view a content's admin panel may render this %>
<%# remote_render partial (mirrors _datahash/_schema/_template_path). %>
<% if content.present? && can?(:show_admin_panel, content) %>
  <% json_api_show = DataCycleCore::ApiRenderer::ThingRendererV4.new(
        content: content,
        language: [I18n.locale.to_s]
      ).render(:json) || {}.to_json %>

  <code class="formatted-json" data-json="<%= json_api_show %>"></code>
<% end %>
