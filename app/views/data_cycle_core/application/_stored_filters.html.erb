<div class="dropdown-menu-item">
  <i class="fa fa-clock-o" aria-hidden="true"></i>
  <span class="title"><%= t('data_cycle_core.stored_searches.last', locale: DataCycleCore.ui_language) %></span>

  <ul class="no-bullet">
    <% @accessible_stored_filters.order(created_at: :desc).first(5).each do |stored_filter| %>
        <li>
          <%= link_to root_path(stored_filter: stored_filter.id) do %>
            <span class="stored-date"><i class="fa fa-clock-o" aria-hidden="true"></i> <%= "vor #{time_ago_in_words stored_filter.created_at}" %></span>
            <span class="stored-filter-params">
              <%= render 'data_cycle_core/application/filters/search_params', stored_search: stored_filter %>
            </span>
          <% end %>
        </li>
    <% end %>
    <li><%= link_to t('data_cycle_core.stored_searches.show_search_history', locale: DataCycleCore.ui_language), stored_filters_path(anchor: 'searches-history'), class: 'button' %></li>
  </ul>
</div>

<div class="dropdown-menu-item">
  <i class="fa fa-bookmark" aria-hidden="true"></i>
  <span class="title"><%= t('data_cycle_core.stored_searches.saved', count: 2, locale: DataCycleCore.ui_language) %></span>

  <ul class="no-bullet">
    <% @accessible_stored_filters.where.not(name: nil).order(updated_at: :desc).first(5).each do |stored_filter| %>
        <li>
          <%= link_to root_path(stored_filter: stored_filter.id) do %>
            <span class="title <%= 'global' if stored_filter.system %>"><i class="fa fa-bookmark" aria-hidden="true"></i> <%= stored_filter.name %></span>
            <span class="stored-date right"><i class="fa fa-clock-o" aria-hidden="true"></i> <%= l(Time.zone.at(stored_filter.created_at.to_datetime), locale: DataCycleCore.ui_language) %></span>
          <% end %>
        </li>
    <% end %>
    <li><%= link_to t('data_cycle_core.stored_searches.show_all_saved', count: 1, locale: DataCycleCore.ui_language), stored_filters_path(anchor: 'searches-saved'), class: 'button' %></li>
  </ul>
</div>
