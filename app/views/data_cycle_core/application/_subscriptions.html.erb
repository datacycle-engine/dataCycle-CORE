<% if content.subscriptions.by_user(current_user).size > 0 %>
    <%= t('common.unsubscribe_text', locale: DataCycleCore.ui_language) %><br />
    <%= link_to t('actions.unsubscribe', locale: DataCycleCore.ui_language), subscription_path(content.subscriptions.by_user(current_user).first), remote: true, method: :delete, class: 'button', data: { disable_with: '<i class="fa fa-circle-o-notch fa-spin fa-fw"></i> ' + t('actions.unsubscribe', locale: DataCycleCore.ui_language) } %>
<% else %>
    <%= t('common.subscribe_text', locale: DataCycleCore.ui_language) %><br />
    <%= link_to t('actions.subscribe', locale: DataCycleCore.ui_language).capitalize, subscriptions_path(subscribable_id: content.id, subscribable_type: content.class.name), remote: true, method: :post, class: 'button', data: { disable_with: '<i class="fa fa-circle-o-notch fa-spin fa-fw"></i> ' + t('actions.subscribe', locale: DataCycleCore.ui_language).capitalize } %>
<% end %>
