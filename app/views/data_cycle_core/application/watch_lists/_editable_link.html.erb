<li id="content-<%= content&.id %>-watch-list-<%= watch_list&.id %>">
  <% linked_watch_lists = watch_list.watch_list_data_hashes.any? { |w| w.hashable_id == content.id && w.hashable_type == 'DataCycleCore::Thing' } %>
  <span class="watch-list-item <%= watch_list.user == current_user ? 'private' : 'shared' %>">
    <span class="check <%= 'checked' if linked_watch_lists %>"><i class="fa fa-check" aria-hidden="true"></i></span>
    <span class="watchlist-name">
      <%= link_to_if !linked_watch_lists && can?(:add_item, watch_list),
        (watch_list.watch_list_shares.any? ? tag.i(class: 'fa fa-users') : '') + watch_list.name,
        add_item_watch_list_path(watch_list, hashable_type: content&.class&.name, hashable_id: content),
        class: 'add-to-watchlist-link',
        remote: true,
        title: watch_list.name %>
    </span>
    <span class="change-link">
      <% if linked_watch_lists && can?(:remove_item, watch_list) %>
        <%= link_to remove_item_watch_list_path(watch_list, hashable_type: content&.class&.name, hashable_id: content&.id),
          class: 'remove-from-watchlist-link',
          remote: true,
          method: :delete,
          data: {
            confirm: "Inhalt (#{I18n.with_locale(content&.first_available_locale){ content&.title }}) von<br>#{DataCycleCore::WatchList.model_name.human(count: 1, locale: DataCycleCore.ui_language)} (#{watch_list.name}) entfernen?",
            disable_with: tag.i(class: 'fa fa-circle-o-notch fa-spin fa-3x fa-fw')
          } do %>
          <i aria-hidden="true" class="fa fa-times-circle"></i>
        <% end %>
      <% elsif can?(:add_item, watch_list) %>
        <%= link_to add_item_watch_list_path(watch_list, hashable_type: content&.class&.name, hashable_id: content), class: 'add-to-watchlist-link', remote: true, data: {
          disable_with: tag.i(class: 'fa fa-circle-o-notch fa-spin fa-fw')
        } do %>
          <i class="fa fa-plus-circle" aria-hidden="true"></i>
        <% end %>
      <% else %>
        <i class="fa fa-exclamation-circle dc-foundation-tooltip" title="<%= t('data_cycle_core.watch_list.locked_by_data_link', locale: DataCycleCore.ui_language) %>" aria-hidden="true"></i>
      <% end %>
    </span>
  </span>
</li>
