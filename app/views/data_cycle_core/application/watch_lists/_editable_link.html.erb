<li
  id="content-<%= content&.id %>-watch-list-<%= watch_list&.id %>"
  class="<%= 'my-selection' if watch_list.my_selection %>"
>
  <% linked_watch_lists = watch_list.watch_list_data_hashes.exists?(thing_id: content&.id) %>

  <span class="watch-list-item <%= watch_list.user == current_user ? 'private' : 'shared' %>">
    <span class="check <%= 'checked' if linked_watch_lists %>">
      <i class="fa fa-check" aria-hidden="true"></i>
    </span>

    <span class="watchlist-name">
      <%= if !linked_watch_lists && can?(:add_item, watch_list)
          button_to watch_list_list_title(watch_list),
            add_item_watch_list_path(watch_list, thing_id: content),
            class: 'add-to-watchlist-link',
            method: :post,
            remote: true
        else
          watch_list_list_title(watch_list)
        end %>
    </span>

    <span class="change-link">
      <%= if linked_watch_lists && can?(:remove_item, watch_list)
        button_to tag.i(class: 'fa fa-times-circle', aria_hidden: 'true'), remove_item_watch_list_path(watch_list, thing_id: content&.id),
          class: 'remove-from-watchlist-link button icon warning',
          remote: true,
          method: :delete,
          data: {
            disable_with: tag.i(class: 'fa fa-spinner fa-spin fa-fw')
          }.merge(watch_list.my_selection ? {} : {
            confirmation_class: 'warning',
            confirm: t('actions.remove_content_from', name: I18n.with_locale(content&.first_available_locale){ content&.title }, collection: watch_list.name, locale: active_ui_locale)
          })
        elsif can?(:add_item, watch_list)
          button_to tag.i(class: 'fa fa-plus-circle', aria_hidden: 'true'), add_item_watch_list_path(watch_list, thing_id: content),
          class: 'add-to-watchlist-link button icon primary',
          remote: true,
          method: :post,
          data: {
            disable_with: tag.i(class: 'fa fa-spinner fa-spin fa-fw')
          }
        end %>
    </span>
  </span>
</li>
