<span class="watch-list-item" id="content-<%= content&.id %>-watch-list-<%= watchlist&.id %>">
  <span class="check checked"><i class="fa fa-check" aria-hidden="true"></i></span>
  <span class="watchlist-headline">
      <%= watchlist.headline %>
  </span>
  <span class="change-link">
  <%= link_to remove_item_watch_list_path(watchlist, hashable_type: content.class.name, hashable_id: content.id), class: 'remove-from-watchlist-link', remote: true, method: :delete, data: { confirm: "Inhalt (#{content.title}) von<br>Merkliste (#{watchlist.headline}) entfernen?" } do %>
      <i aria-hidden="true" class="fa fa-times-circle"></i>
  <% end %>
  </span>
</span>