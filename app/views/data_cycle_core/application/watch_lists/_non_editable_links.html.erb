<a id="add-to-watchlist-link" class="hascontent watch-lists-link" data-toggle="watch-lists-for-user"><%= DataCycleCore::WatchList.model_name.human(count: 2, locale: DataCycleCore.ui_language) %></a>
<div class="dropdown-pane no-bullet bottom watch-lists" id="watch-lists-for-user" data-dropdown data-hover="true" data-hover-pane="true">
    <ul class="list-items">
      <% @accessible_watch_lists.each do |watchlist| %>
          <li>
            <%= render 'data_cycle_core/application/watch_lists/read_link', watchlist: watchlist %>
          </li>
      <% end %>
    </ul>
    <%= render 'data_cycle_core/application/watch_lists/new', content: nil %>

</div>
