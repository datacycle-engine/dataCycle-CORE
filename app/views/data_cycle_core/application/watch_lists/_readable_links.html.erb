<a id="add-to-watchlist-link" class="hascontent watch-lists-link" data-toggle="watch-lists-for-user"><%= DataCycleCore::WatchList.model_name.human(count: 2, locale: DataCycleCore.ui_language) %></a>

<div class="dropdown-pane no-bullet bottom left watch-lists"
  id="watch-lists-for-user"
  data-dropdown>
  <%= render 'data_cycle_core/application/watch_lists/filter', local_assigns %>
  <ul class="list-items no-bullet remote-render"
    id="watch-lists-for-menu"
    data-remote-path="data_cycle_core/application/watch_lists/readable_link_collection"
    data-remote-options="<%= to_query_params(local_assigns).to_json %>">
  </ul>
  <%= render 'data_cycle_core/application/watch_lists/new', content: nil %>
</div>
