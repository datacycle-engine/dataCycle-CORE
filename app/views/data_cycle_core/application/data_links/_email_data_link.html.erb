<% if data_link.id.nil? %>
  <button class="button new-data-link" data-open="data-link-overlay-<%= data_link.id || "new" %>">Neuen Link erstellen</button>
  <%= render 'data_cycle_core/data_links/form', local_assigns %>
<% else %>
  <li class="<%= "invalid" unless data_link.is_valid? %>" id="data-link-<%= data_link.id %>">
    <span class="email" title="<%= data_link.receiver&.email %>"><%= data_link.receiver&.email %></span>
    <span class="buttons">
      <% unless data_link.creator == current_user %>
        <i class="fa fa-user"
          aria-hidden="true"
          title="<%= "<b>#{t('common.creator', locale: DataCycleCore.ui_language)}:</b> #{data_link.creator.full_name} &#x3C;#{data_link.creator.email}&#x3E;" if data_link.creator.present? %>"
          data-tooltip
          data-allow-html="true"></i>
      <% end %>
      <% if data_link.valid_from.present? || data_link.valid_until.present? %>
        <i class="fa fa-calendar"
          aria-hidden="true"
          title="<%= t('terms.valid', locale: DataCycleCore.ui_language) +
            (data_link.valid_from.present? ? " #{t('terms.from', locale: DataCycleCore.ui_language)} #{l(data_link.valid_from.to_date, locale: DataCycleCore.ui_language)}" : '') +
            (data_link.valid_until.present? ? " #{t('terms.until', locale: DataCycleCore.ui_language)} #{l(data_link.valid_until.to_date, locale: DataCycleCore.ui_language)}" : '') %>"
          data-tooltip></i>
      <% end %>
      <% if can?(:edit, data_link) %>
        <span class="send-link-button" data-open="data-link-overlay-<%= data_link.id || "new" %>" title="<%= t('actions.edit', locale: DataCycleCore.ui_language) %>" data-tooltip><i class="fa fa-pencil" aria-hidden="true"></i></span>
        <%= link_to '<i class="fa fa-ban" aria-hidden="true"></i>'.html_safe, data_link, method: :delete, class: 'invalidate-data-link', title: t('actions.lock', locale: DataCycleCore.ui_language), data: { tooltip: true } if data_link.is_valid? %>
        <%= render 'data_cycle_core/data_links/form', local_assigns %>
      <% end %>
    </span>
  </li>
<% end %>
