<div class="filter-minimal column">
  <%= form_tag('', :method => "get", id: "search-form") do %>
    <% excluded_types = DataCycleCore.excluded_filter_classifications %>

    <section class="filters">
      <div class="row">
          <div class="accordion" data-responsive-accordion-tabs="accordion medium-tabs large-accordion" data-allow-all-closed="true">
            <div class="accordion-item" data-accordion-item>
              <div class="accordion2-content" data-tab-content>

                <div class="main-filters">

                    <nav id="primary_nav_wrap">

                        <% classification_tree_labels = ['Inhaltstypen'] %>

                        <% classification_trees = DataCycleCore::ClassificationTreeLabel.where(name: classification_tree_labels).map{|l| {l.name => l.classification_trees.includes(:parent_classification_alias, sub_classification_alias: [sub_classification_alias: [sub_classification_alias: [:sub_classification_alias]]]).where(parent_classification_alias: nil).map(&:sub_classification_alias).select { |type| !excluded_types.include?(type.name) } } }.reduce(:merge) %>

                        <ul>
                            <%= render 'data_cycle_core/application/filters/classification_tree', tree_label: 'Inhaltstypen', display_label: 'Typ', li_class: "subtree", excluded_types: excluded_types, classification_trees: classification_trees %>

                            <%= render 'data_cycle_core/application/filters/sprache' %>

                            <div class="search">
                                <div class="input-group">
                                    <div class="input-group-button">
                                        <button type="submit" class="search_icon "><i class="fa fa-search" aria-hidden="true"></i></button>
                                    </div>
                                    <%= text_field_tag :search, params[:search], placeholder: t('common.searchterm', locale: DataCycleCore.ui_language),class:"input-group-field" %>
                                </div>
                            </div>

                            <div class=" filterbuttons">
                                <button type="reset" id="reset-filter" class="button"><%= t('actions.reset', count: 2, locale: DataCycleCore.ui_language) %></button>
                                <%= button_tag(t('actions.filter', locale: DataCycleCore.ui_language), class: "button success") %>
                            </div>
                        </ul>
                    </nav>

                </div>
              </div>
              <a href="#" class="accordion-title"><span><i class="fa fa-chevron-down" aria-hidden="true"></i><span class="closed"><%= t('common.filter.show') %></span><span class="open"><%= t('common.filter.hide') %></span> </span></a>

            </div>
          </div>
          <div class="filtertags activefilter">
              <span class="icon"><i class="fa fa-check" aria-hidden="true"></i> <strong><%= t('common.active_filters', locale: DataCycleCore.ui_language) %></strong>
              <% unless @total.zero? %>
                <span class="result-count">(<strong><%= @total %></strong> <%= t('common.contents', count: @total, locale: DataCycleCore.ui_language) %>)</span>
              <% end %>
              <strong>:</strong> </span>

              <span class="your-choice tags sprache">
                <i class="choice-label"><%= t('common.language', locale: DataCycleCore.ui_language) %>:</i>
                <% lang = params[:language] || 'de' %>
                  <a class="tag">
                    <%= available_locales_with_names[lang.try(:to_sym)] %>
                  </a>
                </span>

              <% classification_tree_labels.each do |label| %>
                  <% selected_classifications = get_classifications_for_id(@classification_array, label)  %>
                  <span class="your-choice tags <%= label.downcase %>" style="<%= "display: none;" if selected_classifications.blank? %>">
                      <i class="choice-label"><%= label %>:</i>
                      <% unless selected_classifications.blank? %>
                          <% selected_classifications.each do |selected| %>
                              <label for="<%= selected.id %>">
                                  <a class="tag">
                                      <%= selected.name %><i class="fa fa-times" aria-hidden="true"></i>
                                  </a>
                              </label>
                          <% end %>
                      <% end %>
                  </span>
              <% end %>
          </div>

      </div>
    </section>

  <% end %>

</div>
