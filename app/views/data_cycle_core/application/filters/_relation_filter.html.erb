<div data-id="<%= filter_name%>_<%= index %>" data-index="<%= index %>" class="advanced-filter <%= filter_method || 'i' %>" data-label="<%= filter_name %>">
  <%= hidden_field_tag "f[#{index}][t]", 'relation_filter' %>
  <%= hidden_field_tag "f[#{index}][n]", filter_title %>
  <%= hidden_field_tag "f[#{index}][q]", filter_advanced_type %>
  <%= hidden_field_tag "f[#{index}][c]", 'a' %>

  <div class="advanced-filter-title">
    <%= render 'data_cycle_core/shared/icon', icon_type: filter_name %>
    <span><%= t("filter.#{filter_name}", default: filter_title, locale: DataCycleCore.ui_language) %></span>
  </div>
  <div class="advanced-filter-mode">
    <%= select_tag "f[#{index}][m]", options_for_select([[t("filter.relation_filter.contained_in", locale: DataCycleCore.ui_language), 'i'], [t("filter.relation_filter.not_contained_in", locale: DataCycleCore.ui_language), 'e']], filter_method) %>
  </div>

  <div class="advanced-filter-selector">
    <%= select_tag("f[#{index}][v]",
      options_for_select(
        (
          DataCycleCore::StoredFilter.accessible_by(current_ability).where.not(name: nil) +
          DataCycleCore::StoredFilter.where(id: local_assigns[:value])
        ).map { |e| ["#{e.name}", e.id, { title: e.name }] }, value),
      {
        include_blank: true,
        multiple: false,
        class: 'single-select',
        data: {
          placeholder: ''
        }
      }) %>
  </div>
  <% if can?(:advanced_filter, :backend) %>
    <div class="buttons">
      <a class="remove-advanced-filter" data-target="<%= filter_name %>_<%= index %>"><i aria-hidden="true" class="fa fa-times"></i></a>
    </div>
  <% end %>
</div>
