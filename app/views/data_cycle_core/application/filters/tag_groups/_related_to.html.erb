<span class="tag-group tags <%= key %> <%= local_assigns[:filter_method] || 'i' %> <%= local_assigns[:container_classes] %>" data-id="<%= target %>">
  <span class="tag-group-label">
    <i class="fa fa-arrow-circle-o-left" aria-hidden="true"></i>
    <%= t("common.is", locale: DataCycleCore.ui_language) %>
    <%= t("filter.related_to_method.#{'not_' if local_assigns[:filter_method] == 'e'}related", default: title, locale: DataCycleCore.ui_language) %>:
  </span>

  <% item = union_ids_to_value(value)&.first %>
  <span class="tags-container">
    <span class="tag <%= item['class_name'] %>" title="<%= "#{I18n.t("activerecord.models.data_cycle_core/#{item['class_name']}", count: 1, locale: DataCycleCore.ui_language)}: #{item['name']}" %>"><%= item['name'] %></span>
  </span>

  <%= render 'data_cycle_core/application/filters/tag_groups/advanced_buttons', target: target if buttons == 'a' %>
</span>
