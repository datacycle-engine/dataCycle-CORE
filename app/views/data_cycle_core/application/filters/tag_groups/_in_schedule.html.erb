<span class="tag-group tags <%= key %> <%= local_assigns[:filter_method] || 'i' %> <%= local_assigns[:container_classes] %>" data-id="<%= target %>">
    <i class="tag-group-label">
        <i class="fa fa-calendar" aria-hidden="true"></i>
        <%= t("filter_groups.in_schedule", default: title, locale: DataCycleCore.ui_language) %>
        <%= t("filter.in_schedule.#{key}", default: title, locale: DataCycleCore.ui_language) %>
    </i>
    <% if key == 'relative' %>
        <% if value&.dig('from','n').present? %>
            <i class="tag-group-label"><%= t("terms.from", locale: DataCycleCore.ui_language) %></i>
            <span class="tag">
                <% if value.dig('from','mode') == 'p' %>
                    <%= t("filter.in_schedule.in", locale: DataCycleCore.ui_language) %>
                <% else %>
                    <%= t("filter.in_schedule.before", locale: DataCycleCore.ui_language) %>
                <% end %>
                <%= value.dig('from','n') %>
                <%= t("datetime.prompts.#{value.dig('from','unit')}", locale: DataCycleCore.ui_language) %>
            </span>
        <% end %>

        <% if value&.dig('until','n').present? %>
            <i class="tag-group-label"><%= t("terms.until", locale: DataCycleCore.ui_language) %></i>
            <span class="tag">
                <% if value.dig('until','mode') == 'p' %>
                    <%= t("filter.in_schedule.in", locale: DataCycleCore.ui_language) %>
                <% else %>
                    <%= t("filter.in_schedule.before", locale: DataCycleCore.ui_language) %>
                <% end %>
                <%= value.dig('until','n') %>
                <%= t("datetime.prompts.#{value.dig('until','unit')}", locale: DataCycleCore.ui_language) %>
            </span>
        <% end %>
    <% else %>
        <% if value&.dig('from').present? %>
            <i class="tag-group-label"><%= t("terms.from", locale: DataCycleCore.ui_language) %></i>
            <span class="tag"><%= l(value['from'].to_date, locale: DataCycleCore.ui_language) %></span>
        <% end %>

        <% if value&.dig('until').present? %>
            <i class="tag-group-label"><%= t("terms.until", locale: DataCycleCore.ui_language) %></i>
            <span class="tag"><%= l(value['until'].to_date, locale: DataCycleCore.ui_language) %></span>
        <% end %>
    <% end %>
    <%= render 'data_cycle_core/application/filters/tag_groups/advanced_buttons', target: target if buttons == 'a' %>
</span>
