<span class="tag-group tags <%= key %> <%= local_assigns[:filter_method] || 'i' %> <%= local_assigns[:container_classes] %>" data-id="<%= target %>">
  <span class="tag-group-label">
    <i class="fa fa-globe" aria-hidden="true"></i>
    <%= t("filter.#{key}", default: title, locale: DataCycleCore.ui_language) %>:
  </span>

  <span class="tags-container">
    <% unless value['lon'].empty? or value['lat'].empty? %>
      <span class="tag"><%= t("common.center_point", locale: DataCycleCore.ui_language) %>: <%= value['lon'] %>°, <%= value['lat'] %>°</span>
    <% end %>

    <% unless value['distance'].empty? %>
      <span class="tag"><%= t("common.distance", locale: DataCycleCore.ui_language) %>: <%= value['distance'] %> m</span>
    <% end %>
  </span>

  <%= render 'data_cycle_core/application/filters/tag_groups/advanced_buttons', target: target if buttons == 'a' %>
</span>
