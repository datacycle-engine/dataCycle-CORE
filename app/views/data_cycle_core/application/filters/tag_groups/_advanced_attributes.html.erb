<span class="tag-group tags <%= key %> <%= local_assigns[:filter_method] || 'i' %> <%= local_assigns[:container_classes] %>" data-id="<%= target %>">
  <i class="tag-group-label">
    <i class="fa fa-tags" aria-hidden="true"></i>
      <%= t("filter.#{key}", default: title, locale: DataCycleCore.ui_language) %>:
  </i>
    <% if value.is_a?(Hash) %>
        <% value.reject {|_,v| v.blank?}.each do |k,v| %>
            <i class="tag-group-label"><%= t("terms.#{k}", locale: DataCycleCore.ui_language) %></i>
            <span class="tag"><%= v %></span>
        <% end %>
    <% else %>
        <span class="tag"><%= value %></span>
    <% end %>
    <%= render 'data_cycle_core/application/filters/tag_groups/advanced_buttons', target: target if buttons == 'a' %>
</span>
