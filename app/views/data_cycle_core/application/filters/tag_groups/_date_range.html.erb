<span class="tag-group tags <%= key %> <%= local_assigns[:filter_method] || 'i' %> <%= local_assigns[:container_classes] %>" data-id="<%= target %>">
  <i class="tag-group-label">
    <i class="fa fa-calendar" aria-hidden="true"></i>
    <%= t("filter.#{key}", default: title, locale: DataCycleCore.ui_language) %>
    <%= local_assigns[:filter_method] == 'e' ? t("common.is_not", locale: DataCycleCore.ui_language) : t("common.is", locale: DataCycleCore.ui_language) %>
  </i>

  <% if value&.dig('from').present? %>
    <i class="tag-group-label"><%= t("terms.from", locale: DataCycleCore.ui_language) %></i>
    <span class="tag"><%= l(value['from'].to_date, locale: DataCycleCore.ui_language) %></span>
  <% end %>

  <% if value&.dig('until').present? %>
    <i class="tag-group-label"><%= t("terms.until", locale: DataCycleCore.ui_language) %></i>
    <span class="tag"><%= l(value['until'].to_date, locale: DataCycleCore.ui_language) %></span>
  <% end %>

  <%= render 'data_cycle_core/application/filters/tag_groups/advanced_buttons', target: target if buttons == 'a' %>
</span>
