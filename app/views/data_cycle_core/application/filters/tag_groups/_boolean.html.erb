<span class="tag-group tags <%= key %> <%= local_assigns[:filter_method] || 'n' %> <%= local_assigns[:container_classes] %>" data-id="<%= target %>">
  <i class="tag-group-label">
    <i class="fa fa-clone" aria-hidden="true"></i>
    <%= t("filter.#{key}", default: title, locale: DataCycleCore.ui_language) %>
  </i>

  <span class="tag"><%= t("common.#{value}", locale: DataCycleCore.ui_language) %></span>

  <%= render 'data_cycle_core/application/filters/tag_groups/advanced_buttons', target: target if buttons == 'a' %>
</span>
