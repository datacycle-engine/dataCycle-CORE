<div data-id="<%= identifier %>" class="advanced-filter <%= filter_method || 'i' %>" data-label="<%= filter_name %>">
  <%= hidden_field_tag "f[#{identifier}][c]", local_assigns[:filter_code] || 'a' %>
  <%= hidden_field_tag "f[#{identifier}][t]", :duplicate_candidate_filter %>
  <%= hidden_field_tag "f[#{identifier}][n]", filter_title %>

  <div class="advanced-filter-title">
    <%= render 'data_cycle_core/shared/icon', icon_type: filter_name&.underscore_blanks, icon_class: 'filter' %>
    <span><%= t("filter.#{filter_name}", default: filter_title, locale: active_ui_locale) %></span>
  </div>

  <div class="advanced-filter-mode">
    <%= select_tag "f[#{identifier}][m]", options_for_select([[t("common.has", locale: active_ui_locale), 'i'], [t("common.has_not", locale: active_ui_locale), 'e']], filter_method) %>
  </div>

  <span class="separator"><%= t("duplicate.with_method", locale: active_ui_locale) %></span>
  <div class="advanced-filter-selector">
    <%= select_tag(
        "f[#{identifier}][v][method]",
        options_for_select([[t("common.all", locale: active_ui_locale), 'all']] +
          DataCycleCore::Feature::DuplicateCandidate.available_rules.map { |m| m.to_select_option(active_ui_locale).to_option_for_select }, value&.dig('method')),
        {
          multiple: true,
          class: 'multi-select',
          data: { initial_focus: true }
        }
      ) %>
  </div>

  <span class="separator"><%= t("duplicate.with_score", locale: active_ui_locale) %> <%= t("terms.min", locale: active_ui_locale) %></span>
  <div class="advanced-filter-selector">
    <%= number_field_tag "f[#{identifier}][v][min]", value&.dig('min'), { min: 0, max: 100, step: 'any', placeholder: '', class: 'filter-text' } %>
  </div>
  <span class="separator"><%= t("terms.max", locale: active_ui_locale) %></span>
  <div class="advanced-filter-selector">
    <%= number_field_tag "f[#{identifier}][v][max]", value&.dig('max'), { min: 0, max: 100, step: 'any', placeholder: '', class: 'filter-text' } %>
  </div>

  <% if can?(:advanced_filter, :backend) && local_assigns[:filter_buttons] %>
    <div class="buttons">
      <a class="remove-advanced-filter" data-target="<%= identifier %>"><i aria-hidden="true" class="fa fa-times"></i></a>
    </div>
  <% end %>
</div>
