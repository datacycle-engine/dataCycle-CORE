<div data-id="<%= filter_name %>_<%= index %>" data-index="<%= index %>" class="advanced-filter <%= filter_method || 'i' %>" data-label="<%= filter_name %>">
  <%= hidden_field_tag "f[#{index}][c]", 'a' %>
  <%= hidden_field_tag "f[#{index}][t]", :union_filter_ids %>
  <%= hidden_field_tag "f[#{index}][n]", filter_title %>

  <div class="advanced-filter-title">
    <%= render 'data_cycle_core/shared/icon', icon_type: filter_name&.underscore_blanks, icon_class: 'filter' %>
    <span><%= t('filter.union_filter_ids', collections: DataCycleCore::WatchList.model_name.human(count: 2, locale: DataCycleCore.ui_language), default: 'union_filter_ids', locale: DataCycleCore.ui_language) %></span>
  </div>

  <div class="advanced-filter-mode">
    <%= select_tag "f[#{index}][m]", options_for_select([[t("common.has", locale: DataCycleCore.ui_language), 'i'], [t("common.has_not", locale: DataCycleCore.ui_language), 'e']], filter_method) %>
  </div>

  <div class="advanced-filter-selector">
    <%= select_tag("f[#{index}][v]",
      union_values_to_options(value),
      {
        multiple: true,
        class: 'async-select',
        data: {
          max: 20,
          placeholder: '',
          search_path: select_search_or_collection_stored_filters_path
        }
      }) %>
  </div>

  <% if can?(:advanced_filter, :backend) %>
    <div class="buttons">
      <a class="remove-advanced-filter" data-target="<%= filter_name %>_<%= index %>"><i aria-hidden="true" class="fa fa-times"></i></a>
    </div>
  <% end %>
</div>
