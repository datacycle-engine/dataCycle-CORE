<div class="search">
    <div class="input-group">
        <div class="input-group-button">
            <button type="submit" class="search_icon"><i class="fa fa-search" aria-hidden="true"></i></button>
        </div>
        <%= hidden_field_tag "f[s][n]", t('common.searchterm', locale: DataCycleCore.ui_language) %>
        <%= hidden_field_tag "f[s][t]", :fulltext_search %>
        <%= text_field_tag 'f[s][v]',
          filters.presence&.find { |f| f['t'] == 'fulltext_search' }&.dig('v'),
          placeholder: t('common.searchterm', locale: DataCycleCore.ui_language),
          class:"input-group-field fulltext-search-field" %>
    </div>
</div>
