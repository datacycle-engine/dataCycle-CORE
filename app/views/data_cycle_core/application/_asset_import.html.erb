<% uploader_validation ||= uploader_validation(asset_type: local_assigns[:asset_type]) %>
<% type_class = "data_cycle_core/#{local_assigns.dig(:asset_type)}".classify.constantize %>

<div class="reveal full asset-upload-reveal <%= 'in-object-browser' if local_assigns.dig(:remote_options, :object_browser) %>"
  id="asset-upload-reveal-<%= local_assigns[:key] || 'default' %>"
  data-reveal
  data-validation="<%= uploader_validation.to_json %>"
  data-rendered-attributes="<%= local_assigns[:rendered_attributes].to_json %>"
  data-content-uploader="true"
  data-asset-key="<%= local_assigns[:asset_key] %>"
  data-create-duplicates="<%= can?(:create_duplicate, type_class) %>"
  data-remote-options="<%= local_assigns[:remote_options]&.to_json %>"
  data-type="<%= local_assigns[:asset_type] %>"
  data-multiple-opened="true" data-v-offset="0">
  <h2><%= t('data_cycle_core.upload') %></h2>
  <div class="uploader-flex">
    <ul class="accordion" data-accordion data-multi-expand="true" data-allow-all-closed="true">
      <li class="upload-warning accordion-item is-active callout warning" data-accordion-item>
        <a href="#" class="accordion-title"><%= t('common.warning', locale: DataCycleCore.ui_language) %></a>
        <div class="accordion-content" data-tab-content>
          <%= t('uploader.close_warning_html', locale: DataCycleCore.ui_language) %>

          <%= link_to (request.fullpath.include?('remote_render') ? request.referrer : request.fullpath), target: :_blank do %>
            <i class="fa fa-external-link" aria-hidden="true"></i>
            <%= t('uploader.continue_in_new_tab', locale: DataCycleCore.ui_language) %>
          <% end %>
        </div>
      </li>
    </ul>
    <div id="content-upload-form-<%= local_assigns[:key] || 'default' %>" class="content-upload-form" data-url="<%= assets_path %>">
      <%= file_field_tag "files-#{local_assigns[:key] || 'default'}",
        multiple: true,
        accept: uploader_validation[:format].presence&.map{ |e| ".#{e}" }&.join(', '),
        class: 'upload-file' %>
      <div class="buttons">
        <button type="button" class="button asset-create-button" disabled="disabled">
          <span class="progress-bar"><span class="progress-filled"></span></span>
          <span class="button-text">
            <%= tag.i(class: 'fa fa-check') %>
            <%= t('actions.new', data: type_class.model_name.human(count: 2, locale: DataCycleCore.ui_language), locale: DataCycleCore.ui_language) %>
            <span class="progress-value"></span>
          </span>
        </button>
      </div>
    </div>
  </div>
  <button class="close-button"
    data-close
    aria-label="Close modal"
    type="button">
    <span aria-hidden="true">&times;</span>
  </button>
</div>
