<%= form_tag(root_path, :method => "get", id: "search-form") do %>
<% excluded_types = DataCycleCore.excluded_filter_classifications %>

<section class="filters">
  <div class="row">
    <div class="column">

        <div class="search">
            <div class="input-group">
                <div class="input-group-button">
                    <button type="submit" class="search_icon "><i class="fa fa-search" aria-hidden="true"></i></button>
                </div>
                <%= text_field_tag :search, params[:search], placeholder: t('common.searchterm', locale: DataCycleCore.ui_language),class:"input-group-field" %>
            </div>
        </div>

        <div class="main-filters">

          <nav id="primary_nav_wrap">
            <% main= (DataCycleCore.available_filters&.dig(:main)&.map { |t| t[:tree_label] } + DataCycleCore.available_filters&.dig(:advanced)&.map { |t| t[:tree_label] }).inspect %>

            <% classification_tree_labels = DataCycleCore.available_filters&.dig(:main)&.map { |t| t[:tree_label] } + DataCycleCore.available_filters&.dig(:advanced)&.map { |t| t[:tree_label] } %>

            <% classification_trees = DataCycleCore::ClassificationTreeLabel.where(name: classification_tree_labels).map{|l| {l.name => l.classification_trees.includes(:parent_classification_alias, sub_classification_alias: [sub_classification_alias: [sub_classification_alias: [:sub_classification_alias]]]).where(parent_classification_alias: nil).map(&:sub_classification_alias).select { |type| !excluded_types.include?(type.name) } } }.reduce(:merge) %>

            <ul>
              <% DataCycleCore.available_filters&.dig(:main).presence.each do |filter| %>
                <%= render 'data_cycle_core/application/filters/classification_tree', tree_label: filter&.dig(:tree_label), display_label: filter&.dig(:title), excluded_types: excluded_types, classification_tree: classification_trees&.dig(filter&.dig(:tree_label)) if classification_trees&.dig(filter&.dig(:tree_label)).present? %>
              <% end %>
              <%= render 'data_cycle_core/application/filters/sprache'%>
            </ul>
          </nav>

        </div>

        <% if DataCycleCore.available_filters&.dig(:advanced)&.present? %>
          <ul class="accordion advanced-filters" data-responsive-accordion-tabs="accordion medium-tabs large-accordion" data-allow-all-closed="true">
            <li class="accordion-item" data-accordion-item>
              <div class="accordion-content" data-tab-content>

                <% DataCycleCore.available_filters&.dig(:advanced).each do |filter| %>
                  <%= render 'data_cycle_core/application/filters/alternative_classification_tree', tree_label: filter.dig(:tree_label), display_label: filter.dig(:title), excluded_types: excluded_types, classification_tree: classification_trees.dig(filter.dig(:tree_label)) if classification_trees.dig(filter.dig(:tree_label)).present? %>
                <% end %>

              </div>
              <a href="#" class="accordion-title"><span><i class="fa fa-chevron-down" aria-hidden="true"></i></span></a>
            </li>
          </ul>
        <% end %>

        <div class="filtertags activefilter">
            <span class="icon"><i class="fa fa-check" aria-hidden="true"></i> <strong><%= t('common.active_filters', locale: DataCycleCore.ui_language) %></strong>
            <% unless @total.nil? || @total.zero? %>
              <span class="result-count">(<strong><%= @total %></strong> <%= t('common.contents', count: @total, locale: DataCycleCore.ui_language) %>)</span>
            <% end %>
            <strong>:</strong> </span>

            <span class="your-choice tags sprache">
              <i class="choice-label"><%= t('common.language', locale: DataCycleCore.ui_language) %>:</i>
                <% lang = params[:language] || 'de' %>
                <a class="tag">
                  <%= available_locales_with_names[lang.try(:to_sym)] %>
                </a>
              </span>

            <% classification_tree_labels.each do |label| %>
                <% selected_classifications = get_classifications_for_id(@classification_array, label)  %>
                <span class="your-choice tags <%= label.downcase %>" style="<%= "display: none;" if selected_classifications.blank? %>">
                    <i class="choice-label"><%= label %>:</i>
                    <% unless selected_classifications.blank? %>
                        <% selected_classifications.each do |selected| %>
                            <label for="<%= selected.id %>">
                                <a class="tag">
                                    <%= selected.name %><i class="fa fa-times" aria-hidden="true"></i>
                                </a>
                            </label>
                        <% end %>
                    <% end %>
                </span>
            <% end %>
        </div>

        <div class=" filterbuttons">
          <div class="filterbuttons-left">
            <%= button_tag class: "button success" do %>
              <i class="fa fa-search" aria-hidden="true"></i>
              <%= t('actions.filter', locale: DataCycleCore.ui_language) %>
            <% end %>

            <%= button_tag type: :button, id: 'save-filter', data: { open: 'save-filter-with-name' } do %>
              <i class="fa fa-bookmark-o" aria-hidden="true"></i>
              <%= t('data_cycle_core.stored_searches.save', locale: DataCycleCore.ui_language) %>
            <% end if can?(:create, DataCycleCore::StoredFilter) %>

            <%= button_tag type: :reset, id: 'reset-filter' do %>
              <i class="fa fa-times" aria-hidden="true"></i>
              <%= t('actions.reset', count: 2, locale: DataCycleCore.ui_language) %>
            <% end %>
          </div>

          <div class="filterbuttons-right">
            <% if can?(:show_history, DataCycleCore::StoredFilter) %>
              <%= render 'stored_filters' %>
            <% end %>
          </div>
        </div>

    </div>
  </div>
</section>
<% end %>

<% if can?(:create, DataCycleCore::StoredFilter) %>
  <%= render 'data_cycle_core/application/filters/new_stored_filter', local_assigns %>
<% end %>
