var renderedHtml;

<% if @render_function.present? && respond_to?(@render_function) %>
  renderedHtml = $('<%= j try(@render_function, (@render_params || {}).merge(parameters: @options)) %>')
<% else %>
  renderedHtml = $('<%= j render(@partial, @options) %>')
<% end %>

$('.remote-rendering[data-remote-render-id="<%= @target %>"]').html(renderedHtml).removeClass('remote-rendering').addClass('remote-rendered').trigger('dc:html:changed').trigger('dc:html:initialized', JSON.parse('<%== (@options.dig(:event_data) || {}).to_json %>'));

<% @content_for.presence&.each do |yield_class| %>
  $('.remote-rendered[data-remote-render-id="<%= @target %>"]').siblings('.<%= yield_class %>').add($('.remote-rendered[data-remote-render-id="<%= @target %>"]').closest('.<%= yield_class %>')).first().html('<%= j yield(yield_class.to_sym) %>')
<% end %>
