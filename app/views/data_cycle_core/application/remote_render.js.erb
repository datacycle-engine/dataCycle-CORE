$('<%= @target %>:visible').children().fadeOut('fast', function(){
  $('<%= @target %>:visible').html('<%= j render @partial, @options&.symbolize_keys %>').trigger('remote-partial-rendered');
  <% @content_for.presence&.each do |content| %>
    $('<%= @target %>:visible').closest('.reveal[data-remote-path]:not(.loaded)').find('.<%= content %>').html('<%= j yield(content.to_sym) %>')
  <% end %>

  $('<%= @target %>:visible').closest('.reveal[data-remote-path]:not(.loaded)').addClass('loaded');
});
