$('#new_<%= sanitize_to_id(params[:key]) %>').foundation('close');
$('#object_browser_<%= sanitize_to_id(params[:key]) %> .items .no-results').remove();

<% I18n.with_locale(@person.first_available_locale(params[:locale])) do %>

  $('<%= params[:overlay_id] %>').find('.items .loading').before('<%= j render_object_browser_partial(key: params[:key] + (params[:definition]['type'] == "object" ? '[][id]' : '[]'), definition: params[:definition], parameters: {object: @person, options: params[:options], objects: params[:objects], editable: params[:editable]}) if !@person.nil? %>');

  $('<%= params[:overlay_id] %>').find('.item-info').html('<%= escape_javascript(render_object_browser_partial(partial: 'detail', key: params[:key], definition: params[:definition], parameters: {object: @person, options: params[:options]})) %>');

  $('<%= params[:overlay_id] %>').trigger('import-complete', {id: '<%= @person.id %>'});

<% end %>
