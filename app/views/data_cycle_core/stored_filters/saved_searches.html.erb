<% breadcrumb :saved_searches %>

<% content_for(:title, t('data_cycle_core.stored_searches.my_saved', locale: active_ui_locale)) %>

<section class="stored-searches-list" data-pages="<%= @pages %>">
  <div class="row saved-searches" id="searches-saved">
    <ul class="no-bullet content-list">
      <li class="title">
        <span class="title-text"><%= t('data_cycle_core.stored_searches.saved', count: 2, locale: active_ui_locale) %></span>
        <div class="fulltext-search">
          <%= form_with(url: saved_searches_stored_filters_path, local: true, class: 'fulltext-search-form') do |f| %>
            <%= f.button tag.i(class: 'fa fa-search'), type: :submit, class: 'fulltext-search-submit' %>
            <%= f.text_field :q, id: nil, class: 'fulltext-search-field', placeholder: t('data_cycle_core.stored_searches.filter_searches', locale: active_ui_locale) %>
            <%= f.button tag.i(class: 'fa fa-times'), type: :reset, class: 'fulltext-search-reset' %>
          <% end %>
        </div>
        <span class="pages"><%= @saved_count || 0 %> <%= t('common.entries', locale: active_ui_locale) %> <i class="fa fa-angle-down round" aria-hidden="true"></i></span>
      </li>

      <% if @stored_searches.size.zero? %>
        <li>
          <span class="no-results"><%= t('common.no_results', locale: active_ui_locale) %></span>
        </li>
      <% else %>
        <%= render 'data_cycle_core/stored_filters/saved_searches_list',
                    stored_searches: @stored_searches,
                    last_page: @last_page,
                    page: @page
                     %>
      <% end %>
    </ul>
  </div>
</section>
