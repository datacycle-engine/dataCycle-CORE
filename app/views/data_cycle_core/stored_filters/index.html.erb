<% breadcrumb :search_history %>

<% content_for(:title, t('data_cycle_core.stored_searches.my_searches', locale: active_ui_locale)) %>

<section class="stored-searches-list">
  <div class="row search-history-list">
    <ul class="no-bullet content-list">
      <li class="title">
        <span class="title-text"><%= t('data_cycle_core.stored_searches.history', locale: active_ui_locale) %></span>
        <span class="pages"><%= @history_count || 0 %> <%= t('common.entries', locale: active_ui_locale) %>  <i class="fa fa-angle-down round" aria-hidden="true"></i></span>
      </li>

      <% if @stored_searches.size.zero? %>
        <li>
          <span class="no-results"><%= t('common.no_results', locale: active_ui_locale) %></span>
        </li>
      <% else %>
        <%= render 'stored_searches', stored_searches: @stored_searches, last_page: @last_page, page: @page %>
      <% end %>
    </ul>
  </div>
</section>
