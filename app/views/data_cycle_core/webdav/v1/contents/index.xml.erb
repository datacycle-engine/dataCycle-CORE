<?xml version="1.0"?>

<d:multistatus xmlns:d="DAV:">
  <%= render 'collection', {
    id: @contents.id,
    last_modified: @contents.updated_at.httpdate,
    etag: %("#{@contents.id}-#{@contents.updated_at}-#{Time.zone.now}"), # to reliably know if StoredFilter of WatchLists are updated is not easy.
  } %>
  <% @contents.apply.each do |thing| %>
    <%= render 'file', { id: @contents.id }.merge(propstat(thing)) %>
  <% end %>
</d:multistatus>
