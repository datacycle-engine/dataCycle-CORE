<div class="reveal new-item" id="new_<%= sanitize_to_id(type.name.underscore) %>" data-reveal data-multiple-opened="true">
    <h3><%= t('actions.new', data: type.model_name.human(locale: DataCycleCore.ui_language), locale: DataCycleCore.ui_language ) %></h3>

    <%= form_for type.new, url: { controller: type.name.tableize, action: :create_user } do |f| %>

      <%= f.hidden_field :external, value: false %>

      <div class="form-element validation-container">
          <%= f.email_field :email, required: true, autofocus: true %>
      </div>

      <% if type == DataCycleCore::UserOrganization %>
        <div class="form-element validation-container">
            <%= f.text_field :name, class: 'no-validation' %>
        </div>
      <% else %>
        <div class="form-element validation-container">
            <%= f.text_field :given_name, class: 'no-validation' %>
        </div>

        <div class="form-element validation-container">
            <%= f.text_field :family_name, class: 'no-validation' %>
        </div>
      <% end %>

      <div class="form-element validation-container">
          <%= f.password_field :password, required: true %>
      </div>

      <div class="form-element validation-container">
          <%= f.password_field :password_confirmation, required: true %>
      </div>

      <div class="form-element validation-container">
          <%= f.select :role_id, DataCycleCore::Role.where('rank <= ?', current_user.role.try(:rank)).collect{|r| [t('roles.'+r.name, locale: DataCycleCore.ui_language), r.id]}, {}, class: 'no-margin' %>
      </div>

      <%= f.submit t(:submit, locale: DataCycleCore.ui_language), class: "button primary" %>

    <% end %>

    <button class="close-button" data-close aria-label="Close modal" type="button">
        <span aria-hidden="true">&times;</span>
    </button>
</div>
