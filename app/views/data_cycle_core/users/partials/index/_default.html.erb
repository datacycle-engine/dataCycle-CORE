<% I18n.with_locale(@language) do %>

    <%= link_to item do %>

        <div class="inner">

            <div class="infoRow">
                <%= render 'data_cycle_core/shared/icon', icon_type: 'person' %>
                <span class="title"><%= DataCycleCore::User.model_name.human %></span>
            </div>

            <div class="title">
              <%= item.full_name %>
            </div>

            <div class="description">
              <%= item.email %>
            </div>

            <div class="tags">
              <span class="tag"><%= item.role %></span>
            </div>

        </div>

    <% end %>

<% end %>