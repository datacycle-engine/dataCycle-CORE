<div class="reveal data-link-reveal" id="data-link-overlay-<%= data_link.id || "new" %>" data-reveal>
  <button class="close-button" data-close aria-label="Close modal" type="button">
    <span aria-hidden="true">&times;</span>
  </button>
  <%= form_for data_link, namespace: data_link.id, class: "send-link" do |f| %>
    <p class="lead"><%= DataCycleCore::DataLink.model_name.human(locale: DataCycleCore.ui_language).titleize %></p>
    <%= f.hidden_field 'source_table', value: @split_source.class.table_name unless @split_source.blank? %>
    <%= f.hidden_field 'source_id', value: @split_source.id unless @split_source.blank? %>
    <%= f.hidden_field 'item_type', value: content.class.name %>
    <%= f.hidden_field 'item_id', value: content.id %>
    <%= f.fields_for :receiver, data_link.receiver || DataCycleCore::User.new do |r| %>
      <%= r.hidden_field :id %>
      <%= r.label :email, DataCycleCore::User.human_attribute_name("email", locale: DataCycleCore.ui_language) %>
      <% if data_link.receiver.nil? %>
        <%= r.text_field :email, required: true, readonly: data_link.id.nil? ? false : true, label: false, list: "users", class: "ajax-datalist users", autocomplete: :off %>
        <datalist id="users"></datalist>
      <% else %>
        <%= r.text_field :email, required: true, readonly: data_link.id.nil? ? false : true, label: false %>
      <% end %>
      <%= r.label :given_name, DataCycleCore::User.human_attribute_name("given_name", locale: DataCycleCore.ui_language) %>
      <%= r.text_field :given_name, readonly: data_link.id.nil? ? false : true, label: false %>
      <%= r.label :family_name, DataCycleCore::User.human_attribute_name("family_name", locale: DataCycleCore.ui_language) %>
      <%= r.text_field :family_name, readonly: data_link.id.nil? ? false : true, label: false %>
    <% end %>
    <%= f.label :validity_period, DataCycleCore::DataLink.human_attribute_name("validity_period", locale: DataCycleCore.ui_language) %>
    <%= f.date_field :valid_from, {placeholder: "tt.mm.jjjj", label: false} %> -
    <%= f.date_field :valid_until, {placeholder: "tt.mm.jjjj", label: false} %>
    <%= f.label :permissions, DataCycleCore::DataLink.human_attribute_name("permissions", locale: DataCycleCore.ui_language) %>
    <% data_link_modes = [OpenStruct.new(type: :read)] %>
    <% data_link_modes.push(OpenStruct.new(type: :write)) if (
      content.is_a?(DataCycleCore::WatchList) &&
      content.try(:things)&.all? { |thing| can?(:edit, thing) } &&
      can?(:add_item, content)
    ) || can?(:edit, content) %>
    <% data_link_modes.unshift(OpenStruct.new(type: :download)) if (content.is_a?(DataCycleCore::WatchList) && can?(:download_zip, content)) || (content.is_a?(DataCycleCore::Thing) && can?(:download, content)) %>
    <%= f.collection_radio_buttons(:permissions, data_link_modes, :type, :type, { checked: data_link.permissions&.to_sym || :read }) do |b| %>
      <%= b.radio_button %>
      <%= b.label { DataCycleCore::DataLink.human_attribute_name("permissions_#{b.text}", locale: DataCycleCore.ui_language) } %>
    <% end %>

    <%= f.label :text_file, DataCycleCore::DataLink.human_attribute_name("text_file", locale: DataCycleCore.ui_language) %>

    <%= f.hidden_field :asset_id %>

    <%= render 'data_cycle_core/assets/asset_list', assets: Array(data_link.text_file), class: 'editable' %>

    <button type="button" class="button asset-selector-button data-link-asset" data-disable data-open="asset-selector-data-link-<%= data_link.id %>"><%= t('common.select_asset', data: DataCycleCore::DataLink.human_attribute_name("text_file", locale: DataCycleCore.ui_language), locale: DataCycleCore.ui_language) %></button>

    <div class="full reveal asset-selector-reveal" id="asset-selector-data-link-<%= data_link.id %>" data-reveal data-multiple-opened="true" data-v-offset="0" data-hidden-field-id="<%= "#{data_link.id}_" if data_link.id.present? %>data_link_asset_id">
      <div class="asset-list-container">
        <h3><%= t('common.select_asset_title', locale: DataCycleCore.ui_language) %></h3>
        <div class="scrollable-asset-list">
          <%= render 'data_cycle_core/assets/asset_list', class: 'selectable timestamps', key: "#{"#{data_link.id}_" if data_link.id.present?}data_link_asset_id", assets: nil, asset_types: ['DataCycleCore::TextFile'] %>
        </div>
        <div class="buttons">
          <a class="asset-upload-link button" data-open="asset-upload-reveal-data-link">
            <i class="fa fa-upload" aria-hidden="true"></i>
            <%= t('data_cycle_core.upload', locale: DataCycleCore.ui_language) %>
          </a>
          <a class="select-asset-link button" disabled="disabled"><%= t('common.select_asset', data: DataCycleCore::DataLink.human_attribute_name("text_file", locale: DataCycleCore.ui_language), locale: DataCycleCore.ui_language) %></a>
        </div>
      </div>
      <button class="close-button" data-close aria-label="Close modal" type="button">
        <span aria-hidden="true">&times;</span>
      </button>
    </div>

    <%= f.label :comment, DataCycleCore::DataLink.human_attribute_name("comment", locale: DataCycleCore.ui_language) %>
    <%= f.text_area :comment, class: "large-textfield", label: false %>

    <div class="buttons">
      <%= f.button t('actions.save_without_send', locale: DataCycleCore.ui_language),
        class: "button submit-button",
        name: :send,
        value: 0,
        data: {
          disable_with: "#{t('actions.save_without_send', locale: DataCycleCore.ui_language)} <i class='fa fa-circle-o-notch fa-spin fa-3x fa-fw'></i>"
        } %>
      <%= f.button t('actions.save_and_send', locale: DataCycleCore.ui_language),
        class: "button submit-button",
        name: :send,
        value: 1,
        data: {
          disable: true
        } %>
    </div>
  <% end %>
</div>
