<%= form_for content, html: {class: 'edit-content-form validation-form'} do |f| %>
	<%= hidden_field_tag 'uuid', content.id %>
	<%= hidden_field_tag :table, content.class.table_name %>

	<section class="edit-header">
		<div class="row expanded">
			<div class="column edit-header-functions">
				<div class="edit-name">
					<i class="fa fa-pencil" aria-hidden="true"></i> <%= DataCycleCore::WatchList.model_name.human(count: 1, locale: DataCycleCore.ui_language) %> bearbeiten
				</div>
				<ul>
					<li class="buttons">
            <%= link_to previous_authorized_crumb.url do %>
							<button type="button" class="button discard top dc-foundation-tooltip" aria-haspopup="true" title="Änderungen verwerfen"><i class="fa fa-times" aria-hidden="true"></i></button>
            <% end if previous_authorized_crumb.present? %>

            <button class="button-prime submit submit-edit-form" data-tooltip aria-haspopup="true" title="<%= t('actions.save_changes', locale: DataCycleCore.ui_language) %>" data-disable-with="<i class='fa fa-circle-o-notch fa-spin fa-fw'></i>"><i class="fa fa-check" aria-hidden="true"></i></button>
					</li>
				</ul>

			</div>
		</div>
	</section>

	<div class="row">
		<div class="column">
			<div class="detail-header editor">

				<div class="detail-header-info">
          <span class="icon">
              <i class="fa fa-folder-open" aria-hidden="true"></i>
          </span>
          <span class="title"><%= DataCycleCore::WatchList.model_name.human(count: 1, locale: DataCycleCore.ui_language) %></span>
				</div>

				<div class="form-element input name validation-container">
          <%= f.label :full_path do %>
            <%= DataCycleCore::WatchList.human_attribute_name(:full_path, locale: DataCycleCore.ui_language) %>
            <%= tag.i '*', class: 'required-field-marker dc-foundation-tooltip', aria_hidden: true, title: t('common.required_field', locale: DataCycleCore.ui_language), data: { allow_html: true } %>
          <% end %>

          <%= f.text_field :full_path, data: { validate: 'text' } %>
				</div>

        <% if can? :change_owner, content %>
          <div class="form-element">
            <div class="v-select">
              <%= f.label :user_id, DataCycleCore::WatchList.human_attribute_name(:user_id, locale: DataCycleCore.ui_language) %>
              <%= hidden_field_tag 'watch_list[user_id]', nil, id: 'hidden_watch_list_user_id' %>
              <%= select_tag('watch_list[user_id]', options_for_select(DataCycleCore::User.includes(:role).where.not(roles: { rank: 0 }).map { |c| [c.full_name, c.id, { title: c.email }] }, content.user&.id), { class: 'single-select', data: { allow_clear: false } }) %>
            </div>
          </div>
        <% end %>

				<div class="form-element">
					<div class="v-select">
						<%= f.label :user_group_ids, DataCycleCore::WatchList.human_attribute_name(:user_group_ids, locale: DataCycleCore.ui_language) %>
						<%= f.collection_select(:user_group_ids, DataCycleCore::UserGroup.all, :id, :name, {}, { class: 'multi-select', multiple: true, data: { placeholder: '' } }) %>
					</div>
				</div>

				<div class="form-element">
					<div class="v-select">
						<%= f.label :user_ids, DataCycleCore::WatchList.human_attribute_name(:user_ids, locale: DataCycleCore.ui_language) %>
            <%= hidden_field_tag 'watch_list[user_ids][]', nil, id: 'hidden_watch_list_user_ids' %>
            <%= select_tag('watch_list[user_ids][]', options_for_select(DataCycleCore::User.includes(:role).where.not(roles: { rank: 0 }).map { |c| [c.full_name, c.id, { title: c.email }] }, content.users.map(&:id)), { multiple: true, class: 'multi-select' }) %>
					</div>
				</div>

			</div>
		</div>
	</div>

<% end %>
