$('a[data-toggle="watch-lists-<%= @content_object.id %>"] > .fa').removeClass('fa-bookmark-o').addClass('fa-bookmark');

$('<%= escape_javascript(render 'data_cycle_core/application/watch_lists/editable_link', content: @content_object, watch_list: @watch_list) %>').replaceAll('#content-<%= @content_object.id %>-watch-list-<%= @watch_list.id %>').trigger('dc:watchlist:calculate_even');
