<% I18n.with_locale(@language) do %>

    <%= link_to item do %>

        <div class="inner">

            <div class="infoRow">
                <%= render 'data_cycle_core/shared/icon', icon_type: 'merkliste' %>
                <span class="title">Merkliste</span>
            </div>

            <div class="title">

                <% if !item.nil? && !item.headline.nil? %>
                    <%= item.headline %>
                <% end %>

            </div>

        </div>

    <% end %>

<% end %>