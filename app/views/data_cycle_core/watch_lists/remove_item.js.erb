<% unless @content_object.watch_lists.exists? %>
  $('a[data-toggle="watch-lists-<%= @content_object.id %>"] > .fa').removeClass('fa-bookmark').addClass('fa-bookmark-o');
<% end %>

$('#content-<%= @content_object.id %>-watch-list-<%= @watch_list.id %>').replaceWith('<%= escape_javascript(render 'data_cycle_core/application/watch_lists/edit_link', content: @content_object, watch_list: @watch_list) %>');
