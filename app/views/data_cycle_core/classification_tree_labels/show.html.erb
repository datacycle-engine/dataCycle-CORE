<% breadcrumb :classification_tree_label, @classification_tree_label %>
<% content_for :top_content do %>
  <%= render 'filter', filter: { language: true, classification_trees: ['Inhaltstypen', 'Märkte'] } if user_signed_in? %>
<% end %>
<div id="classification-tree-label-list" class="row">
  <div class="search-results">
    <div class="mode-container">
      <span class="result-count">
        <span class="count-full remote-render"
          id="count-full-results"
          data-remote-render-params="<%= to_query_params(request.params.slice(:language, :f, :stored_filter, :watch_list_id, :id, :q, :roles, :user_groups).merge({ action: controller.action_name, controller: controller.controller_name, mode: @mode, count_only: true, ctl_id: @classification_tree_label&.id, count_mode: @classification_tree_label.nil? ? nil : 'classification_tree_label', content_class: local_assigns[:content_class] || 'things' })).to_json %>"
          >-</span>
      </span>
    </div>
  </div>
  <div class="small-12 columns">
    <ul class="backend-treeview-list">
      <li id="<%= @classification_tree_label.id %>">
        <h1>
          <%= t("tree_view.#{@classification_tree_label.name}", locale: DataCycleCore.ui_language, default: @classification_tree_label.name) %>
          <% if can?(:download, @classification_tree_label) %>
            <%= link_to download_classifications_path(classification_tree_label_id: @classification_tree_label.id,
                                                        include_contents: true,
                                                        format: :csv),
                          class: 'download' do %>
              <i class="fa fa-download" aria-hidden="true"></i>
            <% end %>
          <% end %>
        </h1>
        <ul class="children">
          <%= render 'data_cycle_core/contents/tree/classification_trees', classification_tree_label: @classification_tree_label,
                                             classification_trees: @classification_trees %>
        </ul>
      </li>
    </ul>
  </div>
</div>
