<% breadcrumb :'data_cycle_core/publications' %>

<% content_for(:title, t('common.publications_calendar', locale: DataCycleCore.ui_language)) %>

<% content_for :top_content do %>
    <%= render 'filter_minimal', tree_labels: ['Inhaltstypen'] + @publication_classifications.values, hide_language: true, show_filter: true %>
<% end %>

<section class="publications-list" data-pages="<%= @pages %>">

    <% if @contents&.size&.zero? %>

        <div class="row">
            <div class="small-12">
                <span class="no-results"><%= t('common.no_results', locale: DataCycleCore.ui_language) %></span>
            </div>
        </div>

    <% else %>

      <div class="row">
        <ul class="no-bullet">
          <%= render 'publication_list', contents: @contents %>
        </ul>

      </div>

    <% end %>

</section>
