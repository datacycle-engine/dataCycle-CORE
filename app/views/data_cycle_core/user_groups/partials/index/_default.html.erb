<% I18n.with_locale(@language) do %>

    <div class="inner">

        <div class="infoRow">
            <%= render 'data_cycle_core/shared/icon', icon_type: 'gruppe' %>
              <span class="title"><%= DataCycleCore::UserGroup.model_name.human %></span>
        </div>

        <div class="title">
          <%= item.name %>
        </div>

        <div class="tags">
          <span class="tag"><%#= item.role.label %></span>
        </div>

    </div>

    <div class="item-links">
      <% if can? :edit, item %>
        <%= link_to edit_user_group_path(item, trail: breadcrumb_trail), class: 'button-prime small', title: t('actions.edit').capitalize, data: { tooltip: "", 'disable-hover': false }, 'aria-haspopup': "true" do %>
          <i class="fa fa-pencil" aria-hidden="true"></i>
        <% end %>
      <% end %>

      <% if can? :destroy, item %>
        <%= link_to item, method: :delete, class:'button-prime small alert confirm', data: { 'confirmation-text': "#{item.model_name.human} #{t('actions.delete')}?", tooltip: "", 'disable-hover': false}, title: t('actions.delete').capitalize, 'aria-haspopup': "true" do %>
            <i class="fa fa-trash-o" aria-hidden="true"></i>
        <% end %>
      <% end %>
    </div>

<% end %>
