<% breadcrumb :index, 'user_groups' %>

<% content_for :top_content do %>
  <%= render 'data_cycle_core/users/filter', filter_model: DataCycleCore::UserGroup if user_signed_in? %>
<% end %>

<%= render 'results', contents: @contents, no_cache: true %>

<% if can? :create, DataCycleCore::UserGroup %>
  <% content_for :new_button do %>
    <a data-toggle="new-object" class="button-prime new-object-circle"><i class="fa fa-plus" aria-hidden="true"></i></a>
    <div class="reveal" id="new-object" data-reveal data-v-offset="auto">
        <a class="option last" href="#" data-open="newContent"><i class="fa fa-folder-open-o" aria-hidden="true"></i><%= t('actions.new', data: DataCycleCore::UserGroup.model_name.human(locale: DataCycleCore.ui_language), locale: DataCycleCore.ui_language ) %></a>
    </div>

    <%= render 'new' %>
  <% end %>
<% end %>
