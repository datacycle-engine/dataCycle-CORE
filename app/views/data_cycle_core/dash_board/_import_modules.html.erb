<div class="card" style="width: 300px; background-color:white;">
    <div class="card-divider">
        <h5><%= locals[:import_data][:name] %></h5>
    </div>
    <div class="card-section">
        <%= truncate(locals[:import_data][:database], length: 35)%>
        <ul>
            <%= content_tag(:li, "size: #{number_to_human_size(locals[:import_data][:db_size])}")%>
        </ul>
    </div>
    <div class="card-section">
        Collections: <br />
        <ul>
            <% locals[:import_data][:tables].each do |key, value| %>
                <%=content_tag(:li, "#{key}: #{value}")%>
            <% end %>
        </ul>
    </div>
    <div class="card-section">
        last download:
        <ul>
            <%= content_tag(:li, "#{locals[:import_data][:last_download]}".html_safe) %>
        </ul>
        last import:
        <ul>
            <%= content_tag(:li, "#{locals[:import_data][:last_import]}".html_safe) %>
        </ul>
    </div>

    <div class="card-section">
      <span>
        <%= link_to(t('dash_board.download_import', locale: DataCycleCore.ui_language), admin_download_import_path(id: locals[:import_data][:uuid]), class: 'button small') %>
        <%= link_to(t('dash_board.import_full', locale: DataCycleCore.ui_language), admin_import_full_path(id: locals[:import_data][:uuid]), class: 'button small') unless locals[:import_data][:db_size] == 0 %>
      </span>
      <br/>
      <span>
        <%= link_to(t('dash_board.download', locale: DataCycleCore.ui_language), admin_download_path(id: locals[:import_data][:uuid]), class: 'button small') %>
        <%= link_to(t('dash_board.import', locale: DataCycleCore.ui_language), admin_import_path(id: locals[:import_data][:uuid]), class: 'button small') unless locals[:import_data][:db_size] == 0 %>
      </span>
    </div>
</div>
