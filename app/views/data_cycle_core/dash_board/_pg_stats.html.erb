<ul class="pg-table-stats">
  <% DataCycleCore::StatsDatabase.new(current_user.id, true)&.pg_tables&.sort_by{ |k,v| -v[:size] }&.each do |table, data| %>
    <li class="table-stat">
      <span class="table-name" title="<%= table.classify %>"><%= table.classify %></span>
      <span class="table-count"><%= number_with_delimiter(data[:count], locale: active_ui_locale) %></span>

      <span class="table-size">(<%= number_to_human_size(data[:size], locale: active_ui_locale) %>)</span>
    </li>
  <% end %>
</ul>
