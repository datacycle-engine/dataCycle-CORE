<% breadcrumb :admin %>

<section>

    <div class="row">
        <div class="small-12 columns">
            <h2>
                data overview:
            </h2>
            <%= link_to 'update dash-board', root_path, class: 'button small' %>
        </div>
    </div>

    <div class="row">
        <div class="small-12 columns">
            <h4>
                <br/>master data:
            </h4>
            <%= link_to 'import data-types', admin_import_templates_path, class: 'button small' %>
            <%= link_to 'import classifications', admin_import_classifications_path, class: 'button small' %>
            <%= link_to 'import modules-config', admin_import_config_path, class:'button small' %>            
        </div>
    </div>

    <div class="row">
        <div class="small-12 columns">
            <h4>
                <br/><i class='fa fa-database' aria-hidden='true'></i>&nbsp;core database<br/>&nbsp;
            </h4>
        </div>
    </div>
    <div class="row">
        <div class="small-3 columns">
            <%= render 'pg_total_stats' %>
        </div>
        <div class="small-9 columns">
            <%= render 'job_queue_stats' unless @statJobQueue.count == 0 %>
            <%= 'Duplicates:' unless @duplicates.blank? %>
            <%= ap(@duplicates).html_safe unless @duplicates.blank? %>
            <%= 'Errors:' unless @errors.blank? %>
            <%= ap(@errors).html_safe unless @errors.blank? %>
        </div>
    </div>

    <div class="row">
        <div class="small-12 columns">
            <br/></br>
            <h4>
                <i class='fa fa-arrow-circle-o-down' aria-hidden='true'></i>&nbsp; import modules<br/>&nbsp;
            </h4>
        </div>
    </div>
    <div class="row dashboard-cards">
        <% @statOutdoorActive.import_modules.each do |import_modules| %>
            <div class="columns small-3">
                <%= render 'import_modules', locals: {import_data: import_modules} %>
            </div>
        <% end %>
    </div>

</section>
