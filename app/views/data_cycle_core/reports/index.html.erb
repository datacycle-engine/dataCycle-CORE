<% breadcrumb :reports %>

<section>
  <h1><%= t('data_cycle_core.reports.available_reports', locale: active_ui_locale) %></h1>
  <% @reports.each do |key, report| %>
    <div class="row">
      <div><h2><%= t("feature.report_generator.#{key}", locale: active_ui_locale) %></h2></div>
    </div>
    <% report.dig('allowed_formats').each do |format| %>
      <div>
        <%= link_to download_reports_path(type: format, identifier: key), class: '' do %>
          <span class="icon"><i class="fa fa-file-text-o" aria-hidden="true"></i></span>
          <span class="title">Download <%= format %></span>
        <% end %>
      </div>
    <% end %>
  <% end %>

</section>
