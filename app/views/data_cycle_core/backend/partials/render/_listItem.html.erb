<% I18n.with_locale(@language) do %>
    <div class="list-item data-cycle-object">
        <div class="row expanded">
            <div class="columns small-8">
                <div class="type">
                    <div class="infoRow">
                        <span class="icon"><i class="fa fa-picture-o" aria-hidden="true"></i></span>
                        <span class="title">Bild</span>
                    </div>
                </div>
                <div class="title">
                    <%= link_to item do %>
                        <%= item.headline %>
                    <% end %>
                </div>
                <div class="description">
                    <%= item.description %>
                    <!--<%= item.id %>-->
                </div>
                <div class="tags">
                    <% unless item.display_classification_aliases.nil? %>
                        <% item.display_classification_aliases.each do |classificationAlias| %>
                            <span class="tag"><a href="#"><%= classificationAlias.name %></a></span>
                        <% end %>
                    <% end %>
                </div>
            </div>
