
  <div class="grid-item data-cycle-object">
    <%= link_to item do %>
    <div class="inner">

      <% if !item.metadata.nil? && !item.metadata['validation'].nil? %>

        <div class="type thema">
          <div class="infoRow">
            <span class="icon">
              <i class="fa fa-folder-open-o" aria-hidden="true"></i>
              <!--<i class="fa fa-calendar" aria-hidden="true"></i>-->
            </span>
            <span class="title">Thema</span>
          </div>
        </div>

      <% else %>

        <div class="type bilder">
          <div class="infoRow">
            <span class="icon">
              <i class="fa fa-picture-o" aria-hidden="true"></i>
              <!--<i class="fa fa-calendar" aria-hidden="true"></i>-->
            </span>
            <span class="title">Bild</span>
          </div>
        </div>

      <% end %>

      <div class="title">
        <%= item.headline %>
      </div>
      <div class="description">
        <% if !item.description.nil? %>
          <%= item.description.html_safe %>
        <% end %>
        <!--<%= item.id %>-->
      </div>

      <% if !item.metadata.nil? %>

        <% if !item.metadata['url'].nil? %>
            <div class="image">
              <img src="<%= item.metadata['url'] %>" alt="<%= item.headline %>" />
            </div>
        <% end %>
      <% end %>
