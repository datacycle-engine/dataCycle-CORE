<li class="subtree filter" data-tree-label="<%= tree_label.downcase %>">

    <% parent_string = classification_alias_id.nil? ? "IS NULL" : " = '#{classification_alias_id}'" %>
    <% types = DataCycleCore::ClassificationAlias
                .joins(classification_tree: [:classification_tree_label])
                .includes(classification_tree: {classification_tree_label: {}})
                .includes(sub_classification_alias: {sub_classification_alias: {sub_classification_alias: {}}})
                .where("classification_tree_labels.name = ?", tree_label)
                .where("classification_trees.parent_classification_alias_id #{parent_string}") %>

    <%= render 'data_cycle_core/shared/icon', icon_type: tree_label.downcase %>

    <span class="title"><%= display_label %><!-- <strong>(<%=types.count%>)</strong>--></span>
    <div>
        <ul class="clearfix">
            <% types.sort{|a,b| a.name <=> b.name}.each do |item| %>
                <%= render 'data_cycle_core/backend/partials/filter/classification_items', item: item %>
            <% end %>
        </ul>

    </div>
</li>
