<%# LANGUAGES = %w(de en ar bg cs da es fr it hu hr ja ko nl pt pl ro ru sl sk sv tr uk de-CH) %>
<% language_hash = {de: "deutsch", en: "englisch", ar: "arabisch", bg: "bulgarisch", cs: "tschechisch", da: "dänisch", es: "spanisch", fr: "französisch", it: "italienisch", hu: "ungarisch", hr: "kroatisch", ja: "japanisch", ko: "koreanisch", nl: "holländisch", pt: "portugiesisch", pl: "polnisch", ru: "russisch", sl: "slowenisch", sk: "slowakisch", sv: "schwedisch", tr: "türkisch", uk: "ukrainisch", "de-CH" => "schweizer-deutsch"} %>

<li>
    <%= render 'data_cycle_core/creative_works/partials/render/icon', icon_type: "sprache" %>
    <span class="title">Sprache</span>
    <div>
        <ul class="split-list clearfix">
            <% language_hash.each do |key,value| %>
                <li>
                    <input type="radio" name="language" value="<%= key.to_s %>" id="<%= key.to_s %>" <%= "checked" if key.to_s == "de" || key.to_s == params[:language]%> />
                    <label for="<%= key.to_s %>">
                        <span class="title">
                            <strong><%=value%></strong>
                        </span>
                    </label>
                </li>
            <% end %>
        </ul>
        <%= render 'data_cycle_core/backend/partials/filter/filterbutton' %>
    </div>
</li>
