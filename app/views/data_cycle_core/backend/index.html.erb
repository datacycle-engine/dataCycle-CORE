<% breadcrumb :root %>

<% content_for(:title, "Backend") %>

<% content_for :new_button do %>
  <%= render 'new_content_links' if user_signed_in? && can?(:create, DataCycleCore::CreativeWork) %>
<% end %>

<% content_for :top_content do %>
  <% if current_user&.role&.rank&.<(10) %>
    <% classification_filters = [['Inhaltspools', 'classification_alias_ids', data: { name: 'Inhaltspools' }]] %>
  <% else %>
    <% classification_filters = DataCycleCore.available_filters[:advanced].presence&.map { |c| [t("filter.#{c}", default: c, locale: DataCycleCore.ui_language), 'classification_alias_ids', data: { name: c }]} || [] %>
  <% end %>

  <%= render 'filter', filter: { search: true, language: true, store: true, advanced: classification_filters } if user_signed_in? %>
<% end %>

<%= render 'results', contents: @contents %>
