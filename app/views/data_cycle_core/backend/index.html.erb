<% content_for(:title, "Backend") %>

<h3>Die aktuellen Themen</h3>

<section>

  <div class="row">
    <div class="small-12 columns">
      <%= paginate @creativeWorks %>
    </div>
  </div>
    <div class="grid">
      <div class="grid-sizer"></div>
      <div class="gutter-sizer"></div>
      <% (0..5).to_a.each do |chr| %>
        <% @creativeWorks.shuffle.each do |creativeWork| %>
          <div class="grid-item data-cycle-object layout-<%= rand(0..5) %>">
            <div class="type">
              <div class="infoRow">
                <span class="icon"><i class="fa fa-calendar" aria-hidden="true"></i></span>
                <span class="title">Veranstaltung</span>
              </div>
            </div>
            <div class="title">
              <%= link_to creativeWork do %>
                <%= creativeWork.headline %>
              <% end %>
            </div>
            <div class="description">
              <%= creativeWork.description %>
              <%= creativeWork.id %>
            </div>
            <div class="tags">
              <span class="tag"><a href="#">Charity</a></span>
              <span class="tag"><a href="#">Wien</a></span>
              <span class="tag"><a href="#">Party</a></span>
              <span class="tag"><a href="#">Gala</a></span>
            </div>
            <div class="info">
              <div class="infoRow">
                <span class="icon"><i class="fa fa-align-left" aria-hidden="true"></i></span>
                <span class="title"><strong>8</strong> Texte</span>
              </div>
              <div class="infoRow">
                <span class="icon"><i class="fa fa-picture-o" aria-hidden="true"></i></span>
                <span class="title"><strong>63</strong> Bilder</span>
              </div>
              <div class="infoRow">
                <span class="icon"><i class="fa fa-play" aria-hidden="true"></i></span>
                <span class="title"><strong>1</strong> Video</span>
              </div>
              <div class="infoRow">
                <span class="icon"><i class="fa fa-comment" aria-hidden="true"></i></span>
                <span class="title">de, en, ru, it, pl, si <strong>+5</strong></span>
              </div>
            </div>
            <!-- <div>
                <%= creativeWork.metadata %>
            </div> -->
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
  <div class="row">
    <div class="small-12 columns">
      <%= paginate @creativeWorks %>
    </div>
  </div>
</section>
