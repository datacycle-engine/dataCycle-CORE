<% breadcrumb :root %>

<% content_for(:title, "Backend") %>

<% content_for :new_button do %>
  <%= render 'new_content_links' if user_signed_in? && can?(:create, DataCycleCore::CreativeWork) %>
<% end %>

<% content_for :top_content do %>
  <% classification_filters = DataCycleCore::ClassificationTreeLabel.order(:name).pluck(:name).map { |c| [t("filter.#{c}", default: c, locale: DataCycleCore.ui_language), 'classification_alias_ids', data: { name: c }]} %>

  <% classification_filters.push([DataCycleCore::ExternalSource.model_name.human(locale: DataCycleCore.ui_language), 'external_source', data: { name: DataCycleCore::ExternalSource.model_name.human(locale: DataCycleCore.ui_language) }]) %>

  <%= render 'filter', filter: { search: true, language: true, store: true, advanced: classification_filters } if user_signed_in? %>
<% end %>

<%= render 'results', contents: @contents %>
