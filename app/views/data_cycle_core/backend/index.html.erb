<% breadcrumb :root %>

<% content_for(:title, "Backend") %>

<% content_for :new_button do %>
  <%= render 'new_content_links',
    query_methods: [{ method_name: 'for_tree', value: 'Inhaltstypen' }].concat(DataCycleCore::Feature::Container.index_query_methods || []), button_class: 'new-object-circle' if user_signed_in? && can?(:create, DataCycleCore::CreativeWork) %>
<% end %>

<% content_for :top_content do %>
  <%= render 'filter', filter: { search: true, language: true, store: true, advanced: DataCycleCore::Feature::AdvancedFilter.enabled? ? DataCycleCore::Feature::AdvancedFilter.available_filters : false } if user_signed_in? %>
<% end %>

<%= render 'results', contents: @contents %>
