<% breadcrumb :root %>

<% content_for(:title, "Backend") %>

<% content_for :new_button do %>
  <%= render 'new_content_links' if user_signed_in? && can?(:create, DataCycleCore::CreativeWork) %>
<% end %>

<% content_for :top_content do %>
  <% advanced_filters = [] %>
  <% if DataCycleCore.available_filters.dig(:advanced, :classification_alias_ids) == 'all' %>
    <% advanced_filters = DataCycleCore::ClassificationTreeLabel.all.pluck(:name).map { |c| [t("filter.#{c}", default: c, locale: DataCycleCore.ui_language), 'classification_alias_ids', data: { name: c }]} || [] %>
  <% elsif DataCycleCore.available_filters.dig(:advanced, :classification_alias_ids)&.is_a?(Array) %>
    <% advanced_filters = DataCycleCore.available_filters.dig(:advanced, :classification_alias_ids).presence&.map { |c| [t("filter.#{c}", default: c, locale: DataCycleCore.ui_language), 'classification_alias_ids', data: { name: c }]} || [] %>
  <% end %>

  <% advanced_filters.concat(DataCycleCore.available_filters[:advanced].except(:classification_alias_ids).map { |k, v| [t("filter.#{v}", default: v, locale: DataCycleCore.ui_language), k.to_s, data: { name: v }]}) if DataCycleCore.available_filters[:advanced].except(:classification_alias_ids).present? %>

  <%= render 'filter', filter: { search: true, language: true, store: true, advanced: advanced_filters } if user_signed_in? %>
<% end %>

<%= render 'results', contents: @contents %>
