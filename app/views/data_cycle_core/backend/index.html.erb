<% content_for(:title, "Backend") %>

<section>

    <% if @dataCycleObjects.size == 0 %>

        <div class="row">
            <div class="small-12">
                <span class="no-results">Es wurden keine Themen für Ihre Filterkriterien gefunden. </span>
            </div>
        </div>

    <% else %>

        <div class="row">
            <div class="small-12">
                <%= paginate @paginateObject%>
            </div>
        </div>

        <% if @mode == 'list' %>
            <%= render 'data_cycle_core/backend/partials/list', dataCycleObjects: @dataCycleObjects %>
        <% else %>
            <%= render 'data_cycle_core/backend/partials/grid', dataCycleObjects: @dataCycleObjects %>
        <% end %>

        <div class="row">
            <div class="small-12">
                <%= paginate @paginateObject %>
            </div>
        </div>

    <% end %>

</section>
