<% content_for(:title, t('data_cycle_core.settings', locale: DataCycleCore.ui_language)) %>

<% breadcrumb :settings %>

<% content_for :top_content do %>

  <div class="reveal-blur">

      <div id="edit-form">

        <%= form_for current_user do |f| %>
          <%= hidden_field_tag 'uuid', current_user.id %>
          <%= hidden_field_tag 'user_settings', true %>

          <section class="edit-header">
            <div class="row expanded">
              <div class="column edit-header-functions">
                <div class="edit-name">
                  <i class="fa fa-pencil" aria-hidden="true"></i> <%= "#{current_user.model_name.human(locale: DataCycleCore.ui_language)}-#{t('data_cycle_core.settings', locale: DataCycleCore.ui_language)} #{t('actions.edit', locale: DataCycleCore.ui_language)}" %>
                </div>
                <ul>
                  <li class="buttons">
                    <%= link_to previous_authorized_crumb.url do %>
                      <button type="button" class="button discard top" data-tooltip aria-haspopup="true" title="Änderungen verwerfen"><i class="fa fa-times" aria-hidden="true"></i></button>
                    <% end if previous_authorized_crumb.present? %>
                    <button class="button-prime submit submit-edit-form" data-tooltip aria-haspopup="true" data-disable-with="<i class='fa fa-circle-o-notch fa-spin fa-3x fa-fw'></i>" title="Änderungen speichern" data-disable-with="<i class='fa fa-circle-o-notch fa-spin fa-fw'></i>"><i class="fa fa-check" aria-hidden="true"></i></button>
                  </li>
                </ul>
              </div>
            </div>
          </section>

          <div class="row">
            <div class="column">
              <div class="detail-header editor">

                <div class="detail-header-info">
                  <div class="type thema">
                    <span class="icon">
                        <i class="fa fa-cogs" aria-hidden="true"></i>
                    </span>
                    <span class="title"><%= "#{current_user.model_name.human(locale: DataCycleCore.ui_language)}-#{t('data_cycle_core.settings', locale: DataCycleCore.ui_language)}" %></span>
                  </div>
                </div>

                <div class="form-element validation-container">
                  <%= f.label :notification_frequency, DataCycleCore::User.human_attribute_name(:notification_frequency, locale: DataCycleCore.ui_language) %>
                  <div class="v-select">
                    <%= f.select :notification_frequency,
                      DataCycleCore.notification_frequencies.map{ |f|
                        [
                          t("notification.frequency.#{f}", locale: DataCycleCore.ui_language),
                          f
                        ]
                      },
                      {},
                      class: 'single-select',
                      data: {
                        allow_clear: false
                      } %>
                  </div>
                </div>

                <div class="form-element">
                  <%= f.label :default_locale, DataCycleCore::User.human_attribute_name(:default_locale, locale: DataCycleCore.ui_language) %>
                  <div class="v-select">
                    <%= f.select :default_locale,
                      available_locales_with_names.except(:all).invert,
                      {},
                      class: 'single-select',
                      data: {
                        allow_clear: false
                      } %>
                  </div>
                </div>
              </div>
            </div>
          </div>

        <% end %>

      </div>

  </div>

<% end %>
