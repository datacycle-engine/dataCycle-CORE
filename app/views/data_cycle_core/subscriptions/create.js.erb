$('#subscribe-link .text').text("<%= t('actions.subscribed', locale: DataCycleCore.ui_language) %>");
$('#subscribe-link i.fa').removeClass('fa-bell-o').addClass('fa-bell');
$('#subscribe-link .subscriber-count').html(parseInt($('#subscribe-link .subscriber-count').text()) + 1);
$('#subscribe li').html('<%= escape_javascript(render 'subscriptions', content: @subscription.subscribable) %>');
