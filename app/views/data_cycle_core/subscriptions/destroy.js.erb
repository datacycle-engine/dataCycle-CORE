$('#subscribe h5').text("<%= t('common.contents', count: 1, locale: DataCycleCore.ui_language) %> <%= t('actions.subscribe', locale: DataCycleCore.ui_language) %>");
$('#subscribe-link i.fa').removeClass('fa-bell').addClass('fa-bell-o');
