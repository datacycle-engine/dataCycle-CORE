<% breadcrumb :content, @content, @watch_list %>

<% content_for :top_content do %>
    <%= render_content_partial 'header', content: @content %>
<% end %>

<% if DataCycleCore::Feature::Container.enabled? && @content.content_type?('container') %>
    <ul class="accordion container-details" data-accordion data-allow-all-closed="true">
        <li class="accordion-item is-active" data-accordion-item>
            <div class="accordion-content" data-tab-content>
                <%= render_content_partial 'details', content: @content %>
            </div>
            <a href="#" class="accordion-title"><span><i class="fa fa-chevron-down" aria-hidden="true"></i><span class="closed"><%= t('common.details.show') %></span><span class="open"><%= t('common.details.hide') %></span> </span></a>
        </li>
    </ul>

    <%= render 'filter', filter: { classification_trees: ['Inhaltstypen'], search: true, language: true, collapse: true } %>
    <%= render 'results', contents: @contents %>

    <% content_for :new_button do %>
        <%= render 'new_content_button',
                   query_methods: DataCycleCore::Feature::Container.query_methods(@content),
                   content: @content,
                   parent: @content.content_type?(:container) ? @content : nil,
                   scope: 'container',
                   button_class: 'new-object-circle' if new_content_select_options(query_methods: DataCycleCore::Feature::Container.query_methods(@content), scope: 'container').present? %>
    <% end %>
<% else %>
    <%= render_content_partial 'details', content: @content %>
<% end %>

<% content_for :admin_panel do %>

    <section id="admin-panel">
        <nav id="admin-icons">
            <a data-toggle="menuBar">
                <i class="fa fa-user-secret"></i>
            </a>
            <a data-toggle="schema">
                <i class="fa fa-code"></i>
            </a>
        </nav>
        <section id="admin-inner">
            <section id="schema" data-toggler=".expanded">
                <section class="schema-nav">
                    <button class="copy-to-admin-clipboard">COPY</button>
                </section>
<pre id="json"><code><%= JSON.pretty_generate(@content.schema) %></code></pre>
            </section>
        </section>
    </section>

<% end %>