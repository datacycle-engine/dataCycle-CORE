<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options, content: content do %>

    <% object_class = DataCycleCore::Thing %>
    <% objects = value.presence&.includes(:translations)&.page&.per(DataCycleCore.linked_objects_page_size) %>
    <% object_template = definition['template_name'] %>

    <%= label_tag key do %>
      <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if options['readonly'].to_s == 'true' %>
      <%= definition['label'] %>
      <%= render 'helper_text', local_assigns %>
    <% end %>

    <div class="object-browser" id="<%= sanitize_to_id(key) %>"
      data-type="<%= definition.fetch('template_name', nil) %>"
      data-locale="<%= I18n.locale.to_s %>"
      data-key="<%= key %>"
      data-object-id="<%= content.id %>"
      data-object-key="<%= key.attribute_name_from_key %>"
      data-definition="<%= definition.to_json %>"
      data-options="<%= options.to_json %>"
      data-class="<%= object_class %>"
      data-editable="<%= can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>"
      data-table="<%= 'things' %>"
      data-per="<%= DataCycleCore.linked_objects_page_size %>"
      data-objects="<%= value.presence&.ids %>"
      data-content-id="<%= (local_assigns[:parent] || content).id %>"
      data-content-type="<%= (local_assigns[:parent] || content).class.table_name %>"
      data-max="<%= definition.dig('validations', 'max') || 0 %>"
      data-min="<%= definition.dig('validations', 'min') || 0 %>">
        <div class="media-thumbs">
          <div class="object-thumbs">
            <% if objects.present? %>
              <% objects.each do |object| %>
                <%= render_object_browser_partial(key: "#{key}[]", definition: definition, parameters: { object: object, options: options, editable: can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content)) }, content: content) %>
              <% end %>

              <% value.presence&.ids&.reject { |v| objects.presence&.ids&.include?(v) }&.each do |id| %>
                <%= hidden_field_tag "#{key}[]", id %>
              <% end %>
            <% else %>
              <%= hidden_field_tag "#{key}[]", nil, id: sanitize_to_id(key) + '_default' %>
            <% end %>
          </div>

          <div class="buttons clear-both">
            <%= link_to t('common.load_more', locale: DataCycleCore.ui_language), thing_path(
              [:load_more_linked_objects, local_assigns[:parent] || content],
              key: key.attribute_name_from_key,
              complete_key: key,
              definition: definition,
              options: options,
              page: params.fetch(:page, 1).to_i + 1,
              load_more_action: :object_browser,
              editable: can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)),
              locale: I18n.locale,
              content_id: content.id,
              content_type: content.class.table_name
            ),
            remote: true,
            id: "load_more_#{content&.id}_#{sanitize_to_id(key)}",
            class: 'load-more-linked-contents button',
            data: {
              disable_with: "<i class='fa fa-spinner fa-spin'></i> #{t('common.load_more', locale: DataCycleCore.ui_language)}..."
            } if objects.try(:total_pages)&.positive? && !objects&.last_page? %>

            <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
              <button class="button show-objectbrowser" id="show-object-browser-<%= sanitize_to_id(key) %>" type="button" data-open="object_browser_<%= sanitize_to_id(key) %>">
                <i class="fa fa-plus"></i>
              </button>
            <% end %>
          </div>
        </div>
    </div>

    <div id="object_browser_<%= sanitize_to_id(key) %>" data-overlay="false" class="object-browser-overlay full reveal without-overlay" data-reveal data-v-offset="0" data-multiple-opened="true">
      <div class="object-browser-header">
        <span class="search-icon">
          <i class="fa fa-search" aria-hidden="true"></i>
        </span>
        <input placeholder="Volltext Suche" autofocus class="object-browser-search">
        <span class="item-count"></span>
      </div>

      <div class="items margin-bottom-10">
        <div class="loading">
          <i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw"></i>
        </div>
      </div>

      <div class="item-info">
        <div class="item-info-scrollable"></div>
      </div>

      <div class="object-browser-footer">
        <div class="chosen-items items">
          <div class="chosen-items-container">
          </div>
        </div>
        <div class="buttons">
          <span class="button-title">
            <sup>
              <span class="chosen-counter"></span>
              <i class="fa fa-chevron-right" aria-hidden="true"></i>
            </sup>
          </span>
          <a class="button-prime success small save-object-browser">
            <i class="fa fa-check" aria-hidden="true"></i>
          </a>
          <% if can?(:create_in_objectbrowser, object_template) %>
            <button data-open="new_<%= sanitize_to_id(key) %>" class="new-item-button button-prime small" type="button">
              <i class="fa fa-plus"></i>
            </button>
          <% end %>
          <button class="button-prime small close-object-browser" type="button" data-close>
            <i aria-hidden="true" class="fa fa-times"></i>
          </button>

          <% if can?(:create_in_objectbrowser, object_template) %>
            <% begin %>
              <%= render_object_browser_partial(partial: 'new', key: key, definition: definition, parameters: { new_overlay_key: sanitize_to_id(key), object: DataCycleCore::Thing.find_by(template: true, template_name: definition&.dig('template_name')) }, content: content) %>
            <% rescue %>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>

<% end %>
