<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options, content: content, parent: local_assigns[:parent] do %>

  <% object_class = DataCycleCore::Thing %>
  <% objects = value&.includes(:translations)&.page&.per(DataCycleCore.linked_objects_page_size) %>
  <% object_template = definition['template_name'] %>

  <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" do %>
    <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) unless attribute_editable?(key, definition, options, content) %>
    <%= yield_content!(:attribute_label) %>
    <%= render 'data_cycle_core/contents/helper_text', local_assigns %>
  <% end %>

  <div class="object-browser" id="<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>"
      data-type="<%= definition.fetch('template_name', nil) %>"
      data-locale="<%= I18n.locale.to_s %>"
      data-key="<%= key %>"
      data-hidden-field-id="<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}_default" %>"
      data-prefix="<%= local_assigns.dig(:options, :prefix) %>"
      data-object-id="<%= content.id %>"
      data-object-key="<%= key.attribute_name_from_key %>"
      data-definition="<%= definition.to_json %>"
      data-options="<%= options.to_json %>"
      data-class="<%= object_class %>"
      data-editable="<%= attribute_editable?(key, definition, options, content) %>"
      data-table="<%= 'things' %>"
      data-per="<%= DataCycleCore.linked_objects_page_size %>"
      data-objects="<%= value&.ids %>"
      data-content-id="<%= (local_assigns[:parent] || content).id %>"
      data-content-type="<%= (local_assigns[:parent] || content).class.table_name %>"
      data-max="<%= definition.dig('validations', 'max') || 0 %>"
      data-min="<%= definition.dig('validations', 'min') || 0 %>"
      data-limited-by="<%= definition.dig('ui', 'edit', 'options', 'limited_by')&.to_json %>">
    <div class="media-thumbs">
      <ul class="object-thumbs no-bullet<%= ' has-items' if objects.present? %>">
        <% if objects.present? %>
          <% objects.each do |object| %>
            <%= render_linked_partial(key: "#{key}[]", definition: definition, parameters: { object: object, prefix: local_assigns.dig(:options, :prefix), options: options, edit_buttons: true }, content: content) %>
          <% end %>

          <% value.presence&.ids&.reject { |v| objects.presence&.ids&.include?(v) }&.each do |id| %>
            <%= hidden_field_tag "#{key}[]", id %>
          <% end %>
        <% else %>
          <%= hidden_field_tag "#{key}[]", nil, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}_default" %>
        <% end %>
      </ul>

      <div class="buttons clear-both">
        <%= link_to t('common.load_all', locale: active_ui_locale), load_more_linked_objects_thing_path(
              local_assigns[:parent] || content,
              key: key.attribute_name_from_key,
              complete_key: key,
              definition: definition,
              options: options,
              page: params.fetch(:page, 1).to_i + 1,
              load_more_action: :object_browser,
              editable: attribute_editable?(key, definition, options, content),
              locale: I18n.locale,
              content_id: content.id,
              content_type: content.class.table_name
            ),
            remote: true,
            id: "load_more_#{content&.id}_#{sanitize_to_id(key)}",
            class: 'load-more-linked-contents button',
            data: {
              disable_with: "<i class='fa fa-spinner fa-spin'></i> #{t('common.load_all', locale: active_ui_locale)}..."
            } if objects.try(:total_pages)&.positive? && !objects&.last_page? %>

        <% if attribute_editable?(key, definition, options, content) %>
          <button class="button show-objectbrowser" data-disable id="show-object-browser-<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>" type="button" data-open="object_browser_<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>">
            <i class="fa fa-plus"></i>
          </button>
        <% end %>
      </div>
    </div>
  </div>

  <div id="object_browser_<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>" data-overlay="false" class="object-browser-overlay full reveal without-overlay" data-reveal data-v-offset="0" data-multiple-opened="true">
    <div class="object-browser-header">
      <span class="search-icon">
        <i class="fa fa-search" aria-hidden="true"></i>
      </span>
      <input placeholder="Volltext Suche" autofocus class="object-browser-search">
      <span class="item-count"></span>
    </div>

    <ul class="items margin-bottom-10 no-bullet">
      <div class="loading">
        <i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw"></i>
      </div>
    </ul>

    <div class="item-info">
      <div class="item-info-scrollable"></div>
    </div>

    <div class="object-browser-footer">
      <div class="chosen-items items">
        <ul class="chosen-items-container no-bullet"></ul>
      </div>
      <div class="buttons">
        <span class="button-title">
          <sup>
            <span class="chosen-counter"></span>
            <i class="fa fa-chevron-right" aria-hidden="true"></i>
          </sup>
        </span>
        <a class="button-prime success small save-object-browser">
          <i class="fa fa-check" aria-hidden="true"></i>
        </a>

        <% form_parameters = object_browser_new_form_parameters({
            content: content,
            button_class: 'small new-content-button',
            locale: I18n.locale,
            object_browser: true,
            key: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}",
            scope: 'object_browser'
        }, definition) %>

        <%= render 'data_cycle_core/contents/new_content_button', form_parameters if definition.dig('ui', 'edit', 'options', 'limited_by').blank? && form_parameters.present? %>

        <button class="button-prime small close-object-browser" type="button" data-close>
          <i aria-hidden="true" class="fa fa-times"></i>
        </button>
      </div>
    </div>
  </div>

<% end %>
