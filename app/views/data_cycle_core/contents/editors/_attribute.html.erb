<div data-label="<%= definition['label'] %>" class="<%= [
    'clearfix',
    'form-element',
    key.attribute_name_from_key,
    definition.dig('validations').present? ? 'validation-container' : '',
    definition.dig('type').try(:underscore),
    definition.dig('ui', 'edit', 'type').try(:underscore),
    definition.dig('ui', 'edit', 'options', 'class').try(:underscore),
    options.try(:[], 'class'),
    local_assigns[:parent]&.embedded_title_property_name.present? && key.attribute_name_from_key == local_assigns[:parent].embedded_title_property_name ? 'is-embedded-title' : nil
].reject(&:blank?).uniq.join(' ') %>" data-key="<%= key %>" data-readonly="<%= options['readonly'].to_s == 'true' %>" data-id="<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>">

  <% if content.try(:translatable_property?, key.attribute_name_from_key, definition) && content.translatable? && I18n.available_locales&.many? %>
    <span class="translated"><i class="fa fa-language" aria-hidden="true"></i></span>
  <% end %>

  <%= yield %>

</div>
