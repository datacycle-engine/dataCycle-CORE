<%= render 'data_cycle_core/contents/editors/attribute_editor', key: key, definition: definition, value: value, options: options do %>

  <div class="embedded-object" id="<%= sanitize_to_id(key) %>"
    data-language="<%= I18n.locale.to_s %>"
    data-key="<%= key %>"
    data-label="<%= definition['label'] %>"
    data-definition="<%= definition.to_json %>"
    data-options="<%= options.to_json %>"
    data-total="<%= value.size %>"
    data-ids="<%= value.ids %>"
    data-per="<%= DataCycleCore.linked_objects_page_size %>"
    data-max="<%= definition.dig('validations', 'maxLength') || 0 %>"
    data-min="<%= definition.dig('validations', 'minLength') || 0 %>"
    data-write="<%= can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content)) %>">

    <% value.ids.presence&.each_with_index do |id, index| %>
      <%= hidden_field_tag "#{key}[#{index}][id]", id %>
    <% end %>

    <% objects = value.presence&.includes(:translations)&.page&.per(DataCycleCore.linked_objects_page_size) %>

    <% objects.presence&.each_with_index do |object, index| %>
      <%= render_embedded_object_partial(key: key, definition: definition, parameters: { object: object, index: index, options: options, new_content: new_content ||= false }) %>
    <% end %>

    <div class="buttons">
      <% if value.presence&.size&.>(DataCycleCore.linked_objects_page_size) %>
        <button id="load_more_<%= sanitize_to_id(key) %>" class="load-more-linked-contents button" type="button" data-page="2">
          <%= t('common.load_more', locale: DataCycleCore.ui_language) %>
        </button>
      <% end %>

      <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content)) %>
        <button id="add_<%= sanitize_to_id(key) %>" type="button" class="button addContentObject" style="display: none;"><%= definition['label'] %> hinzufügen<i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw"></i></button>
      <% end %>
    </div>
  </div>

<% end %>
