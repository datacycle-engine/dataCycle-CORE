<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options, content: content do %>

  <%= hidden_field_tag key, value, class: 'location-data', id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>

  <% if value.try(:geometry_type) == RGeo::Feature::LineString || definition.dig('ui', 'edit', 'type') == 'LineString' %>
      <div class="edit-type geographic <%= 'editable' if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) && DataCycleCore.default_map_position.dig('editor') == 'TourSprung' %>">
          <div id="map_<%= SecureRandom.hex(16) %>"
            class="geographic-map linestring"
            data-map-options="<%= DataCycleCore.default_map_position.presence&.to_json %>"
            data-icon-paths="<%= { default: image_path('location.svg'), before: image_path('location_before.svg'), after: image_path('location_after.svg') }.to_json %>"
            data-type="<%= (value.presence&.geometry_type || RGeo::Feature::LineString).to_s %>"
            data-value="[<%= value.presence&.points&.map { |p| "[#{p.x}, #{p.y}]" }&.join(",") || [] %>]"
            data-marker-path="<%= definition&.dig('ui', 'edit', 'options', 'marker_path')&.to_json || [].to_json %>">
          </div>
      </div>
  <% elsif value.try(:geometry_type) == RGeo::Feature::Point || value.blank? %>
      <div class="edit-type geographic <%= 'editable' if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>">
          <div id="map_<%= SecureRandom.hex(16) %>"
            class="geographic-map point"
            data-map-options="<%= DataCycleCore.default_map_position.presence&.to_json %>"
            data-icon-paths="<%= { default: image_path('location.svg'), before: image_path('location_before.svg'), after: image_path('location_after.svg') }.to_json %>"
            data-type="<%= (value.presence&.geometry_type || RGeo::Feature::Point).to_s %>"
            data-value="[<%= value.present? ? "[#{value.presence&.x}, #{value.presence&.y}]" : '[]' %>]">
          </div>
      </div>
  <% end %>

  <div class="map-info detail_object <%= 'linestring-info' if value.try(:geometry_type) == RGeo::Feature::LineString || definition.dig('ui', 'edit', 'type') == 'LineString' %>">
    <div class="content-object-item">
      <span class="embedded-header">
        <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if options['readonly'].to_s == 'true' %>
        <%= definition['label'] %>
        <%= render 'data_cycle_core/contents/helper_text', local_assigns %>
      </span>

      <% unless value.try(:geometry_type) == RGeo::Feature::LineString || definition.dig('ui', 'edit', 'type') == 'LineString' %>

        <div class="form-element longitude number">
          <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key.gsub(/location/, 'longitude'))}" do %>
            <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) unless can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
            <%= DataCycleCore::Thing.human_attribute_name(:longitude, locale: DataCycleCore.ui_language) %>
          <% end %>
          <%= number_field_tag key.gsub(/location/, 'longitude'), value.presence&.x, class: 'form-control', step: :any, readonly: !can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)), id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key.gsub(/location/, 'longitude'))}", placeholder: 'z.B. 14,550683' %>
        </div>

        <div class="form-element latitude number">
          <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key.gsub(/location/, 'latitude'))}" do %>
            <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) unless can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
            <%= DataCycleCore::Thing.human_attribute_name(:latitude, locale: DataCycleCore.ui_language) %>
          <% end %>
          <%= number_field_tag key.gsub(/location/, 'latitude'), value.presence&.y, class: 'form-control', step: :any, readonly: !can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)), id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key.gsub(/location/, 'longitude'))}", placeholder: 'z.B. 47,515785' %>
        </div>

        <%= render_attribute_editor key: key.gsub(/location/, 'elevation'), definition: content&.schema&.dig(*schema_path_from_key(key.gsub(/location/, 'elevation'))), value: (content.elevation.blank? || content.elevation.zero?) ? nil : content.elevation, parameters: { options: { force_render: true, prefix: local_assigns.dig(:options, :prefix) } }, content: content if content.collect_properties.flatten.include?('elevation') %>

        <%= link_to t('actions.geocode', locale: DataCycleCore.ui_language, title: content&.schema&.dig('properties', DataCycleCore::Feature::Geocode.address_source(content), 'label')), '#',
          class: 'button geocode-address-button',
          title: t('actions.geocode', locale: DataCycleCore.ui_language, title: content&.schema&.dig('properties', DataCycleCore::Feature::Geocode.address_source(content), 'label')),
          data: {
            address_key: DataCycleCore::Feature::Geocode.address_source(content),
            locale: I18n.locale.to_s,
            not_found_text: t('common.address_not_found', locale: DataCycleCore.ui_language)
          } if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) && DataCycleCore::Feature::Geocode.allowed?(content) %>
      <% end %>
    </div>
  </div>

<% end %>
