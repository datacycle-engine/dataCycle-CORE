<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options, content: content do %>

  <%= label_tag key, class: 'openlayers-style' do %>
    <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if options['readonly'].to_s == 'true' %>
    <%= definition['label'] %>
  <% end %>

  <%= hidden_field_tag key, value, class: 'location-data' %>

  <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) && DataCycleCore::Feature::Geocode.allowed?(content) %>
    <a href="#" class="button geocode-address-button openlayers-style" title="<%= t('actions.geocode', locale: DataCycleCore.ui_language, title: content&.schema&.dig('properties', DataCycleCore::Feature::Geocode.address_source(content), 'label')) %>" data-address-key="<%= DataCycleCore::Feature::Geocode.address_source(content) %>"><%= t('actions.geocode', locale: DataCycleCore.ui_language, title: content&.schema&.dig('properties', DataCycleCore::Feature::Geocode.address_source(content), 'label')) %></a>
  <% end %>

  <% if value.try(:geometry_type) == RGeo::Feature::Point || value.blank? %> <%# only show points for now, not the lines %>
      <div class="edit-type geographic">
          <span class="map-info openlayers-style">
              <%= DataCycleCore::Place.human_attribute_name(:longitude, locale: DataCycleCore.ui_language) %>: <span class="map-longitude"><%= value.presence&.x %></span><br>
              <%= DataCycleCore::Place.human_attribute_name(:latitude, locale: DataCycleCore.ui_language) %>: <span class="map-latitude"><%= value.presence&.y %></span>
          </span>

          <% map_id = "map_#{SecureRandom.hex(16)}" %>
          <script>
              var <%= map_id %> = {
                  type: "<%= (value.presence&.geometry_type || RGeo::Feature::Point).to_s %>",
                      points: [<%= value.present? ? "[#{value.presence&.x}, #{value.presence&.y}]" : '[]' %>]
              };
          </script>

          <div id="<%= map_id %>" class="geographic-map <%= 'editable' if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>" style="max-height: 450px;" data-default-position="<%= DataCycleCore.default_map_position.presence&.to_json %>" data-icon-path="<%= image_path('location.svg') %>">
          </div>
      </div>
  <% elsif value.try(:geometry_type) == RGeo::Feature::LineString %> <%# only show points for now, not the lines %>
      <div class="edit-type geographic">

          <% map_id = "map_#{SecureRandom.hex(16)}" %>
          <script>
              var <%= map_id %> = {
                  type: "<%= value.geometry_type.to_s %>",
                      points: [<%= value.points.map { |p| "[#{p.x}, #{p.y}]" }.join(",") %>]
              };
          </script>

          <div id="<%= map_id %>" class="geographic-map" style="max-height: 450px;" data-default-position="<%= DataCycleCore.default_map_position.presence&.to_json %>" data-icon-path="<%= image_path('location.svg') %>">
          </div>
      </div>
  <% end %>

<% end %>
