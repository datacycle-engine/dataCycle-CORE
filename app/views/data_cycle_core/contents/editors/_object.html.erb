<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options.merge('class' => 'detail_object'), content: content, parent: local_assigns[:parent] do %>

  <div class="content-object-item">
    <span class="embedded-header">
      <%= attribute_edit_label_tag(**local_assigns) %>
    </span>

    <% ordered_validation_properties(validation: definition).each do |o_key, o_definition| %>
      <%= render_attribute_editor key: o_key,
                                  definition: o_definition,
                                  value: value.try(:[], o_key),
                                  parameters: {
                                    options: { prefix: local_assigns.dig(:options, :prefix) }
                                  },
                                  content: content,
                                  prefix: key %>
    <% end %>

  </div>

<% end %>
