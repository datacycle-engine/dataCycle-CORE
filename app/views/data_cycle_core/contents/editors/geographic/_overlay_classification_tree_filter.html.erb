<% if local_assigns[:show_title] %>
  <ul class="accordion" data-accordion data-allow-all-closed="true" data-multi-expand="true">
    <%= tag.li(class: "accordion-item", data: { accordion_item: true }) do %>
      <span class="filter-group-label"><%= config[:label] %></span>
      <a href="#" class="accordion-title"></a>
      <div class="accordion-content" data-tab-content>
        <%= render 'data_cycle_core/contents/editors/geographic/overlay_classification_tree_level',
                    value: config[:value],
                    random_id: random_id,
                    key: key %>
      </div>
    <% end %>
  </ul>
<% else %>
  <%= render 'data_cycle_core/contents/editors/geographic/overlay_classification_tree_level',
              value: config[:value],
              random_id: random_id,
              key: key %>
<% end %>
