<%= render 'data_cycle_core/contents/editors/attribute_editor', key: key, definition: definition, value: value, options: options.merge('class' => 'object embedded_object'), content: content do %>
  <% new_content ||= false %>

  <%= label_tag(key, definition['label']) if DataCycleCore::Feature::PublicationSchedule.includes_attribute_key(content, key) %>

  <div class="embedded-object" id="<%= sanitize_to_id(key) %>"
    data-language="<%= I18n.locale.to_s %>"
    data-key="<%= key %>"
    data-label="<%= definition['label'] %>"
    data-definition="<%= definition.to_json %>"
    data-options="<%= options.to_json %>"
    data-max="<%= definition.dig('validations', 'maxLength') || 0 %>"
    data-min="<%= definition.dig('validations', 'minLength') || 0 %>"
    data-write="<%= can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>">

    <% internal_template = DataCycleCore::DataHashService.get_internal_template(definition['linked_table'], definition['template_name']) %>
    <% internal_objects = DataCycleCore::DataHashService.get_internal_data(definition['linked_table'], value) %>

    <% if internal_template&.template_name.present? && internal_objects.present? %>
      <% internal_objects.each_with_index do |object, index| %>
        <%= render_embedded_object_partial(key: key, definition: definition, parameters: {internal_template: internal_template, object: object, index: index, options: options, new_content: new_content}, content: content) %>
      <% end %>
    <% elsif internal_template&.template_name.present? && internal_objects.blank? %>
      <%= hidden_field_tag key + '[]', nil, id: "#{sanitize_to_id(key)}_default" %>
    <% end %>

    <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
        <button id="add_<%= sanitize_to_id(key) %>" type="button" class="button addContentObject" style="display: none;"><%= definition['label'] %> hinzufügen<i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw"></i></button>
    <% end %>
    </div>

<% end unless (DataCycleCore::Feature::PublicationSchedule.includes_attribute_key(content, key) && !DataCycleCore::Feature::PublicationSchedule.enabled?) %>
