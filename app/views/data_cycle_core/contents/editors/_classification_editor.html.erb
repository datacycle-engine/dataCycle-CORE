<%= render 'data_cycle_core/contents/editors/attribute_editor', key: key, definition: definition, value: value, options: options, content: content do %>
    
  <%= label_tag(key, definition['label']) %>

  <div class="v-select">
    <%= select_tag(key, value.blank? ? nil : options_for_select(value.map{ |c| [c.try(:name), c.id] }, value.map(&:id)), {multiple: true, disabled: !can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)), class: 'async-select', data: { tree_label: definition['tree_label'], max: 20, placeholder: '' }}) %>

    <% value.presence&.each do |c| %>
      <%= hidden_field_tag key + '[]', c.id %>
    <% end unless can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
  </div>

<% end if classification_tree_label_has_children?(definition['tree_label']) %>