<% I18n.with_locale(locale) do %>
  <% internal_template = DataCycleCore::DataHashService.get_internal_template(definition['template_name']) %>

  <% validation_properties = ordered_validation_properties(validation: internal_template.schema) %>

  <% unless validation_properties.nil? %>
    <div class="content-object-item draggable_<%= sanitize_to_id(key) %>" id="<%= sanitize_to_id(key) %>_item_<%= index %>" data-index="<%= index %>">
      <span class="embedded-header">
        <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, internal_template, :edit)) %>
          <span class="draggable-handle"><i class="fa fa-bars" aria-hidden="true"></i></span>
        <% end %>
        <%= render 'data_cycle_core/shared/icon', icon_type: internal_template.template_name.downcase %> <%= definition['label'] %>
        <%= render 'data_cycle_core/contents/helper_text', local_assigns %>
      </span>

      <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, internal_template, :edit)) %>
        <%= button_tag tag.i(class: 'fa fa-times'), type: :button, class: 'button removeContentObject' %>
      <% end %>

      <% validation_properties.each do |o_key, o_prop| %>
        <%= render_attribute_editor key: "#{key}[#{index}][#{o_key}]", definition: o_prop, value: nil, parameters: { options: { prefix: local_assigns.dig(:options, :prefix) }, parent: internal_template }, content: content %>
      <% end %>
    </div>
  <% end %>
<% end %>
