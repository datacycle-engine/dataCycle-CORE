<%= tag.div class: "content-object-item draggable_#{sanitize_to_id(key)} accordion-item is-active",
  id: "#{sanitize_to_id(key)}_item_#{index}",
  data: {
    id: local_assigns[:object]&.id,
    index: index,
    accordion_item: true
  } do %>

  <% readonly = !attribute_editable?(key, definition, local_assigns[:options], local_assigns[:object]) %>

  <span class="embedded-header">
    <% unless readonly %>
      <span class="draggable-handle"><i class="fa fa-bars" aria-hidden="true"></i></span>
      <span class="swap-prev swap-button disabled dc-foundation-tooltip"
        title="<%= t('embedded.move_up', locale: DataCycleCore.ui_language) %>"><i
          class="fa fa-arrow-up" aria-hidden="true"></i></span>
      <span class="swap-next swap-button disabled dc-foundation-tooltip"
        title="<%= t('embedded.move_down', locale: DataCycleCore.ui_language) %>"><i
          class="fa fa-arrow-down" aria-hidden="true"></i></span>
    <% end %>
  </span>

  <a href="#" class="accordion-title">
    <span class="icon"><i class="fa fa-calendar" aria-hidden="true"></i></span>
    <span class="embedded-label"><%= definition['label'] %></span>
    <%= render 'data_cycle_core/contents/helper_text', local_assigns %>
  </a>

  <% unless readonly %>
    <%= button_tag tag.i(class: 'fa fa-times'), type: :button, class: 'button removeContentObject', data: {
          confirm_delete: definition&.dig('translated') && local_assigns[:object]&.translations&.many? ? t('actions.delete_with_translated_html', locale: DataCycleCore.ui_language) : nil
        } %>
  <% end %>

  <%= hidden_field_tag("#{key}[#{index}][id]", local_assigns[:object].id) unless local_assigns[:duplicated_content] || local_assigns[:object].nil? %>

  <% value = local_assigns[:object]&.to_h || {} %>

  <div class="schedule-editor embedded-properties accordion-content" data-tab-content>
    <div class="daterange schedule-range">
      <div class="form-element start">
        <% full_day = value&.dig(:duration).to_i.positive? && value&.dig(:duration) % 1.day == 0 && Time.zone.now.beginning_of_day == value&.dig(:start_time, :time) %>

        <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][start_time][time]")}" do %>
          <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if readonly %>
          <%= t('schedule.dtstart', locale: DataCycleCore.ui_language) %>
        <% end %>
        <% if readonly %>
          <%= text_field_tag "#{key}[#{index}][start_time][time]",
            value&.dig(:start_time, :time).blank? ? nil : l(value&.dig(:start_time, :time)&.in_time_zone.try(full_day ? :to_date : :to_datetime), format: :edit, locale: DataCycleCore.ui_language),
            class: 'read-only date',
            id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][start_time][time]")}", readonly: true %>
        <% else %>
          <%= datetime_field_tag "#{key}[#{index}][start_time][time]", value&.dig(:start_time, :time)&.in_time_zone, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][start_time][time]")}", data: { type: 'datepicker', disable_time: full_day } %>
        <% end %>
      </div>

      <div class="form-element end">
        <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][end_time][time]")}" do %>
          <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if readonly %>
          <%= t('schedule.dtend', locale: DataCycleCore.ui_language) %>
        <% end %>

        <% end_time = full_day ? value&.dig(:start_time, :time)&.in_time_zone&.+(value&.dig(:duration).to_i)&.beginning_of_day&.-(1.second)&.to_date : value&.dig(:start_time, :time)&.in_time_zone&.+(value&.dig(:duration).to_i) %>

        <% if readonly %>
          <%= text_field_tag "#{key}[#{index}][end_time][time]",
            end_time.blank? ? nil : l(end_time, format: :edit, locale: DataCycleCore.ui_language),
            class: 'read-only date',
            id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][end_time][time]")}", readonly: true %>
        <% else %>
          <%= datetime_field_tag "#{key}[#{index}][end_time][time]", end_time, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][end_time][time]")}", data: { type: 'datepicker', disable_time: full_day } %>
        <% end %>
      </div>

      <div class="fullday">
        <%= hidden_field_tag "#{key}[#{index}][full_day]", full_day ? '1' : nil if readonly %>
        <%= check_box_tag "#{key}[#{index}][full_day]", '1', full_day, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][full_day]")}", disabled: readonly %>
        <%= label_tag "#{key}[#{index}][full_day]", t('schedule.full_day', locale: DataCycleCore.ui_language) %>
      </div>
    </div>

    <div
      class="rrules <%= value&.dig(:rrules, 0, :rule_type)&.remove('IceCube::')&.remove('Rule')&.downcase || 'single_occurrence' %>">
      <div class="form-element">
        <%= label_tag "#{key}[#{index}][rrules][][rule_type]" do %>
          <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if readonly %>
          <%= t('schedule.rrule', locale: DataCycleCore.ui_language) %>
        <% end %>
        <%= hidden_field_tag "#{key}[#{index}][rrules][][rule_type]", value.dig(:rrules, 0, :rule_type) || 'IceCube::SingleOccurrenceRule' if readonly %>
        <%= select_tag "#{key}[#{index}][rrules][][rule_type]", options_for_select(ice_cube_select_options, value.dig(:rrules, 0, :rule_type)), class: 'rrule-type-selector', disabled: readonly %>
      </div>

      <div class="form-element daily weekly monthly yearly">
        <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][interval]")}" do %>
          <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if readonly %>
          <span class="daily"><%= t('schedule.every.maskulin', locale: DataCycleCore.ui_language) %></span>
          <span class="weekly"><%= t('schedule.every.feminin', locale: DataCycleCore.ui_language) %></span>
          <span class="monthly"><%= t('schedule.every.neutrum', locale: DataCycleCore.ui_language) %></span>
          <span class="yearly"><%= t('schedule.every.neutrum', locale: DataCycleCore.ui_language) %></span>
        <% end %>
        <%= number_field_tag "#{key}[#{index}][rrules][][interval]", value&.dig(:rrules, 0, :interval) || 1, in: 1..30, step: 1, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][interval]")}", readonly: readonly %>
        <span class="after-label">
          <span class="daily"><%= t('schedule.day', locale: DataCycleCore.ui_language) %></span>
          <span class="weekly"><%= t('schedule.week', locale: DataCycleCore.ui_language) %></span>
          <span class="monthly"><%= t('schedule.month', locale: DataCycleCore.ui_language) %></span>
          <span class="yearly"><%= t('schedule.year', locale: DataCycleCore.ui_language) %></span>
        </span>
      </div>

      <div class="weekly form-element">
        <%= label_tag sanitize_to_id("#{key}[#{index}][rrules][][validations][day]") do %>
          <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if readonly %>
          <%= t('schedule.on', locale: DataCycleCore.ui_language) %>
        <% end %>
        <% [*(1..6), 0].each do |v| %>
          <span class="weekday-checkbox">
            <%= hidden_field_tag "#{key}[#{index}][rrules][][validations][day][]", v if readonly && value&.dig(:rrules, 0, :validations, :day)&.include?(v) %>
            <%= check_box_tag "#{key}[#{index}][rrules][][validations][day][]", v, value&.dig(:rrules, 0, :validations, :day)&.include?(v), id: sanitize_to_id("#{key}[#{index}][rrules][][validations][day][#{v}]"), disabled: readonly %>
            <%= label_tag sanitize_to_id("#{key}[#{index}][rrules][][validations][day][#{v}]"), t('date.abbr_day_names', locale: DataCycleCore.ui_language)[v] %>
          </span>
        <% end %>
      </div>

      <div class="until daily weekly monthly yearly form-element">
        <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][until]")}" do %>
          <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if readonly %>
          <%= t('terms.until', locale: DataCycleCore.ui_language) %>
        <% end %>
        <% if readonly %>
          <%= text_field_tag "#{key}[#{index}][rrules][][until]",
            value&.dig(:rrules, 0, :until).blank? ? nil : l(value.dig(:rrules, 0, :until).in_time_zone.to_date, locale: DataCycleCore.ui_language),
            class: 'read-only date',
            id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][until]")}", readonly: true %>
        <% else %>
          <%= date_field_tag "#{key}[#{index}][rrules][][until]",
            value&.dig(:rrules, 0, :until)&.in_time_zone&.to_date,
            id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][until]")}",
            data: {
              type: 'datepicker' ,
              min_date: value&.dig(:start_time, :time)&.in_time_zone
            } %>
        <% end %>
      </div>

      <div class="special-dates daterange single_occurrence daily weekly monthly yearly">
        <%= hidden_field_tag "#{key}[#{index}][rtimes]", value&.dig(:rtimes).blank? ? nil : value&.dig(:rtimes)&.map{ |t| l(t[:time]&.in_time_zone, format: :edit, locale: DataCycleCore.ui_language) }&.join(', ') %>

        <div class="form-element exdate">
          <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][extimes]")}" do %>
            <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if readonly %>
            <%= t('schedule.exdate', locale: DataCycleCore.ui_language) %>
          <% end %>
          <% if readonly %>
            <%= text_field_tag "#{key}[#{index}][extimes]",
              value&.dig(:extimes).blank? ? nil : value&.dig(:extimes)&.map{ |t| l(t[:time].in_time_zone, format: :edit, locale: DataCycleCore.ui_language) }&.join(', '),
              class: 'read-only date',
              id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][extimes]")}", readonly: true %>
          <% else %>
            <%= date_field_tag "#{key}[#{index}][extimes]",
              value&.dig(:extimes)&.map { |t| t[:time]&.in_time_zone }&.join(', '),
              id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][extimes]")}",
              data: {
                type: 'datepicker',
                mode: 'multiple' ,
                min_date: value&.dig(:start_time, :time)&.in_time_zone,
                max_date: value&.dig(:rrules, 0, :until)&.in_time_zone
              } %>
          <% end %>
        </div>
      </div>
    </div>

  </div>
<% end %>
