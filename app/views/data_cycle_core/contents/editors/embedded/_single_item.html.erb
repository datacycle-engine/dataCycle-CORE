<% I18n.with_locale(locale) do %>
  <% ordered_validation_properties(validation: object&.schema)&.each do |o_key, o_prop| %>
    <% o_value = object.template ? nil : I18n.with_locale(local_assigns[:attribute_locale]){ object.try(o_key.to_sym) } %>
    <%= render_attribute_editor key: "#{key}[#{index}][#{o_key}]",
      definition: o_prop,
      value: o_value,
      parameters: {
        options: (o_prop.dig('ui', 'edit', 'options') || {}).merge(prefix: local_assigns.dig(:options, :prefix)),
        parent: object,
        attribute_locale: local_assigns[:attribute_locale],
        duplicated_content: local_assigns[:duplicated_content],
        hide_embedded: local_assigns[:hide_embedded]
      },
      content: content %>
  <% end %>
<% end %>
