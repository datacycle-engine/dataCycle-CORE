<div class="content-object-item content-schedule-item draggable_<%= sanitize_to_id(key) %>" id="<%= sanitize_to_id(key) %>_item_<%= index %>" data-index="<%= index %>">

    <span class="embedded-header">
      <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
        <span class="draggable-handle"><i class="fa fa-bars" aria-hidden="true"></i></span>
        <span class="swap-prev swap-button disabled" title="<%= t('common.embedded_move_up', locale: DataCycleCore.ui_language) %>" data-tooltip><i class="fa fa-arrow-up" aria-hidden="true"></i></span>
        <span class="swap-next swap-button disabled" title="<%= t('common.embedded_move_down', locale: DataCycleCore.ui_language) %>" data-tooltip><i class="fa fa-arrow-down" aria-hidden="true"></i></span>
      <% end %>
      <span class="icon"><i class="fa fa-calendar" aria-hidden="true"></i></span>
      <%= definition['label'] %>
      <%= render 'data_cycle_core/contents/helper_text', local_assigns %>
    </span>

    <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
      <%= button_tag tag.i(class: 'fa fa-times'), type: :button, class: 'button removeContentObject' %>
    <% end %>

    <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
      <div class="schedule-editor">
        <div class="daterange schedule-range">
          <div class="form-element start">
            <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][start_time][time]")}", t('schedule.dtstart', locale: DataCycleCore.ui_language) %>
            <%= datetime_field_tag "#{key}[#{index}][start_time][time]", nil, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][start_time][time]")}", data: { type: 'datepicker' } %>
          </div>

          <div class="form-element end">
            <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][end_time][time]")}", t('schedule.dtend', locale: DataCycleCore.ui_language) %>
            <%= datetime_field_tag "#{key}[#{index}][end_time][time]", nil, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][end_time][time]")}", data: { type: 'datepicker' } %>
          </div>

          <div class="form-element fullday">
            <%= check_box_tag "#{key}[#{index}][full_day]", '1', false, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][full_day]")}", data: { type: 'datepicker' } %>
            <%= label_tag "#{key}[#{index}][full_day]", t('schedule.full_day', locale: DataCycleCore.ui_language) %>
          </div>
        </div>

        <div class="rrules single_occurrence">
          <div class="form-element">
            <%= label_tag "#{key}[#{index}][rrules][][rule_type]", t('schedule.rrule', locale: DataCycleCore.ui_language) %>
            <%= select_tag "#{key}[#{index}][rrules][][rule_type]", options_for_select(ice_cube_select_options), class: 'rrule-type-selector' %>
          </div>

          <div class="form-element daily weekly monthly yearly">
            <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][interval]")}" do %>
              <span class="daily"><%= t('schedule.every.maskulin', locale: DataCycleCore.ui_language) %></span>
              <span class="weekly"><%= t('schedule.every.feminin', locale: DataCycleCore.ui_language) %></span>
              <span class="monthly"><%= t('schedule.every.neutrum', locale: DataCycleCore.ui_language) %></span>
              <span class="yearly"><%= t('schedule.every.neutrum', locale: DataCycleCore.ui_language) %></span>
            <% end %>
            <%= number_field_tag "#{key}[#{index}][rrules][][interval]", 1, in: 1..30, step: 1, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][interval]")}" %>
            <span class="after-label">
              <span class="daily"><%= t('schedule.day', locale: DataCycleCore.ui_language) %></span>
              <span class="weekly"><%= t('schedule.week', locale: DataCycleCore.ui_language) %></span>
              <span class="monthly"><%= t('schedule.month', locale: DataCycleCore.ui_language) %></span>
              <span class="yearly"><%= t('schedule.year', locale: DataCycleCore.ui_language) %></span>
            </span>
          </div>

          <div class="weekly form-element">
            <%= label_tag sanitize_to_id("#{key}[#{index}][rrules][][validations][day]"), t('schedule.on', locale: DataCycleCore.ui_language) %>
            <% [*(1..6), 0].each do |v| %>
              <span class="weekday-checkbox">
                <%= check_box_tag "#{key}[#{index}][rrules][][validations][day]", v, false, id: sanitize_to_id("#{key}[#{index}][rrules][][validations][day][#{v}]") %>
                <%= label_tag sanitize_to_id("#{key}[#{index}][rrules][][validations][day][#{v}]"), t('date.abbr_day_names', locale: DataCycleCore.ui_language)[v] %>
              </span>
            <% end %>
          </div>

          <div class="monthly form-element">
            <%#= radio_button_tag "#{key}[rrules][][validations][wday]", 'weekday', true, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}_rrules_validations_wday_weekday" %>
            <%#= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}_rrules_validations_wday_weekday", t('schedule.weekday', locale: DataCycleCore.ui_language) %>
            <%#= radio_button_tag "#{key}[rrules][][validations][day_of_month]", 'dayofmonth', id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}_rrules_validations_day_of_month_dayofmonth" %>
            <%#= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}_rrules_validations_day_of_month_dayofmonth", t('schedule.dayofmonth', locale: DataCycleCore.ui_language) %>
          </div>

          <div class="until form-element">
            <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][until]")}", t('terms.until', locale: DataCycleCore.ui_language) %>
            <%= date_field_tag "#{key}[#{index}][rrules][][until]", nil, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id("#{key}[#{index}][rrules][until]")}", data: { type: 'datepicker' } %>
          </div>
        </div>
      </div>
    <% end %>



</div>
