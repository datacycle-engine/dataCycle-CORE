<%= render 'data_cycle_core/contents/editors/attribute_editor', key: key, definition: definition, value: value, options: options do %>

  <%= label_tag(key, definition['label']) %>

  <div class="v-select">
    <%= select_tag(key, value.blank? ? nil : options_for_select(value.map{ |c| [c.try(:name), c.id] }, value.map(&:id)), {multiple: true, disabled: !can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options)) || (Regexp.union(*DataCycleCore.features.dig(:publication_schedule, :validation_keys)) === key && !key.include?('publication_schedule')), class: 'async-select', data: { tree_label: definition['type_name'], max: 20, placeholder: '' }}) %>

    <% value.presence&.each do |c| %>
      <%= hidden_field_tag key + '[]', c.id %>
    <% end unless can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options)) && !(Regexp.union(*DataCycleCore.features.dig(:publication_schedule, :validation_keys)) === key && !key.include?('publication_schedule')) %>
  </div>

<% end %>
