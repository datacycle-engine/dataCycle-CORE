<%= render 'data_cycle_core/contents/editors/attribute_editor', key: key, definition: definition, value: value, options: options do %>

  <div class="v-select">
    <%= label_tag(key, definition['label']) %>
    <%= select_tag(key, options_for_select(value.map { |c| [c.name, c.id] }, value.map(&:id)), {multiple: true, class: 'async-select', data: { 'tree-label': definition['type_name'] }}) %>
  </div>

<% end %>
