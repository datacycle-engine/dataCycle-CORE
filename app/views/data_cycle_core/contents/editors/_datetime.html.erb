<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: merge_class_in_options(options, 'daterange'), content: content, parent: local_assigns[:parent] do %>
  <%= attribute_edit_label_tag(**local_assigns) %>

  <%= datetime_field_tag key, value, options.except('class').merge(id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}", disabled: !attribute_editable?(key, definition, options, content)) %>
<% end %>
