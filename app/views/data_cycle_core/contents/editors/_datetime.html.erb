<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options, content: content, parent: local_assigns[:parent] do %>

  <div class="form-element <%= key.attribute_name_from_key %>">
    <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" do %>
      <span class="icon <%= key.attribute_name_from_key %>">
        <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) unless attribute_editable?(key, definition, options, content) %>
        <i aria-hidden="true" class="fa fa-clock-o"></i> <%= definition['label'] %>
      </span>
      <%= render 'data_cycle_core/contents/helper_text', local_assigns %>
    <% end %>
    <% unless attribute_editable?(key, definition, options, content) %>
      <%= text_field_tag key, value.blank? ? value : l(value.to_datetime, format: :edit, locale: DataCycleCore.ui_language), options.merge({ class: 'read-only date', id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" }) %>
    <% else %>
      <%= datetime_field_tag key, value, options.merge(id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}") %>
    <% end %>
  </div>

<% end %>
