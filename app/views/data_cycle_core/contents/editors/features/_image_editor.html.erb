<% asset_id = value&.id %>

<% if asset_id.present? %>
  <div class="image-editor" data-image-editor="image-editor-<%= asset_id %>">
    <button type="button" class="button image-editor-button" data-disable data-open="image-editor-<%= asset_id %>">
      <i class="fa fa-pencil-square-o" aria-hidden="true"></i>
    </button>
    <div class="full reveal image-editor-reveal"
       id="image-editor-<%= asset_id %>"
       data-reveal data-multiple-opened="true"
       data-v-offset="0"
       data-asset-id="<%= asset_id %>"
       data-file-url="<%= value&.file&.url %>"
       data-file-name="<%= value&.name %>"
       data-file-format="<%= value.content_type.split('/').last %>"
       data-file-mime-type="<%= value.content_type %>"
       data-hidden-field-key="<%= key %>">
      <div class="top-bar">
        <button class="save-button" data-close aria-label="Save modal" type="button">
          <i class="fa fa-floppy-o" aria-hidden="true"></i>
        </button>
        <button class="close-button" data-close aria-label="Close modal" type="button">
          <i class="fa fa-ban" aria-hidden="true"></i>
        </button>
      </div>
      <div class="image-editor-wrapper">
        <div class="tui-image-editor"></div>
      </div>
      <div class="bottom-bar">
        <span>
          POWERED BY:
        </span>
        <a href="#" target="_blank">
          <img src="https://uicdn.toast.com/toastui/img/tui-image-editor-bi.png" />
        </a>
      </div>
    </div>
  </div>
<% else %>
  <% asset_id = SecureRandom.hex(10) %>
  <div class="image-editor" data-image-editor="image-editor-<%= asset_id %>">
    <button type="button" class="button image-editor-button" data-disable data-open="image-editor-<%= asset_id %>">
      <i class="fa fa-pencil-square-o" aria-hidden="true"></i>
    </button>
    <div class="full reveal image-editor-reveal"
         id="image-editor-<%= asset_id %>"
         data-reveal data-multiple-opened="true"
         data-v-offset="0"
         data-asset-id=""
         data-file-url="<%= content&.asset&.file&.url %>"
         data-file-name="<%= content&.asset&.name %>"
         data-file-format="<%= content&.asset&.content_type.split('/').last %>"
         data-file-mime-type="<%= content&.asset&.content_type %>"
         data-hidden-field-key="<%= key %>">
      <button class="save-button" data-close aria-label="Save modal" type="button">
        <span aria-hidden="true">save</span>
      </button>
      <button class="close-button" data-close aria-label="Close modal" type="button">
        <span aria-hidden="true">&times;</span>
      </button>
      <div class="tui-image-editor"></div>
    </div>
  </div>
<% end %>