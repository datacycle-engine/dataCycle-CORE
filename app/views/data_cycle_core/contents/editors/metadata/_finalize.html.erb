<div class="clearfix form-element finalize-container">

    <hr />
    <div class="finalize-button-container">
      <%= check_box_tag 'finalize', true %>
      <%= label_tag 'finalize', t('actions.finalize', locale: DataCycleCore.ui_language), data: { tooltip: true }, title: t('common.content_not_editable', locale: DataCycleCore.ui_language) %>
    </div>

    <% if content.indirect_data_links.by_receiver(current_user).valid.map(&:text_file).compact.present? %>
      <div class="data-link-text-files">
        <b><%= DataCycleCore::DataLink.human_attribute_name("text_file", locale: DataCycleCore.ui_language) %>: </b>

        <ul class="no-bullet">
        <% content.indirect_data_links.by_receiver(current_user).valid.each do |data_link| %>
          <li><%= link_to data_link.text_file.name, get_text_file_data_link_url(data_link), target: :_blank if data_link.text_file.present? %></li>
        <% end %>
        </ul>
      </div>
    <% end %>

</div>
