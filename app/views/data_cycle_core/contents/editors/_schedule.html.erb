<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options.merge('class' => 'object embedded_object'), content: content do %>

  <% objects = value.presence %>

  <div class="embedded-object" id="<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>"
    data-locale="<%= I18n.locale.to_s %>" data-key="<%= key %>" data-label="<%= definition['label'] %>"
    data-definition="<%= definition.to_json %>" data-options="<%= options.to_json %>"
    data-total="<%= value.presence&.size %>" data-ids="<%= value.presence&.ids %>"
    data-max="<%= definition.dig('validations', 'max') || 0 %>"
    data-min="<%= definition.dig('validations', 'min') || 0 %>" data-content-id="<%= content.id %>"
    data-content-type="<%= content.class.table_name %>" data-url="<%= thing_path(content) %>"
    data-write="<%= can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>">

    <% if objects.present? %>
      <% objects.each_with_index do |object, index| %>
        <%= render_embedded_object_partial(key: key, definition: definition, parameters: { object: object, index: index, options: options, new_content: new_content ||= false, attribute_locale: local_assigns[:attribute_locale] }, content: content) %>
      <% end %>

      <% value.presence&.ids&.reject {|v| objects.presence&.ids&.include?(v)}&.each_with_index do |id, index| %>
        <%= hidden_field_tag "#{key}[#{index + objects.size}][id]", id %>
      <% end %>
    <% else %>
      <%= hidden_field_tag key + '[]', nil, id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}_default" %>
    <% end %>

    <div class="buttons">
      <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
        <button id="add_<%= "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" %>" type="button"
        class="button addContentObject" style="display: none;"><%= definition['label'] %>
          hinzufügen<i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw"></i></button>
      <% end %>
    </div>
  </div>

<% end %>
