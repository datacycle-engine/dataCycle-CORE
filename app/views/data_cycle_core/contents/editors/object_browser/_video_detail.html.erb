<% I18n.with_locale(object.first_available_locale) do %>
    <h5>Details (<%= I18n.locale %>)</h5>
    <%= render 'data_cycle_core/contents/viewers/shared/buttons', local_assigns.merge({ content: object }) %>

    <%
        thumbnail_url = object.try(:thumbnail_url) || object.try(:asset).try(:first).try(:thumbnail_url)
    %>

    <% unless object.title.blank? %>
        <dl>
            <dt>Name: </dt>
            <dd><%= object.title %></dd>
        </dl>
    <% end %>
    <dl>
        <% unless object.try(:content_url).nil? %>
            <dt></dt>
            <dd>
                <video class="lazyload" data-poster="<%= thumbnail_url %>" controls="controls" controlsList="nodownload" preload="none">
                    <source src="<%= object.try(:content_url) %>" type="video/mp4">
                    Your browser does not support the video tag
                </video>
            </dd>
        <% end %>

        <% if object.try(:url).present? %>
            <dt>Datei Url: </dt>
            <dd><%= link_to object.try(:url), object.try(:url), target: :_blank %></dd>
        <% elsif object.try(:content_url).present? %>
            <dt>Datei Url: </dt>
            <dd><%= link_to object.try(:content_url), object.try(:content_url), target: :_blank %></dd>
        <% end %>

        <% unless object.try(:file_format).nil? %>
            <dt>Format: </dt>
            <dd><%= object.try(:file_format) %></dd>
        <% end %>

        <% unless object.try(:width).to_i.zero? || object.try(:height).to_i.zero? %>
            <dt>Abmessungen: </dt>
            <dd><%= "#{object.try(:width)} x #{object.try(:height)}" %></dd>
        <% end %>

        <% unless object.try(:content_size).nil? %>
            <dt>Dateigröße: </dt>
            <dd><%= number_to_human_size(object.try(:content_size)) %></dd>
        <% end %>

        <% unless object.try(:director).blank? %>
            <dt>Regie: </dt>
            <dd><%= object.director.first.try(:given_name) %> <%= object.director.first.try(:family_name) %></dd>
        <% end %>

        <% unless object.try(:contributor).blank? %>
            <dt>Kamera: </dt>
            <dd><%= object.contributor.first.try(:given_name) %> <%= object.contributor.first.try(:family_name) %></dd>
        <% end %>

        <% unless object.try(:license).nil? %>
            <dt>Lizenz: </dt>
            <dd><%= object.try(:license) %></dd>
        <% end %>

        <% unless object.try(:restrictions).nil? %>
            <dt>Einschränkungen: </dt>
            <dd><%= object.try(:restrictions) %></dd>
        <% end %>

        <% unless object.try(:date_created).nil? %>
            <dt>Erstellt: </dt>
            <dd><%= l(object.date_created.to_date, locale: DataCycleCore.ui_language) if object.date_created.present? %></dd>
        <% end %>

        <% unless object.try(:date_modified).nil? %>
            <dt>Bearbeitet: </dt>
            <dd><%= l(object.date_modified.to_date, locale: DataCycleCore.ui_language) if object.date_modified.present? %></dd>
        <% end %>

        <%= render partial: 'data_cycle_core/contents/validity_period', locals: {dataCycleObject: object} %>
    </dl>
<% end %>