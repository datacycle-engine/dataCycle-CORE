<% content_for :forms do %>
  <div class="reveal new-item" id="new_<%= new_overlay_key ||= '' %>" data-reveal data-multiple-opened="true" data-overlay="false" data-reset-on-close="true">
      <h3>Neue Organisation erstellen</h3>

      <%= form_for :organization, :url => {:controller => :organizations, :action => "create"} do |f| %>

          <%= hidden_field_tag 'template', 'Organization' %>
          <%= hidden_field_tag 'locale', I18n.locale %>
          <div class="validation-container form-element">
              <%= label_tag 'organization[datahash][legal_name]', DataCycleCore::Organization.human_attribute_name("legal_name", locale: DataCycleCore.ui_language) %>
              <%= text_field_tag 'organization[datahash][legal_name]', '', class: 'form-control', value:'' %>
          </div>
          <%= f.submit t(:submit, locale: DataCycleCore.ui_language), class: "button primary" %>

      <% end %>

      <button class="close-button" data-close aria-label="Close modal" type="button">
          <span aria-hidden="true">&times;</span>
      </button>
  </div>
<% end %>
