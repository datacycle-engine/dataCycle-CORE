<div class="padding-bottom-10">
  <h5>Details</h5>
  <% unless object.title.blank? %>
    <dl>
      <dt>Name: </dt>
      <dd><%= object.title %></dd>
    </dl>
  <% end %>
  <% unless object.metadata.nil? %>
    <dl>
      <% unless object.try(:thumbnail_url).nil? %>
        <dt class="block-flex"></dt>
        <dd class="block-flex"><img class="lazyload" data-src="<%= object.try(:thumbnail_url) %>" /></dd>
      <% end %>

      <% unless object.try(:url).nil? %>
        <dt>Datei Url: </dt>
        <dd><%= link_to object.try(:url), target: :_blank %></dd>
      <% end %>

      <% unless object.try(:file_format).nil? %>
        <dt>Format: </dt>
        <dd><%= object.try(:file_format) %></dd>
      <% end %>

      <% unless object.try(:width).nil? || object.try(:height).nil? %>
        <dt>Abmessungen: </dt>
        <dd><%= "#{object.try(:width)} x #{object.try(:height)}" %></dd>
      <% end %>

      <% unless object.try(:content_size).nil? %>
        <dt>Dateigröße: </dt>
        <dd><%= number_to_human_size(object.try(:content_size)) %></dd>
      <% end %>

      <% unless object.try(:license).nil? %>
        <dt>Lizenz: </dt>
        <dd><%= object.try(:license) %></dd>
      <% end %>

      <% unless object.try(:restrictions).nil? %>
        <dt>Einschränkungen: </dt>
        <dd><%= object.try(:restrictions) %></dd>
      <% end %>

      <% unless object.try(:date_created).nil? %>
        <dt>Erstellt: </dt>
        <dd><%= object.date_created.to_datetime.to_s(:german_date_format) %></dd>
      <% end %>

      <% unless object.try(:date_modified).nil? %>
        <dt>Bearbeitet: </dt>
        <dd><%= object.date_modified.to_datetime.to_s(:german_date_format) %></dd>
      <% end %>

      <% unless object.try(:formatted_validity_period).blank? %>
        <dt>Gültigkeit: </dt>
        <dd><strong>von </strong><%= object.formatted_validity_period['date_published'] %> <%== "<strong>bis</strong> #{object.formatted_validity_period['expires']}" unless object.formatted_validity_period['expires'].blank? %></dd>
      <% end %>
    </dl>
  <% end %>
</div>
