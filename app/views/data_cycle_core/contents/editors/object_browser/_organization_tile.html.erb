<div class="media organization item <%= 'active' if (objects ||= []).include?(object.id) %>" data-id="<%= object.id %>">
  <%= hidden_field_tag key, object.id %>

  <% if editable ||= false %>
    <span class="delete-thumbnail"><i aria-hidden="true" class="fa fa-times"></i></span>
  <% end %>

  <i class="fa fa-user" aria-hidden="true"></i>
  <span class="name"><%= object.try(:legal_name) %></span>
</div>
