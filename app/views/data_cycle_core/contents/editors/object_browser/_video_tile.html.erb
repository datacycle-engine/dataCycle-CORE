<%
    thumbnail_url = object.try(:thumbnail_url) || object.try(:asset).try(:first).try(:thumbnail_url)
%>
<div class="media thumbnail item <%= 'has-restrictions' if object.try(:restrictions).try(:include?, 'gesperrt') %> <%= 'expired-item' unless object.try(:is_valid?) %> <%= 'active' if (objects ||= []).include?(object.id) %>" style="<%= "background-image: url(#{thumbnail_url})" if thumbnail_url.present? %>" data-open="media_reveal_<%= object.id %>" data-id="<%= object.id %>">

  <%= hidden_field_tag key, object.id %>

  <% if object.try(:restrictions).try(:include?, 'gesperrt') %>
    <span data-tooltip aria-haspopup="true" class="has-tip warning" data-click-open="false" tabindex="1" title="Einschränkungen: <%= object.try(:restrictions) %>"><i class="fa fa-exclamation-triangle" aria-hidden="true"></i></span>
  <% end %>

  <% unless object.is_valid? %>
      <span class="expired-item-overlay"><%= t('common.expired_content', locale: DataCycleCore.ui_language) %></span>
  <% end %>

  <% if object.try(:title) %>
    <div class="description"><%= object.try(:title) %></div>
  <% end %>


  <% if editable ||= false %>
    <span class="draggable-handle"><i class="fa fa-bars" aria-hidden="true"></i></span>
    <span class="delete-thumbnail"><i aria-hidden="true" class="fa fa-times"></i></span>
  <% end %>

  <div class="width-content reveal media-preview" id="media_reveal_<%= object.id %>" data-reveal data-reset-on-close="true">
      <button class="close-button" data-close aria-label="Close modal" type="button">
          <span aria-hidden="true">&times;</span>
      </button>
      <span class="preview-title">
        <%= object.try(:title) %>
      </span>
      <div class="video">
          <video class="lazyload" data-poster="<%= thumbnail_url %>" controls="controls" controlsList="nodownload" preload="none">
            <source src="<%= object.try(:content_url) %>" type="video/mp4">
            Your browser does not support the video tag
          </video>
      </div>
      <div class="description">
          <%= render partial: 'data_cycle_core/contents/validity_period', locals: {dataCycleObject: object} %>

          <% unless object.try(:restrictions).blank? %>
              <strong>Einschränkungen:</strong> <%== '<i class="fa fa-exclamation-triangle" aria-hidden="true"></i>' if object.try(:restrictions).try(:include?, 'gesperrt') %> <%= object.try(:restrictions) %> <br /><br />
          <% end %>

          <%= link_to t('tile_links.details', locale: DataCycleCore.ui_language), thing_path(object), target: :_blank %>

          <% if object.try(:content_url).present? %>
            | <%= link_to t('tile_links.full_size', locale: DataCycleCore.ui_language), object.try(:content_url), target: :_blank %>
          <% end %>

          <% if DataCycleCore.features.dig(:external_media_archive, :enabled) %>
              <% if object.try(:url).present? %>
                | <%= link_to t('tile_links.media_archive', locale: DataCycleCore.ui_language), object.url, target: :_blank %>
              <% end %>
          <% end %>
      </div>
  </div>
</div>
