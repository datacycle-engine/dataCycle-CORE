<div v-if="props.item != undefined" class="media person">
  <a v-if="!props.readonly" slot="remove" class="delete-thumbnail" href="#" @click.prevent="props.remove(props.item)"><i aria-hidden="true" class="fa fa-times"></i></a>
  <i class="fa fa-map-marker" aria-hidden="true"></i>
  <span class="name" v-if="props.item.name">{{ props.item.name }} {{ props.item.address }}</span>
  <span class="name" v-else>Keine Übersetzung vorhanden</span>
  <input type="hidden" name="<%= key %>" :value="props.item.id">
</div>


