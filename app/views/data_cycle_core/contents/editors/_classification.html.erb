<%= render 'data_cycle_core/contents/editors/attribute', key: key, definition: definition, value: value, options: options, content: content do %>

  <%= label_tag "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}" do %>
    <%= content_tag(:i, nil, class: 'fa fa-ban', aria_hidden: true) if options['readonly'].to_s == 'true' %>
    <%= definition['label'] %>
    <%= render 'data_cycle_core/contents/helper_text', local_assigns %>
  <% end %>

  <% if can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) && DataCycleCore::Feature::AutoTagging.allowed?(content) && DataCycleCore.features.dig(:auto_tagging, :attribute_keys).include?(key.attribute_name_from_key) %>
    <%= link_to auto_tagging_thing_path(id: content.id, key: sanitize_to_id(key)), class: 'auto-tagging-button', remote: true, data: { disable_with: '<i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw"></i>' } do %>
      <i class="fa fa-cloud-download"></i>
    <% end %>
  <% end %>

  <div class="v-select">
      <% classification_items = DataCycleCore::ClassificationTreeLabel
        .includes(:classification_aliases)
        .find_by(name: definition['tree_label'])
        &.classification_aliases
        &.includes(
          :primary_classification, :classification_alias_path, sub_classification_alias: [
            :primary_classification, :classification_alias_path, sub_classification_alias: [
              :primary_classification, :classification_alias_path, :sub_classification_alias
            ]
          ]
        )
        &.order(internal_name: :asc) %>
      <%= hidden_field_tag key + '[]', nil %>
      <% if classification_items.size > DataCycleCore.max_asynch_classification_items || (DataCycleCore::Feature::AutoTagging.allowed?(content) && DataCycleCore.features.dig(:auto_tagging, :attribute_keys).include?(key.attribute_name_from_key)) %>
          <%= select_tag(
            key,
            value.blank? ? nil : options_for_select(
              value.map { |c|
                [
                  c.primary_classification_alias.try(:internal_name),
                  c.id,
                  {
                    title: [
                      c.primary_classification_alias.full_path,
                      c.primary_classification_alias.description
                    ].reject(&:blank?).join("\n\n")
                  }
                ]
              }, value&.map(&:id)
            ),
            {
              multiple: true,
              include_blank: true,
              disabled: !can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)),
              class: 'async-select',
              data: {
                tree_label: definition['tree_label'],
                max: 20,
                placeholder: ''
              },
              id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}"
            }.merge(definition.dig('ui', 'edit', 'options') || {})
          ) %>
      <% else %>
          <% available_items = classification_items&.map { |c|
            [
              c.try(:internal_name),
              c&.primary_classification.try(:id),
              {
                title: [
                  c.full_path,
                  c.description
                ].reject(&:blank?).join("\n\n"),
                data: {
                  title: c.full_path,
                },
                disabled: !c.assignable
              }
            ]
          } %>

          <%= select_tag(
            key,
            options_for_select(available_items, value&.map(&:id)),
            {
              multiple: true,
              include_blank: true,
              disabled: !can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)),
              class: 'multi-select',
              data: {
                tree_label: definition['tree_label'],
                max: 20,
                placeholder: ''
              },
              id: "#{local_assigns.dig(:options, :prefix)}#{sanitize_to_id(key)}"
            }.merge(definition.dig('ui', 'edit', 'options') || {})
          ) %>
      <% end %>

    <% value.presence&.each do |c| %>
      <%= hidden_field_tag key + '[]', c.id %>
    <% end unless can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
  </div>
<% end if classification_tree_label_has_children?(definition['tree_label']) %>
