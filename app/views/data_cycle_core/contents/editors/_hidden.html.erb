<% if value.is_a?(ActiveRecord::Relation) %>
  <% value.each do |v| %>
    <%= hidden_field_tag key + '[]', v.try(:id), multiple: true %>
  <% end %>
<% elsif value.is_a?(OpenStruct) %>
  <% value.each_pair do |k, v| %>
    <%= hidden_field_tag "#{key}[#{k.to_s.underscore_blanks}]", v %>
  <% end %>
<% elsif !value.nil? %>
  <%= hidden_field_tag key, value %>
<% end %>
