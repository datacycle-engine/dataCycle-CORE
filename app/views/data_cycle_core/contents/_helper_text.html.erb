<%= tag.i class: 'fa fa-info-circle dc-foundation-tooltip',
          title: t("helper_text.attributes.#{content&.template_name}.#{key.attribute_name_from_key}.tooltip", locale: active_ui_locale),
          data: {
            allow_html: true
          } if I18n.exists?("helper_text.attributes.#{content&.template_name}.#{key.attribute_name_from_key}.tooltip", locale: active_ui_locale) %>

<%= tag.i '*', class: 'required-field-marker', title: t('common.required_field', locale: active_ui_locale) if local_assigns[:definition]&.dig('validations', 'required') %>
