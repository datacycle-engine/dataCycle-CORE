<% helper_text = t("helper_text.attributes.#{content&.template_name&.underscore_blanks}.#{key.attribute_name_from_key}.tooltip", default: '', locale: DataCycleCore.ui_language) %>

<%= tag.i class: 'fa fa-info-circle', aria_hidden: true, title: helper_text, data: { tooltip: true, allow_html: true } if helper_text.present? %>

<%= tag.i '*', class: 'required-field-marker', aria_hidden: true, title: t('common.required_field', locale: DataCycleCore.ui_language), data: { tooltip: true, allow_html: true } if local_assigns[:definition]&.dig('validations', 'required') %>
