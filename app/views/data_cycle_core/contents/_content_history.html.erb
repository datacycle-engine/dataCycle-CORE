<div class="detail-content detail-content-wrapper">

    <div class="row align-center">

      <% unless content.metadata.nil? %>

          <% if !content.metadata.nil? && !content.schema.nil? %>

              <% validation_properties = get_ordered_validation_properties(content.schema) %>

              <% if !validation_properties.nil? %>

                  <div class="type properties">

                      <% validation_properties.each do |key, prop| %>

                          <% value = prop.dig('type') == "object" ? content.try(key.to_sym) : schema[key] %>
                          <%= render_attribute_history_viewer key: key, definition: prop, value: normalize_value(value), parameters: { options: options ||= {} } %>

                      <% end %>

                  </div>

              <% end %>

          <% end %>

      <% end %>

      <%= render 'translations', language: nil, dataCycleObject: content %>

    </div>

</div>
