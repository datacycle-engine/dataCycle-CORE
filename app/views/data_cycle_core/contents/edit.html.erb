<% breadcrumb :edit_content, @content, @watch_list %>

<% content_for :top_content do %>

  <div class="reveal-blur">
    <div id="edit-form">
      <%= render 'form',
        key_prefix: 'thing[datahash]',
        content: @content,
        watch_list: @watch_list,
        split_source: @split_source,
        subscribe_notice: true,
        link_action: :split_view %>
    </div>
  </div>

<% end %>
