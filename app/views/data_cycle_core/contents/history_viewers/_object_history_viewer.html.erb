<%= render 'data_cycle_core/contents/viewers/attribute_viewer', key: key, definition: definition, value: value, options: options do %>

    <% get_ordered_validation_properties(definition).each do |o_key, o_definition| %>

        <% item_diff = options.dig(:item_diff) ? options.dig(:item_diff) : nil  %>
        <% item_diff = item_diff.kind_of?(Hash) ? item_diff.dig(o_key) : item_diff  %>
        <% item_diff_options = options.clone %>
        <% item_diff_options[:item_diff] = item_diff %>

        <%= render_attribute_history_viewer key: "#{key}[#{o_key}]", definition: o_definition, value: value.try(:[], o_key), parent_object: parent_object,  parameters: { options: item_diff_options } %>

    <% end %>

<% end %>
