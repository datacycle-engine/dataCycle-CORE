<% contents.presence&.each do |content| %>
  <% I18n.with_locale(content.first_available_locale) do %>
    <%= render_content_tile(item: content, parameters: local_assigns, mode: 'tree') %>
  <% end %>
<% end %>
<% if @page < @total_pages %>
  <li class="content-row button-row">
    <%= link_to request.params.slice(:language, :f, :stored_filter).merge({ ct_id: local_assigns[:classification_parent_tree]&.id || classification_tree.id, con_id: local_assigns[:container]&.id, ctl_id: classification_tree_label&.id, cpt_id: local_assigns[:classification_parent_tree]&.id, page: (@page + 1), mode: @mode }), data: { remote: true, disable_with: "<i class='fa fa-spinner fa-spin'></i> #{t('common.loading', locale: DataCycleCore.ui_language)}" } do %>
      <%= t('common.load_more', locale: DataCycleCore.ui_language) %>
    <% end %>
  </li>
<% end %>
