<% set_key_prefix keyPrefix %>

<%= render_content_partial 'edit_header_functions', content: content %>

<%= form_for content, url: polymorphic_path(content, watch_list_id: @watch_list), html: {class: 'validation-form edit-content-form'}, builder: DataCycleCore::DataHashHelper::DataCycleFormBuilder do |f| %>
	<%= hidden_field_tag 'uuid', content.id %>
	<%= hidden_field_tag :table, content.class.table_name %>
	<%= hidden_field_tag 'creative_work[datahash][creator]', content.try(:creator).try(:first).try(:id) %>
  <%= hidden_field_tag 'locale', I18n.locale %>

	<% unless @splitSource.nil? %>
		<% I18n.with_locale(@splitSource.first_available_locale) do %>
			<div class="flex-box">
				<div class="row split-content detail-content">
          <%= hidden_field_tag 'splitview', true %>
					<% if can?(:subscribe, @splitSource) && @splitSource.subscriptions.by_user(current_user).size == 0 %>
						<div class="subscribe-parent notice"><p>Sie sollten diesen Inhalt (<%=@splitSource.template_name%>) abonnieren, um Ihren neu erstellten Inhalt (<%=content.template_name%>) aktuell halten zu können.</p>
							<%= link_to "Abonnieren", subscriptions_path(subscribable_id: @splitSource.id, subscribable_type: @splitSource.class.name), method: :post %>

							<button name="button" type="button" class="close-subscribe-notice" data-close="" aria-label="Dismiss Notice"><span aria-hidden="true">×</span></button>
						</div>
					<% end %>
					<div class="show-content">
						<div class="detail-header-info">
							<%= render 'meta_data', content: @splitSource %>
						</div>

						<%= render_content_partial 'details', content: @splitSource, schema: @splitSchema, options: {force_render: true} %>

					</div>
				</div>
		<% end %>
	<% end %>

	<div class="row<%= ' split-content edit-content' unless @splitSource.nil? %>">
		<div class="column">
			<div class="detail-header editor">

				<div class="detail-header-info">
          <%= render 'meta_data', content: content %>
				</div>

				<a class="bookmark" href="#">
					<span class="bookmarkinfo">zur Recherche hinzufügen</span>
					<i class="fa fa-bookmark-o" aria-hidden="true"></i>
				</a>

				<div id="validation_errors">

				</div>

				<% if !content.schema.nil? %>

					<% validation_properties = get_ordered_validation_properties(content.schema) %>

					<%= render 'data_cycle_core/contents/editors/metadata/releasable_editor',
							   value: {'release_id' => content.release_id, 'release_comment' => content.release_comment},
							   key: 'creative_work',
							   definition: {'type' => 'releasable'},
							   options:{} if content.schema.dig('releasable') == true %>

					<% if !validation_properties.nil? %>

						<% validation_properties.each do |key, prop| %>

							<% value = prop.dig('type') == "object" || prop.dig('type') == "classificationTreeLabel" ? content.try(key.to_sym) : dataSchema[key] %>

              <%== '<span class="translated"><i class="fa fa-language" aria-hidden="true"></i></span>' if (content.translated_attributes.keys&.include?(key) || content.translated_attributes['content']&.keys&.include?(key)) && (DataCycleCore.translatable_types & [content.class.name, content.template_name]).present? && I18n.available_locales&.size&.>(1) %>

							<%= render_attribute_editor key: "#{keyPrefix}[#{key}]", definition: prop, value: value, parameters: { options: (prop.dig('editor', 'options') || {}) } unless dataSchema.nil? %>

						<% end %>

					<% end %>

				<% end %>

			</div>
		</div>
	</div>

	<% unless @splitSource.nil? %>
		</div>
	<% end %>

<% end %>

<%= content_for :forms %>
