<%= render_content_partial 'edit_header_functions', content: content %>

<%= form_with url: local_assigns[:form_url] || thing_path(content, watch_list_id: watch_list), local: true, method: :patch, class: 'validation-form edit-content-form' do |f| %>
  <%= hidden_field_tag :uuid, content.id %>
  <%= hidden_field_tag :table, content.class.table_name %>
  <%= hidden_field_tag "#{content.class.name.demodulize.underscore}[datahash][creator][]", content.created_by %>
  <%= hidden_field_tag :locale, @locale %>
  <%= content_for :additional_form_fields %>

  <div class="<%= 'flex-box' if split_source %>">
    <% if split_source %>
      <% I18n.with_locale(split_source.first_available_locale(@split_source_params&.dig(:source_locale))) do %>
        <div class="row split-content detail-content">
          <%= hidden_field_tag 'splitview', true %>

          <%= render 'split_source_subscribe_notice', content: content, split_source: split_source if local_assigns[:subscribe_notice] && can?(:subscribe, split_source) && split_source.subscriptions.by_user(current_user).size.zero? && cookies[:subscribe_notice_dismissed].blank? %>

          <div class="show-content">
            <div class="detail-header-info">
              <%= render 'meta_data', content: split_source %>
              <ul class="split-locales no-bullet">
                <%= render 'edit_locale_links', locales: available_locales_with_names.except(:all), prefix: "source-#{split_source.id}-", content: content, locale: @locale %>
              </ul>
              <%= link_to tag.i(class: 'fa fa-times', aira_hidden: true), edit_thing_path(content, watch_list_id: @watch_list, locale: @locale), title: t('actions.close_source', locale: DataCycleCore.ui_language), data: { tooltip: true }, class: 'close-source-link' %>
            </div>

            <%= render_content_partial 'details', content: split_source, options: { force_render: true } %>
          </div>
        </div>
      <% end %>
    <% end %>

    <div class="row <%= 'split-content edit-content' if split_source %>">
      <div class="column">
        <div class="detail-header editor">
          <div class="detail-header-info">
            <%= render 'meta_data', content: content %>
          </div>

          <%= render 'data_cycle_core/contents/editors/metadata/finalize', content: content if DataCycleCore::Feature::Releasable.allowed?(content) && current_user.is_rank?(0) && content.indirect_data_links.by_receiver(current_user).valid.exists? %>

          <% ordered_validation_properties(validation: content.schema).presence&.each do |key, prop| %>
              <%= render_attribute_editor key: "#{key_prefix}[#{key}]", definition: prop, value: content.try(key.to_sym), parameters: { options: {} }, content: content %>
          <% end %>

        </div>
      </div>
    </div>
  </div>
<% end %>

<%= content_for :forms %>
