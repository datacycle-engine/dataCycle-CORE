<% unless translation.nil? %>

    <% unless translation.content.nil? %>

        <% translation.content.each do | translated_key, translated_content | %>

            <% unless translated_content.nil? %>
                <%= render_attribute_viewer key: translated_key,
                                            definition: dataCycleObject.metadata['validation']['properties'][translated_key],
                                            value: normalize_value(translated_content),
                                            parameters: { options: {} } %>
            <% end %>

        <% end %>

    <% end %>

    <% unless translation.properties.nil? %>

        <% translation.properties.each do | translated_key, translated_property | %>

            <% unless translated_content.nil? %>
                <%= render_attribute_viewer key: translated_key,
                                            definition: dataCycleObject.metadata['validation']['properties'][translated_key],
                                            value: normalize_value(translated_property),
                                            parameters: { options: {} } %>
            <% end %>

        <% end %>

    <% end %>

<% end %>
