<% unless translation.nil? %>

    <% unless translation.content.nil? %>

        <% translation.content.each do | translated_key, translated_content | %>

            <% unless translated_content.nil? %>
                <%= render_attribute_viewer key: translated_key,
                                            definition: dataCycleObject.schema['properties'][translated_key],
                                            value: translated_content,
                                            parameters: { options: {} },
                                            content: dataCycleObject %>
            <% end %>

        <% end %>

    <% end %>

<% end %>
