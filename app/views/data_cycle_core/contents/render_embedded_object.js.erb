<% content_for :rendered_items do %>
  <% @objects.presence&.each_with_index do |object, index| %>
    <%= render_embedded_object_partial(key: params[:key], definition: params[:definition], parameters: {index: params[:index].presence&.to_i + index, options: params[:options], object: object, new_content: true, language: params[:language]}, content: object) %>
  <% end %>
<% end %>

$('#<%= sanitize_to_id(params[:key]) %> > .buttons > .addContentObject .fa').css('display', 'none');
$('#<%= sanitize_to_id(params[:key]) %> > .buttons > button').prop('disabled', false);
$('#<%= sanitize_to_id(params[:key]) %> > .buttons').before('<%= j yield :rendered_items %>');
$('<%= j content_for :forms %>').appendTo('body').foundation();

$('<%= (params[:index].presence&.to_i..(params[:index].presence&.to_i + @objects.size)).map { |i| "##{sanitize_to_id(params[:key])}_item_#{i}" }.join(', ') %>').foundation().trigger('clone-added');
