var load_more_button = $('#load_more_<%= @content.id %>_<%= sanitize_to_id(@params[:complete_key]) %>').parent('.clear-both');
<% if @params.dig(:definition, :type) == 'linked' %>
  <% content_for :rendered_items do %>
    <% I18n.with_locale(@params[:locale] || I18n.locale) do %>
      <% @linked_objects.each do |content| %>
        <%= render_linked_partial(key: "#{@params[:complete_key]}[]", definition: @params[:definition], parameters: { object: content, options: @params[:options], objects: @params[:objects], object_id: [content.id], tile_links: true, parent: @object }, content: @content) %>
      <% end %>
    <% end %>
    <span class="clear-both">
      <%= link_to t('common.load_more', locale: DataCycleCore.ui_language), load_more_linked_objects_thing_path(
        @object,
        key: @params[:key],
        complete_key: @params[:complete_key],
        definition: @params[:definition],
        options: @params[:options],
        page: @params.fetch(:page, 1).to_i + 1,
        load_more_action: :show,
        locale: (@params[:locale] || I18n.locale),
        content_id: @content.id,
        content_type: @content.class.table_name
      ),
      remote: true,
      id: "load_more_#{@object&.id}_#{sanitize_to_id(@params[:complete_key])}",
      class: 'load-more-linked-contents button small secondary',
      data: {
        disable_with: "<i class='fa fa-spinner fa-spin'></i> #{t('common.loading', locale: DataCycleCore.ui_language)}"
      } if @linked_objects.try(:total_pages)&.positive? && !@linked_objects&.last_page? %>
    </span>
  <% end %>
  $('<%= j yield :rendered_items %>').replaceAll(load_more_button).trigger('dc:contents:added', { editor: 'object_browser', single: true }).foundation();
<% else %>
  <% I18n.with_locale(@params[:locale] || I18n.locale) do %>
    $('<%= j render_attribute_viewer key: @params[:complete_key], definition: @params[:definition], value: @linked_objects, parameters: { options: (@params[:options].presence || {}), page: params.fetch(:page, 1).to_i, parent: @object, no_wrapper: true, }, content: @content %>').replaceAll(load_more_button).trigger('dc:contents:added', { editor: 'embedded_object', single: false }).foundation();
  <% end %>
<% end %>
