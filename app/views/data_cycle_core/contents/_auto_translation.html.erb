<li class="has-dropdown">
  <a id="auto_translation-link" data-toggle="auto_translation">
    <i class="fa fa-cloud-download" aria-hidden="true"></i>
  </a>
  <div class="dropdown-pane align-right no-bullet bottom" id="auto_translation" data-dropdown data-hover="true" data-hover-pane="true">
    <h5>
      <%= t('actions.auto_translate', data: t('common.contents', count: 1, locale: active_ui_locale).capitalize, locale: active_ui_locale) %>
    </h5>
    <%= link_to t('actions.translate', locale: active_ui_locale).capitalize, auto_translations_thing_path(id: content.id), remote: true, method: :post, class: 'button', data: { disable_with: '<i class="fa fa-circle-o-notch fa-spin fa-fw"></i> ' + t('actions.translate', locale: active_ui_locale).capitalize } %>
    <%= link_to t('actions.translate_create', locale: active_ui_locale).capitalize, create_auto_translations_thing_path(id: content.id), remote: true, method: :post, class: 'button', data: { disable_with: '<i class="fa fa-circle-o-notch fa-spin fa-fw"></i> ' + t('actions.translate_create', locale: active_ui_locale).capitalize } %>
  </div>
</li>
