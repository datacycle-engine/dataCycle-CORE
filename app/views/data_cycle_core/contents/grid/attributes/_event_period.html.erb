<div class="event-period">

  <% event_period_value = '' %>
  <% event_period_full_value = '' %>

  <% unless item.try(:start_date).nil? %>
    <% event_period_value = l(item.start_date.to_date, locale: DataCycleCore.ui_language) %>

    <% if item.start_date.to_s(:time) == '00:00' %>
      <% event_period_full_value = l(item.start_date.to_date, format: :full, locale: DataCycleCore.ui_language) %>
    <% else %>
      <% event_period_full_value = l(item.start_date.to_datetime, locale: DataCycleCore.ui_language) %>
    <% end %>
  <% end %>

  <% unless item.try(:end_date).nil? %>
    <% event_period_value += " - #{l(item.end_date.to_date, locale: DataCycleCore.ui_language)}" %>

    <% if item.end_date.to_s(:time) == '00:00' %>
      <% event_period_full_value += " #{t('terms.until', locale: DataCycleCore.ui_language)} #{l(item.end_date.to_date, format: :full, locale: DataCycleCore.ui_language)}" %>
    <% else %>
      <% event_period_full_value += " #{t('terms.until', locale: DataCycleCore.ui_language)} #{l(item.end_date.to_datetime, locale: DataCycleCore.ui_language)}" %>
    <% end %>
  <% end %>

  <span data-allow-html="true"
        aria-haspopup="true"
        class="date event-period dc-foundation-tooltip"
        title="<%= event_period_full_value.present? ? event_period_full_value : event_period_value %>">
    <%= event_period_value %>
  </span>
</div>
