<% if !item.event_period.try(:start_date).nil? || !item.event_period.try(:end_date).nil? %>

    <div class="event-period">

        <% event_period_value = '' %>
        <% event_period_full_value = '' %>

        <% unless item.event_period.try(:start_date).nil? %>
            <% event_period_value = l(item.event_period.start_date.to_date, locale: DataCycleCore.ui_language) %>

            <% if item.event_period.start_date.to_s(:time) == '00:00' %>
                <% event_period_full_value = l(item.event_period.start_date.to_date, format: :full, locale: DataCycleCore.ui_language) %>
            <% else %>
                <% event_period_full_value = l(item.event_period.start_date.to_datetime, locale: DataCycleCore.ui_language) %>
            <% end %>
        <% end %>

        <% unless item.event_period.try(:end_date).nil? %>
            <% event_period_value += " - #{l(item.event_period.end_date.to_date, locale: DataCycleCore.ui_language)}" %>

            <% if item.event_period.end_date.to_s(:time) == '00:00' %>
                <% event_period_full_value += " #{t('terms.until', locale: DataCycleCore.ui_language)} #{l(item.event_period.end_date.to_date, format: :full, locale: DataCycleCore.ui_language)}" %>
            <% else %>
                <% event_period_full_value += " #{t('terms.until', locale: DataCycleCore.ui_language)} #{l(item.event_period.end_date.to_datetime, locale: DataCycleCore.ui_language)}" %>
            <% end %>
        <% end %>

        <span class="date"
              data-tooltip data-allow-html="true" data-tooltip-class="tooltip"
              aria-haspopup="true" class="event-period"
              title="<%= event_period_full_value.present? ? event_period_full_value : event_period_value %>">
            <%= event_period_value %>
        </span>
    </div>

<% end %>
