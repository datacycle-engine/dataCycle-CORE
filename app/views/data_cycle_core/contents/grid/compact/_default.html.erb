<%= render 'data_cycle_core/contents/grid/compact/tile_wrapper', local_assigns.merge(tile_classes: 'media') do %>
  <% render_locale = I18n.locale %>
  <% I18n.with_locale(object.first_available_locale) do %>
    <div class="tile-top">
      <% if local_assigns[:edit_buttons] && can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
        <span class="draggable-handle"><i class="fa fa-bars" aria-hidden="true"></i></span>
        <span class="delete-thumbnail"><i aria-hidden="true" class="fa fa-times"></i></span>
      <% end %>
      <%= yield_content!(:tile_links) %>
      <%= render 'data_cycle_core/contents/grid/attributes/warnings', content: object, locale: render_locale %>
      <%= render 'data_cycle_core/shared/icon', icon_type: object.template_name.parameterize(separator: '_') %>

      <%= tag.span "#{object.title} (#{I18n.locale.to_s})", class: 'name' if object.try(:title).present? %>
      <% if object.respond_to?(:internal_name) && object.internal_name.present? %>
        <span class="title working-title" title="<%= object.internal_name %>">
          (<%= sanitize(strip_links(truncate(object.internal_name, length: 70, separator: " ", escape: false))) %>)
        </span>
      <% end %>

    </div>

    <div class="tile-properties">
      <%= yield_content!(:additional_tile_attributes) %>
    </div>

    <% if object.try(:external_source).present? %>
      <div class="external-sources-tiles">
        <span class="external-source-icon fa-stack default-view has-tip" title="<%= object.external_source.name %>">
          <i class="fa fa-file-o fa-stack-2x" aria_hidden="true"></i>
          <i class="fa fa-long-arrow-right fa-stack-1x" aria_hidden="true"></i>
        </span>
        <span class="external-source-title">
          <%= object.external_source.name %>
        </span>
      </div>
    <% end %>
  <% end %>
<% end %>
