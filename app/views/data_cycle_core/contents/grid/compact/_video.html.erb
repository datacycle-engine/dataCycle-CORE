<%= render 'data_cycle_core/contents/grid/compact/tile_wrapper', local_assigns.except(:tile_links).merge(tile_classes: 'image') do %>
  <%
      thumbnail_url = object.try(:thumbnail_url) || object.try(:asset).try(:first).try(:thumbnail_url)
  %>
  <% render_locale = I18n.locale %>
  <% I18n.with_locale(object.first_available_locale) do %>
    <div class="thumbnail media item <%= local_assigns[:class] %>" style="<%= "background-image: url(#{thumbnail_url})" if thumbnail_url.present? %>" data-open="media-reveal<%= local_assigns.dig(:options, :prefix) %>-<%= object.id %>">
      <div class="show-for-print">
        <img src="<%= thumbnail_url %>" />
      </div>
      <% if thumbnail_url.blank? %>
        <div class="fallback-title">
          <%= object.title %> (<%= I18n.locale.to_s %>)
        </div>
      <% end %>
      <% if object.title.present? %>
        <div class="description">
          <%= object.title %> (<%= I18n.locale.to_s %>)
          <div class="show-for-print">
            <br />
            (ID: <%= object.id %>)
          </div>
        </div>
      <% end %>
      <% if local_assigns[:edit_buttons] && can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
        <span class="draggable-handle"><i class="fa fa-bars" aria-hidden="true"></i></span>
        <span class="delete-thumbnail"><i aria-hidden="true" class="fa fa-times"></i></span>
      <% end %>
      <%= render 'data_cycle_core/contents/grid/attributes/warnings', content: object, locale: render_locale %>
      <% if object.try(:external_source).present? %>
        <span class="external-source-icon fa-stack has-tip" title="<%= object.external_source.name %>">
          <i class="fa fa-file-o fa-stack-2x" aria_hidden="true"></i>
          <i class="fa fa-long-arrow-right fa-stack-1x" aria_hidden="true"></i>
          <span class="external-source-title">
            <%= object.external_source.name %>
          </span>
        </span>
      <% end %>
    </div>

    <div class="width-content reveal media-preview" id="media-reveal<%= local_assigns.dig(:options, :prefix) %>-<%= object.id %>" data-reveal>
      <button class="close-button" data-close aria-label="Close modal" type="button">
        <span aria-hidden="true">&times;</span>
      </button>
      <%= tag.span "#{object.title} (#{I18n.locale.to_s})", class: 'preview-title' if object.try(:title).present? %>
      <div class="video">
        <video class="lazyload" data-poster="<%= thumbnail_url %>" controls="controls" controlsList="nodownload" preload="none">
          <source src="<%= object.try(:content_url) %>" type="video/mp4">
          Your browser does not support the video tag
        </video>
      </div>
      <div class="description">
        <%= render 'data_cycle_core/contents/validity_period', dataCycleObject: object %>
        <%= render 'data_cycle_core/contents/grid/attributes/warnings', content: object, text: true, locale: render_locale %>
        <%= link_to t('tile_links.details', locale: DataCycleCore.ui_language), thing_path(object), target: :_blank %>
        <% if can?(:download, object) && object.try(:content_url).present? %>
          | <%= link_to t('tile_links.full_size', locale: DataCycleCore.ui_language), object.try(:content_url), target: :_blank %>
        <% end %>
        <% if DataCycleCore.features.dig(:external_media_archive, :enabled) %>
          <% if object.try(:url).present? %>
            | <%= link_to t('tile_links.media_archive', locale: DataCycleCore.ui_language), object.url, target: :_blank %>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
