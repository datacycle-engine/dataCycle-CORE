<% content_for :additional_tile_attributes, flush: true do %>
  <div class="tile-property address-line">
    <%= sanitize(object.address_block, tags: ['br']) %>
  </div>

  <%= tag.span(data: { location_for: local_assigns[:key], location_data: { lng: object.location&.x, lat: object.location&.y }.to_json }) if object.try(:location).present? %>
<% end %>

<%= render 'data_cycle_core/contents/grid/compact/default', local_assigns %>
