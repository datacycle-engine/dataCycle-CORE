<% I18n.with_locale(@language) do %>

  <div class="inner content-link">

    <div class="infoRow">
      <%= render 'data_cycle_core/shared/icon', icon_class: item.class.name.demodulize.underscore_blanks %>
      <span class="title"><%= DataCycleCore::UserGroup.model_name.human(locale: DataCycleCore.ui_language) %> (<%= item.users.size %>)</span>
    </div>

    <div class="title">
      <%= item.name %>
    </div>

  </div>

<% end %>

<% content_for :media_buttons do %>
  <% if can? :edit, item %>
    <%= link_to tag.i(class: 'fa fa-pencil', aria_hidden: true), edit_user_group_path(item, watch_list_id: @watch_list), class: 'edit-link dc-foundation-tooltip', title: t('actions.edit', locale: DataCycleCore.ui_language) %>
  <% end %>

  <% if can? :destroy, item %>
    <%= link_to tag.i(class: 'fa fa-trash-o', aria_hidden: true),
      item,
      method: :delete,
      class:'alert delete-link dc-foundation-tooltip',
      title: t('actions.delete', locale: DataCycleCore.ui_language),
      data: {
        confirm: "#{item.model_name.human(locale: DataCycleCore.ui_language)} #{t('actions.delete', locale: DataCycleCore.ui_language)}?"
      } %>
  <% end %>
<% end %>
