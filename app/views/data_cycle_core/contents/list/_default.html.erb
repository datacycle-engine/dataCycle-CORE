<% I18n.with_locale(item.first_available_locale(@language)) do %>

  <div class="inner-item">
    <div class="content-row">
      <%= link_to thing_path(item, watch_list_id: @watch_list&.id, locale: I18n.locale) do %>
        <span class="type <%= item.template_name.downcase %>">
          <%= render 'data_cycle_core/shared/icon', icon_type: item.template_name.parameterize(separator: '_') %>
          <span><%= t("content_type.#{item.template_name.underscore_blanks}", default: item.template_name, locale: DataCycleCore.ui_language) %></span>
          <span class="locale">(<%= I18n.locale.to_s %>)</span>
        </span>
        <span class="title" title="<%= item.title %>"><%= item.title %></span>
      <% end %>
    </div>

    <a class="toggle-details toggler" data-toggle="content-details-<%= item.id %>"></a>

    <% if content_for?(:media_buttons) %>
      <div class="buttons">
        <%= yield_content!(:media_buttons) %>
      </div>
    <% end %>
  </div>

  <div class="content-details remote-render"
    id="content-details-<%= item.id %>"
    data-remote-render-function="render_content_tile_details"
    data-remote-render-params="<%= to_query_params(item: item, mode: 'list').to_json %>"
    data-remote-options="<%= to_query_params(locale: I18n.locale.to_s, language: @language).to_json %>">
  </div>

<% end %>
