<% if @template.present? %>
  $('.new-content-reveal:visible .new-content-form').html('<%= j render_new_form(template: @template, parameters: { content: @content }) %>').trigger('form-rendered');
<% else %>
  $('.new-content-reveal:visible .new-content-form').html('<%= j render 'data_cycle_core/contents/new/new_stage', query_methods: @query_methods, content: @content %>').trigger('form-rendered');
<% end %>

$('.new-content-reveal:visible .new_content_form_title').html('<%= yield :new_content_form_title %>');
$('.new-content-reveal:visible .form_crumbs').html('<%= j yield :form_crumbs %>');
