<section class="duplicate-candidates">
    <span class="horizontal-separator-header">
      <h4 class="header-text"><%= t('duplicate.candidates', locale: DataCycleCore.ui_language) %> (<%= content.duplicate_candidates.size %>)</h4>
    </span>
    <ul class="content-tiles">
        <% content.duplicate_candidates.presence&.each do |item| %>
          <% content_for :tile_buttons, flush: true do %>
            <div class="duplicate-buttons">
              <div class="duplicate-score"><%= t('duplicate.score', locale: DataCycleCore.ui_language) %>: <b><%= item.score.to_i %></b></div>
              <%= link_to t('duplicate.merge', locale: DataCycleCore.ui_language).titleize, merge_with_duplicate_thing_path(id: content.id, duplicate_id: item.duplicate.id), class: 'button' %>
              <%= link_to t('duplicate.mark_false_positive', locale: DataCycleCore.ui_language), '#', class: 'button secondary' %>
            </div>
          <% end %>
          <%= render_linked_partial key: "duplicate_candidate_#{item.duplicate.id}", definition: { template_name: item.duplicate.template_name }.with_indifferent_access, content: content, parameters: { options: {}, object: item.duplicate, object_id: [item.duplicate.id], prefix: local_assigns.dig(:options, :prefix), tile_links: true } %>
        <% end %>
    </ul>
</section>
