<div class="metadata">
  <span class="type <%= content.template_name.underscore_blanks %>">
    <%= render 'data_cycle_core/shared/icon', icon_type: content.template_name.underscore_blanks, icon_class: content.class.name.demodulize.underscore %>
    <%= t("content_type.#{content.template_name.underscore_blanks}", default: content.template_name.titleize, locale: active_ui_locale) %> (<%= I18n.locale %>)
  </span>

  <span class="created-at">
    <%= t('history.created_at', locale: active_ui_locale) %>
    <strong><%= l(content.created_at&.in_time_zone, locale: active_ui_locale) %></strong>
    <% if content.created_by.present? %>
      <% creator = content.created_by_user %>
      <%= t('terms.from', locale: active_ui_locale) %> <strong><a href="mailto:<%= "#{creator.email}" %>"><%= "#{creator.full_name}" %></a></strong>
    <% end %>
  </span>
</div>
