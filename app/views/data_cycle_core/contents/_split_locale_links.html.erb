<li class="has-dropdown">
  <a data-toggle="<%= local_assigns[:prefix] %>locales-menu"><i class="fa fa-language" aria-hidden="true"></i></a>
  <div class="dropdown-pane align-right no-bullet bottom" id="<%= local_assigns[:prefix] %>locales-menu" data-dropdown data-hover="true" data-hover-pane="true">
    <h5><%= t('common.choose_language', locale: DataCycleCore.ui_language) %></h5>
    <ul class="list-items">
      <% locales.each do |l| %>
        <li class="<%= "active" if l.first == I18n.locale %>">
          <%= link_to_if l.first != I18n.locale && @split_source.translated_locales.include?(l.first),
            l.last,
            polymorphic_path([local_assigns[:link_action], content],
              watch_list_id: @watch_list,
              locale: local_assigns[:locale],
              source_id: @split_source&.id,
              source_locale: l.first
            ),
            data: {
              locale: l.first
            } %>

          <%= tag.span(tag.i(class: 'fa fa-language', aria_hidden: true), class: 'buttons') if @split_source.translated_locales.include?(l.first) %>
        </li>
      <% end %>
    </ul>
  </div>
</li>
