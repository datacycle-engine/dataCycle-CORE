<% unless content.schema.nil? %>

    <%# validation_properties = ordered_validation_properties(validation: content.schema) %>

    <%# if !validation_properties.nil? %>

        <!-- todo: [patrick]: make this more generic ? -->
        <%# exludedProperties = @splitSource.nil? && @historySource.nil? ? ['headline','validity_period'] : []  %>

        <div class="type properties">

            <% ordered_validation_properties(validation: content.schema).each do |key, prop| %>

                <% value = content.try(key.to_sym) %>
                <% value = value.presence&.page&.per(DataCycleCore.linked_objects_page_size) if value.is_a?(ActiveRecord::Relation) %>

                <% unless prop.dig('ui','show','content_area') == 'header' %>
                    <%= render_attribute_viewer key: key, definition: prop, value: value, parameters: { options: options }, content: content %>
                <% end %>

            <% end %>

        </div>

    <%# end %>

<% end %>
