<% unless content.schema.nil? %>

    <div class="type properties">

        <% ordered_validation_properties(validation: content.schema, content_area: options.presence&.dig(:force_render).try(:to_s) == 'true' ? '' : 'content').each do |key, prop| %>

            <% value = content.try(key.to_sym) %>
            <% value = value.presence&.page&.per(DataCycleCore.linked_objects_page_size) if value.is_a?(ActiveRecord::Relation) %>

            <%= render_attribute_viewer key: key, definition: prop, value: value, parameters: { options: options }, content: content %>

        <% end %>

    </div>

<% end %>