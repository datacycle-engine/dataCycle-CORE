
<% DataCycleCore::Feature::Serialize.available_serializers(content).each_key do |serializer_key| %>

    <%= link_to download_thing_path(content, serializer_key), class:'button-prime small download-content-link', data: { tooltip: true }, title: t('actions.download_asset', locale: DataCycleCore.ui_language).capitalize, 'aria-haspopup': true do %>
        <i class="fa fa-download" aria-hidden="true"></i>
    <% end if can? :download, content %>

<% end %>
