<a data-toggle="download_<%= content.id %>" class="button-prime small download-content-link" title="<%= t('actions.download_asset', locale: DataCycleCore.ui_language).capitalize %>" data-tooltip>
    <i class="fa fa-download" aria-hidden="true"></i>
</a>

<div class="reveal download-content-reveal"
     id="download_<%= content.id %>"
     data-reveal>
    <h3 class="new_content_form_title"><%= t('common.download_content', locale: DataCycleCore.ui_language) %></h3>

    <% DataCycleCore::Feature::Serialize.available_serializers(content).each_key do |serializer_key| %>

        <%= link_to download_thing_path(content, serializer_key), class:'small download-content-link', title: t('actions.download_asset', locale: DataCycleCore.ui_language).capitalize do %>
            <i class="fa fa-download" aria-hidden="true"></i>
            <span><%= serializer_key.camelize %></span>
        <% end if can? :download, content %>

    <% end %>

    <button class="close-button" data-close aria-label="Close modal" type="button">
        <span aria-hidden="true">&times;</span>
    </button>
</div>