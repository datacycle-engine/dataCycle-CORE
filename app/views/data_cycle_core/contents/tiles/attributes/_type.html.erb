<% if item.schema.present? && item.template_name.present? %>

    <div class="type <%= item.template_name.downcase %> <%= "has-parent" if item.try(:parent).present? %>">
        <div class="infoRow">
            <% if DataCycleCore.features&.dig(:life_cycle, :attribute_key).present? && item.is_content_type?('container') %>
              <%= render 'data_cycle_core/shared/icon', icon_type: item.try(DataCycleCore.features&.dig(:life_cycle, :attribute_key))&.first&.name&.parameterize(separator: '_') %>
            <% else %>
              <%= render 'data_cycle_core/shared/icon', icon_type: item.template_name.parameterize(separator: '_') %>
            <% end %>
            <span class="title"><%= t("content_type.#{item.template_name.downcase}", default: item.template_name, locale: DataCycleCore.ui_language) %></span>
            <span class="locale">(<%= I18n.locale.to_s %>)</span>
        </div>
    </div>

<% else %>

    <div class="type">
        <div class="infoRow">
            <span class="icon">
                <i class="fa fa-folder-open-o" aria-hidden="true"></i>
            </span>
            <span class="title">Undefined Content</span>
        </div>
    </div>

<% end %>
