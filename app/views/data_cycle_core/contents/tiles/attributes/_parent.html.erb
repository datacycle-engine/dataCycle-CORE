<div class="type <%= item.template_name.downcase %>">
    <div class="infoRow parent">
        <% if DataCycleCore::Feature::LifeCycle.allowed?(item) && DataCycleCore::Feature::LifeCycle.allowed_attribute_keys(item).present? && item.content_type?('container') %>
          <%= render 'data_cycle_core/shared/icon', icon_type: item.try(DataCycleCore::Feature::LifeCycle.allowed_attribute_keys(item).first)&.first&.name&.parameterize(separator: '_') %>
        <% else %>
          <%= render 'data_cycle_core/shared/icon', icon_type: item.template_name.parameterize(separator: '_') %>
        <% end %>
        <% I18n.with_locale(item.first_available_locale(@language)) do %>
          <span class="title" title="<%= item.title %>"><%= item.title %></span>
        <% end %>
    </div>
</div>
