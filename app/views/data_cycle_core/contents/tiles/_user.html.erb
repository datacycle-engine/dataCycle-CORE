<% I18n.with_locale(@language) do %>

    <div class="inner content-link">

        <div class="infoRow">
          <%= render 'data_cycle_core/shared/icon', icon_type: item.class.name.demodulize.underscore %>
          <%== "<del>" if item.access_locked? %>
            <span class="title"><%= item.model_name.human(locale: DataCycleCore.ui_language) %> <%= "("+item.class.human_attribute_name('external', locale: DataCycleCore.ui_language)+")" if item.external %></span>
          <%== "</del>" if item.access_locked? %>
        </div>

        <div class="title">
          <%= item.full_name %>
        </div>

        <div class="description" title="<%= item.email %>">
          <%= item.email %>
        </div>

        <% if can? :generate_access_token, item %>
          <div class="token">
            <% if item.access_token.present? %>
              <%= content_tag :span, class: 'copy-to-clipboard with-shadow', data: { value: item.access_token } do %>
                <i class="fa fa-key" aria-hidden="true"></i>
                <%= item.access_token %>
              <% end %>
            <% end %>
          </div>
        <% end %>

        <div class="tags">
          <% if item.role %>
            <span class="tag"><%= t('roles.'+item.role.name, locale: DataCycleCore.ui_language) %></span>
          <% end %>
          <% item.user_groups.each do |user_group| %>
            <span class="tag"><%= user_group.name %></span>
          <% end %>
        </div>

    </div>

<% end %>

<% content_for :media_buttons do %>
  <% if can? :become, item %>
    <%= link_to user_become_path(item), class: 'button-prime small become-link', title: t('actions.become', data: item.email, locale: DataCycleCore.ui_language), data: { tooltip: true, click_open: false } do %>
      <i class="fa fa-sign-in" aria-hidden="true"></i>
    <% end %>
  <% end %>

  <% if can? :edit, item %>
    <%= link_to edit_user_path(item, watch_list_id: @watch_list), class: 'button-prime small edit-link', title: t('actions.edit', locale: DataCycleCore.ui_language), data: { tooltip: true, click_open: false }, 'aria-haspopup': "true" do %>
      <i class="fa fa-pencil" aria-hidden="true"></i>
    <% end %>
  <% end %>

  <% if can?(:destroy, item) && !item.access_locked? %>
    <%= link_to item, method: :delete, class:'button-prime small alert lock-link', title: t('actions.lock', locale: DataCycleCore.ui_language), data: { confirm: "#{item.model_name.human(locale: DataCycleCore.ui_language)} #{t('actions.lock', locale: DataCycleCore.ui_language)}?", tooltip: true } do %>
        <i class="fa fa-lock" aria-hidden="true"></i>
    <% end %>
  <% elsif can?(:destroy, item) %>
    <%= link_to unlock_user_path(item), method: :post, class:'button-prime small alert unlock-link', title: t('actions.unlock', locale: DataCycleCore.ui_language), data: { tooltip: true } do %>
        <i class="fa fa-unlock" aria-hidden="true"></i>
    <% end %>
  <% end %>

  <% if can?(:show_representation_of, DataCycleCore::User) && item.represented_by.present? %>
    <a class="hascontent represented-by-link" data-toggle="represented-by-<%= item.id %>">
      <i class="fa fa-link" aria-hidden="true"></i>
    </a>
    <div class="dropdown-pane no-bullet bottom align-right"
      id="represented-by-<%= item.id %>"
      data-dropdown
      data-hover="true"
      data-hover-pane="true">
      <ul class="list-items">
        <% item.represented_by.each do |thing| %>
          <li><%= link_to I18n.with_locale(thing.first_available_locale) { thing.title }, thing_path(thing.id), target: :_blank %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
<% end %>
