<% I18n.with_locale(@language) do %>

    <%= link_to polymorphic_path(item, watch_list_id: @watch_list), class: 'content-link' do %>

        <div class="inner">

            <%= render 'data_cycle_core/contents/tiles/attributes/type', item: item %>
            <%= render 'data_cycle_core/contents/tiles/attributes/title', item: item %>
            <%= render 'data_cycle_core/contents/tiles/attributes/description', item: item %>

            <% unless item.metadata.nil? %>

                <% unless item.metadata['thumbnail_url'].nil? %>

                    <div class="image-thumbnail">
                        <img data-src="<%= item.metadata['thumbnail_url'] %>" alt="<%= item.content['name'] unless item.content.blank?%>" class="lazyload" />
                    </div>

                <% end %>

            <% end %>

            <% unless item.display_classification_aliases.nil? %>

                <div class="tags">
                    <% item.display_classification_aliases.each do |classificationAlias| %>
                        <span class="tag"><%= classificationAlias.name %></span>
                    <% end %>
                </div>

            <% end %>

        </div>

    <% end %>

<% end %>
