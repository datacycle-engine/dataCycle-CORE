<%= render 'data_cycle_core/contents/tiles/compact/tile_wrapper', local_assigns.except(:tile_links).merge(tile_classes: 'image') do %>
  <%
      thumbnail_url = object.try(:asset)&.first&.thumbnail_url
  %>
  <% render_locale = I18n.locale %>
  <% I18n.with_locale(object.first_available_locale) do %>
    <div class="thumbnail media item <%= local_assigns[:class] %>" style="<%= "background-image: url(#{thumbnail_url})" if thumbnail_url.present? %>" data-open="media-reveal<%= local_assigns.dig(:options, :prefix) %>-<%= object.id %>">
        <div class="show-for-print">
            <img src="<%= thumbnail_url %>" />
        </div>
        <% if object.title.present? %>
            <div class="description">
                <%= object.title %> (<%= I18n.locale.to_s %>)
                <div class="show-for-print">
                    <br />(ID: <%= object.id %>)
                </div>
            </div>
        <% end %>
        <% if local_assigns[:edit_buttons] && can?(:edit, DataCycleCore::DataAttribute.new(key, definition, options, content, :edit)) %>
            <span class="draggable-handle"><i class="fa fa-bars" aria-hidden="true"></i></span>
            <span class="delete-thumbnail"><i aria-hidden="true" class="fa fa-times"></i></span>
        <% end %>
        <%= render 'data_cycle_core/contents/tiles/attributes/warnings', content: object, locale: render_locale %>
    </div>

    <div class="width-content reveal media-preview" id="media-reveal<%= local_assigns.dig(:options, :prefix) %>-<%= object.id %>" data-reveal>
        <button class="close-button" data-close aria-label="Close modal" type="button">
            <span aria-hidden="true">&times;</span>
        </button>
        <%= tag.span "#{object.title} (#{I18n.locale.to_s})", class: 'preview-title' if object.try(:title).present? %>
        <div class="image">
            <img class="lazyload" data-src="<%= thumbnail_url %>" />
        </div>
        <div class="description">
            <%= render 'data_cycle_core/contents/validity_period', dataCycleObject: object %>
            <%= render 'data_cycle_core/contents/tiles/attributes/warnings', content: object, text: true, locale: render_locale %>
            <%= link_to t('tile_links.details', locale: DataCycleCore.ui_language), thing_path(object), target: :_blank %>
            <% if can?(:download, object) && object.try(:content_url).present? %>
                | <%= link_to t('tile_links.full_size', locale: DataCycleCore.ui_language), object.try(:content_url), target: :_blank %>
            <% end %>
        </div>
    </div>
  <% end %>
<% end %>
