<% I18n.with_locale(@language) do %>

    <%= link_to polymorphic_path(item, trail: (breadcrumb_trail unless request.path == root_path)) do %>

        <div class="inner">

            <% if !item.metadata.nil? && !item.metadata['validation'].nil? && !item.metadata['validation']['name'].nil? %>

                <div class="type <%= item.metadata['validation']['name'].downcase %>">
                    <div class="infoRow">
                        <%= render 'data_cycle_core/shared/icon', icon_type: item.metadata['validation']['name'].downcase %>
                        <% if item.metadata['validation']['name'].downcase == 'contentlocation' %>
                            <span class="title">Ort</span>
                        <% else %>
                            <span class="title"><%= item.metadata['validation']['name'] %></span>
                        <% end %>
                        <span class="locale">(<%= I18n.locale.to_s %>)</span>
                    </div>
                </div>

            <% end %>

            <div class="title">

                <% if !item.name.nil? %>
                    <%= item.name %>
                <% end %>

            </div>

            <%= render 'data_cycle_core/contents/tiles/attributes/address', item: item %>

            <% unless item.display_classification_aliases.nil? %>

                <div class="tags">
                    <% item.display_classification_aliases.each do |classificationAlias| %>
                        <span class="tag"><%= classificationAlias.name %></span>
                    <% end %>
                </div>

            <% end %>

        </div>

    <% end %>

<% end %>
