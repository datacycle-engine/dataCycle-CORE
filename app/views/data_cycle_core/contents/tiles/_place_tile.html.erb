<% I18n.with_locale(@language) do %>

    <%= link_to polymorphic_path(item, watch_list_id: @watch_list), class: 'content-link' do %>

        <div class="inner">

            <% if !item.metadata.nil? && !item.schema.nil? && !item.template_name.nil? %>

                <div class="type <%= item.template_name.downcase %>">
                    <div class="infoRow">
                        <%= render 'data_cycle_core/shared/icon', icon_type: item.template_name.downcase %>
                        <% if item.template_name.downcase == 'contentlocation' %>
                            <span class="title">Ort</span>
                        <% else %>
                            <span class="title"><%= item.template_name %></span>
                        <% end %>
                        <span class="locale">(<%= I18n.locale.to_s %>)</span>
                    </div>
                </div>

            <% end %>

            <div class="title">

                <% if !item.name.nil? %>
                    <%= item.name %>
                <% end %>

            </div>

            <%= render 'data_cycle_core/contents/tiles/attributes/address', item: item %>

            <% unless item.display_classification_aliases.nil? %>

                <div class="tags">
                    <% item.display_classification_aliases.each do |classificationAlias| %>
                        <span class="tag"><%= classificationAlias.name %></span>
                    <% end %>
                </div>

            <% end %>

            <%= render 'data_cycle_core/contents/tiles/attributes/images', item: item if item.respond_to?('image') && item.image.count > 0 %>

        </div>

    <% end %>

<% end %>
