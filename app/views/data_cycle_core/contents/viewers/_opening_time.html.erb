<%= render 'data_cycle_core/contents/viewers/attribute',
  key: key,
  definition: definition,
  value: value,
  options: options,
  content: content do %>

  <% objects = value.presence&.map(&:to_h)&.compact&.group_by { |s| [s[:dtstart]&.in_time_zone&.beginning_of_day, s.dig(:rrules, 0, :until)&.in_time_zone&.beginning_of_day] } %>

  <% objects.each do |validity_period, opening_times| %>
    <div class="opening-time-group">
      <span class="opening-time-validity-period">
        <%= opening_time_validity_period(validity_period) %>
      </span>

      <span class="opening-time-opening-hours">
        <%= opening_time_opening_hours(opening_times) %>
      </span>
    </div>
  <% end %>

<% end %>
