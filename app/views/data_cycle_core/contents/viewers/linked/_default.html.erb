<%= render 'data_cycle_core/contents/viewers/attribute', key: key, definition: definition, value: value, options: options.merge({'class' => 'embedded_link_array object_browser media'}), data_attributes: {id: (value.presence&.ids || [] ), editor: "object_browser" } do %>

    <ul class="content-tiles">
        <% objects = value.presence&.includes(:translations)&.page&.per(DataCycleCore.linked_objects_page_size) %>
        <% objects.presence&.each do |item| %>

            <li class="<%= [
                               'copy-single',
                               'content',
                               item.class.name.demodulize.underscore.sub('_', '-'),
                               item.template_name.underscore.sub('_', '-'),
                           ].join(' ') %>" data-id="<%= [item.id] %>">

                <%= render_first_existing_partial [
                                                      "data_cycle_core/contents/viewers/tiles/#{item.class.name.demodulize.underscore}_#{item.template_name.underscore}",
                                                      "data_cycle_core/contents/viewers/tiles/#{item.class.name.demodulize.underscore}",
                                                      'data_cycle_core/contents/viewers/tiles/default'
                                                  ], local_assigns.merge({content: item})
                %>
            </li>
        <% end %>

        <div class="clear-both">
            <%= link_to t('common.load_more', locale: DataCycleCore.ui_language), polymorphic_path([:load_more_linked_objects, content], key: key, definition: definition, options: options, page: params.fetch(:page, 1).to_i + 1, load_more_action: :show), remote: true, id: "load_more_#{content&.id}_#{sanitize_to_id(key)}", class: 'load-more-linked-contents button small secondary', data: { disable_with: "<i class='fa fa-spinner fa-spin'></i> #{t('common.loading', locale: DataCycleCore.ui_language)}" } if objects.try(:total_pages)&.positive? && !objects&.last_page? %>
        </div>

    </ul>

<% end %>
