<% objects = value.presence&.includes(primary_classification_alias: [:classification_alias_path, :classification_tree_label, :primary_classification])&.map(&:primary_classification_alias)&.select { |c| c.classification_tree_label.visible?('show') }&.compact || [] %>
<% if objects.present? %>
  <%= render 'data_cycle_core/contents/viewers/attribute',
    key: key,
    definition: definition,
    value: value,
    options: options,
    content: content,
    data_attributes: {
      id: (value&.presence&.ids || [] ),
      editor: "classification"
    } do %>
    <span class="detail-content tags">
      <% objects = objects.concat(new_relations(options.dig(:item_diff), 'classifications').includes(primary_classification_alias: [:classification_alias_path, :classification_tree_label, :primary_classification]).map(&:primary_classification_alias)&.compact) if changes_by_mode(options.dig(:item_diff), '+').present? %>

      <% objects.presence&.each do |a| %>
        <span class="tag has-tip <%= changes_class(options.dig(:item_diff), a.primary_classification.id) %> dc-foundation-tooltip" data-allow-html="true" title="<%= classification_tooltip(a) %>">
          <%= a.internal_name%>
        </span>
      <% end %>
    </span>
  <% end %>
<% end %>
