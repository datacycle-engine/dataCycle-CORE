<% image ||= value.first %>

<% unless image.nil? %>
    <div class="inner">
        <span class="asset-title"><%= image.file.file.filename %></span>
        <span class="asset-type"><%=  image.content_type %> (<%= image.file_size %> B)</span>
        <div class="thumb">
            <% if image.thumbnail_url? %>
                <a href="<%= image.file.url %>" target="_blank">
                    <img src="<%= image.thumbnail_url %>" />
                </a>
            <% else %>
                <div class="placeholder">
                    <i class="fa fa-picture-o" aria-hidden="true"></i>
                    <span>Bild wird verarbeitet.</span>
                </div>
            <% end %>
        </div>
    </div>
<% end %>