<% asset ||= value.first %>

<% unless asset.nil? %>
    <div class="inner">
        <%= tag.span asset.name, class: 'asset-title' if asset.name.present? %>
        <span class="asset-type">
          <%= asset.content_type %> (<%= number_to_human_size(asset.file_size) %>)
        </span>

        <div class="thumb hide-for-print">
            <a href="<%= asset.file.url %>" target="_blank">
                <%= t('actions.open_asset', locale: DataCycleCore.ui_language) %> <i class="fa fa-external-link" aria-hidden="true"></i>
            </a>
        </div>
    </div>
<% end %>
