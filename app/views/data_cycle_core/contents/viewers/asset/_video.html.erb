<% image ||= value.first %>

<% unless image.nil? %>
    <div class="inner">
        <div class="thumb">
            <% if image.thumbnail_url? %>
                <a href="<%= image.file.url %>" target="_blank">
                    <img src="<%= image.thumbnail_url %>" />
                </a>
            <% else %>
                <div class="placeholder">
                    <i class="fa fa-picture-o" aria-hidden="true"></i>
                    <span><%= t('actions.processing_asset') %></span>
                </div>
            <% end %>

            <span class="asset-type">
                <%= image.content_type %> (<%= number_to_human_size(image.file_size) %>)
            </span>
        </div>
    </div>
<% end %>
