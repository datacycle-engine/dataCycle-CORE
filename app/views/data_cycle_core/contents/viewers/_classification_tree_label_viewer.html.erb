<% if options[:force_render] ||= false %>
    <%= render 'data_cycle_core/contents/viewers/attribute_viewer', key: key, definition: definition, value: value, options: options do %>
        <div class="detail-type classification">
          <span class="detail-content tags">
            <% DataCycleCore::Classification.where(id: value).map(&:primary_classification_alias).each do |a| %>
              <span class="tag"><%= a.name %></span>
            <% end %>
          </span>
        </div>
    <% end %>
<% end %>
