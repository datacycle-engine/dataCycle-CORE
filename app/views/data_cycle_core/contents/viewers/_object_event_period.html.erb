<% if content.try(:start_date).present? || content.try(:end_date).present? %>

  <div class="event_period">
    <i class="fa fa-calendar" aria-hidden="true"></i>
    <% unless content.try(:start_date).nil? %>
      <%= t('terms.from', locale: DataCycleCore.ui_language) %>
      <span class="date">
        <% if content.start_date.to_s(:time) == '00:00' %>
          <strong><%= l(content.start_date.to_date, format: :full, locale: DataCycleCore.ui_language) %></strong>
        <% else %>
          <strong><%= l(content.start_date.to_datetime, locale: DataCycleCore.ui_language) %></strong>
        <% end %>
      </span>
    <% end %>

    <% unless content.try(:end_date).nil? %>
      <%= t('terms.until', locale: DataCycleCore.ui_language) %>
      <span class="date">
        <% if content.end_date.to_s(:time) == '00:00' %>
          <strong><%= l(content.end_date.to_date, format: :full, locale: DataCycleCore.ui_language) %></strong>
        <% else %>
          <strong><%= l(content.end_date.to_datetime, locale: DataCycleCore.ui_language) %></strong>
        <% end %>
      </span>
    <% end %>
  </div>

<% end %>
