<% if value.present? || options.dig(:force_render).to_s == 'true' || value.is_a?(FalseClass) %>

    <% mode = options.fetch(:mode, 'has-changes edit') %>

    <%= tag.div class: "detail-type #{[
                key.attribute_name_from_key,
                definition.dig('type').try(:underscore),
                definition.dig('compute', 'type'),
                definition.dig('ui', 'show', 'type').try(:underscore),
                options.dig(:item_diff).present? ? "#{mode}" : "",
                options.dig('class'),
            ].reject(&:blank?).join(' ')}", data: (local_assigns[:data_attributes]&.transform_values{ |v| v&.to_s&.html_safe } || {}).merge(label: local_assigns[:data_label] || definition['label'], key: key) do %>

        <% if options.dig(:hide_label).blank? %>
            <span class="detail-label">
              <span class="icon <%= definition['label']&.parameterize(separator: '_') %>"><i class="fa" aria-hidden="true"></i></span>
              <%= definition['label'] %>
            </span>
        <% end %>

        <%= yield %>

    <% end %>

<% end %>
