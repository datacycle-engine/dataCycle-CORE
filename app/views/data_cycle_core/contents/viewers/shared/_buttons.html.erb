<div class="buttons">
  <% if content.try(:translated_locales)&.many? %>
      <span data-tooltip data-allow-html="true" title="<%= content.translated_locales.map{ |t| t("locales.#{t}", locale: DataCycleCore.ui_language) }.join("<br>") %>"><i class="fa fa-language" aria-hidden="true"></i></span>
  <% end %>

  <%= link_to thing_path(content), data: { tooltip: true }, title: t('actions.show', locale: DataCycleCore.ui_language).capitalize, target: :_blank, class: "show-link" do %>
      <i class="fa fa-eye" aria-hidden="true"></i>
  <% end if local_assigns[:definition] && definition['type'] == "linked" && @diff_source.nil? && can?(:show, content) %>

  <%= link_to edit_thing_path(content, locale: I18n.locale), data: { tooltip: true }, title: t('actions.edit', locale: DataCycleCore.ui_language).capitalize, target: :_blank, class: "edit-link" do %>
      <i class="fa fa-pencil" aria-hidden="true"></i>
  <% end if local_assigns[:definition] && definition['type'] == "linked" && @diff_source.nil? && can?(:update, content) %>
</div>
