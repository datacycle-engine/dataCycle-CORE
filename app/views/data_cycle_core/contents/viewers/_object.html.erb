<%= render 'data_cycle_core/contents/viewers/attribute', key: key, definition: definition, value: value, options: options, content: content do %>

    <% ordered_validation_properties(definition).each do |o_key, o_definition| %>
        <%= render_attribute_viewer key: "#{key}[#{o_key}]", definition: o_definition, value: value.try(o_key), parameters: { options: options, content: content } %>
    <% end %>

<% end %>
