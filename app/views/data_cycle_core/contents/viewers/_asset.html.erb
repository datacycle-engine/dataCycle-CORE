<%= render 'data_cycle_core/contents/viewers/attribute', key: key, definition: definition, value: value, options: options, content: content do %>

    <% value = Array(value) %>
    <% value = new_relations(options.dig(:item_diff), 'assets').to_a if changes_by_mode(options.dig(:item_diff), '+').present? %>

    <%= render 'data_cycle_core/assets/asset_list', assets: value %>

<% end %>
