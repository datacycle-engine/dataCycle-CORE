<% if definition['type'] == 'object' && !definition['properties'].nil? %>

    <% object_properties = get_ordered_validation_properties(definition) %>
    <% object_properties.each do |object_key, object_property| %>

        <% object_value = value.nil? ? "" : value[object_key] %>

        <%= render "data_cycle_core/creative_works/partials/show/datatype/#{object_property['type'].downcase}",
                   label: object_property['label'],
                   prop: object_property,
                   value: object_value %>

    <% end %>

<% elsif definition['type'] == 'object' %>

    <% objects = value %>

    <% if !objects.nil? && !objects.blank? %>

        <% objects_length = objects.count %>

        <% objects.each_with_index do |object,index| %>

            <%= definition['editor']['type'] %>

            <div class="detail-type object" data-label="<%= definition['name'] %>" data-editor="<%= definition['editor']['type'] %>" data-id="<%= object.id.split(',') %>">

                <span class="detail-label"><%= render 'data_cycle_core/shared/icon', icon_type: objects[0].metadata['validation']['name'].downcase %><strong><%= definition['label'].capitalize %> <%= content_tag(:span, index+1) if objects_length > 1 %></strong></span>

                <%= link_to '<i class="fa fa-pencil" aria-hidden="true"></i>'.html_safe, edit_polymorphic_path(object), target: :_blank, class: "edit-link" if definition['editor']['type'] == "objectBrowser" %>

                <% I18n.with_locale(object.first_available_locale) do %>

                    <% objectDataHash = object.get_data_hash %>

                    <% if !object.metadata.nil? && !object.metadata['validation'].nil? %>

                        <% validation_properties = get_ordered_validation_properties(object.metadata['validation']) %>

                        <% if !validation_properties.nil? %>

                            <% validation_properties.each do |key, prop| %>

                                <% if prop['type'] == 'object' && !prop['properties'].nil? %>

                                    <% object_options = !prop['editor'].nil? && !prop['editor']['options'].nil? ? prop['editor']['options'] : nil %>
                                    <% object_options['class'] << ' detail-type' unless object_options.nil? %>
                                    <%= content_tag :div, object_options do %>

                                        <% object_properties = get_ordered_validation_properties(prop) %>
                                        <% object_properties.each do |object_key, object_property| %>

                                            <% object_value = objectDataHash[key].nil? ? "" : objectDataHash[key][object_key] %>

                                            <%= render "data_cycle_core/creative_works/partials/show/datatype/#{object_property['type'].downcase}",
                                                       label: object_property['label'],
                                                       prop: object_property,
                                                       key: key,
                                                       object_id: object.id,
                                                       value: object_value %>

                                        <% end %>

                                    <% end %>

                                <% else %>
                                    <% object_value = prop.dig('type') == "object" ? object.try(key.to_sym) : objectDataHash[key] %>

                                    <% object_value = !object_value.blank? ? object_value : "" %>


                                    <% if !object_value.blank? %>

                                        <% begin %>
                                            <%= render "data_cycle_core/creative_works/partials/show/datatype/#{prop['editor']['type'].try(:downcase)}",
                                                       label: prop['label'],
                                                       prop: prop,
                                                       key: key,
                                                       object_id: object.id,
                                                       value: object_value,
                                                       force_render: true %>
                                        <% rescue ActionView::MissingTemplate %>
                                            <%= render "data_cycle_core/creative_works/partials/show/datatype/#{prop['type'].try(:downcase)}",
                                                       label: prop['label'],
                                                       prop: prop,
                                                       key: key,
                                                       object_id: object.id,
                                                       value: object_value,
                                                       force_render: true %>
                                        <% end %>

                                    <% end %>

                                <% end %>

                            <% end %>

                        <% end %>

                    <% end %>

                    </div>

                <% end %>

        <% end %>

    <% end %>

<% end %>
