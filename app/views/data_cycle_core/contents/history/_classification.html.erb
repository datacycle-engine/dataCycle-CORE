<%= render 'data_cycle_core/contents/viewers/attribute_viewer', key: key, definition: definition, value: value, options: options do |item_diff| %>
    <% added_objects, removed_objects = getRelationObjectChanges item_diff %>
    <div class="detail-type classification">
        <span class="detail-content tags">
            <% DataCycleCore::Classification.where(id: value).each do |a| %>
                <span class="tag <%= "has-changed removed" if removed_objects.include?(a.id) %>"><%= a.primary_classification_alias.name %></span>
            <% end %>
            <% unless added_objects.blank? %>
                <% DataCycleCore::Classification.where(id: added_objects).each do |a| %>
                    <span class="tag has-changed added"><%= a.primary_classification_alias.name %></span>
                <% end %>
            <% end %>
        </span>
    </div>
<% end %>