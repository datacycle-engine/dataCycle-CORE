<fieldset>
  <%= render 'data_cycle_core/contents/new/shared/attributes', local_assigns.merge(search_param: true) %>

  <%= render_attribute_editor key: 'thing[datahash][name]',
                              definition: template.schema.dig('properties', 'name'),
                              value: nil,
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } %>

  <%= render_attribute_editor key: 'thing[datahash][address][street_address]',
                              definition: template.schema.dig('properties', 'address', 'properties', 'street_address'),
                              value: nil,
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } %>

  <%= render_attribute_editor key: 'thing[datahash][address][postal_code]',
                              definition: template.schema.dig('properties', 'address', 'properties', 'postal_code'),
                              value: nil,
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } %>

  <%= render_attribute_editor key: 'thing[datahash][address][address_locality]',
                              definition: template.schema.dig('properties', 'address', 'properties', 'address_locality'),
                              value: nil,
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } %>
</fieldset>
