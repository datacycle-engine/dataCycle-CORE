<fieldset>
  <%= render 'data_cycle_core/contents/new/shared/attributes', local_assigns.merge(search_param: true) %>

  <%= render_attribute_editor key: 'thing[datahash][name]',
                              definition: template.schema.dig('properties', 'name').deep_reject{ |k, v| k == 'readonly' },
                              value: local_assigns[:search_param],
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } if template.schema.dig('properties', 'name').present? %>

  <%= render_attribute_editor key: 'thing[datahash][address][street_address]',
                              definition: template.schema.dig('properties', 'address', 'properties', 'street_address').deep_reject{ |k, v| k == 'readonly' },
                              value: nil,
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } if template.schema.dig('properties', 'address', 'properties', 'street_address').present? %>

  <%= render_attribute_editor key: 'thing[datahash][address][postal_code]',
                              definition: template.schema.dig('properties', 'address', 'properties', 'postal_code').deep_reject{ |k, v| k == 'readonly' },
                              value: nil,
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } if template.schema.dig('properties', 'address', 'properties', 'postal_code').present? %>

  <%= render_attribute_editor key: 'thing[datahash][address][address_locality]',
                              definition: template.schema.dig('properties', 'address', 'properties', 'address_locality').deep_reject{ |k, v| k == 'readonly' },
                              value: nil,
                              content: template,
                              parameters: {
                                options: local_assigns[:options]
                              } if template.schema.dig('properties', 'address', 'properties', 'address_locality').present? %>
</fieldset>
