<fieldset>
  <%= render 'data_cycle_core/contents/new/shared/attributes', local_assigns.merge(search_param: true) %>

  <div class="form-element<%= ' validation-container' if template.schema.dig('properties', 'given_name', 'validations').present? %>">
    <%= label_tag "#{template.class.name.demodulize.underscore}[datahash][given_name]", "#{template.schema.dig('properties', 'given_name', 'label')}" %>
    <%= text_field_tag "#{template.class.name.demodulize.underscore}[datahash][given_name]", local_assigns[:search_param], class: 'form-control' %>
  </div>

  <div class="form-element<%= ' validation-container' if template.schema.dig('properties', 'family_name', 'validations').present? %>">
    <%= label_tag "#{template.class.name.demodulize.underscore}[datahash][family_name]", "#{template.schema.dig('properties', 'family_name', 'label')}" %>
    <%= text_field_tag "#{template.class.name.demodulize.underscore}[datahash][family_name]", nil, class: 'form-control' %>
  </div>
</fieldset>
