<div class="form-element">
  <%= label_tag "#{local_assigns.dig(:options, :prefix)}parent_id", t('common.parent', locale: active_ui_locale) %>

  <div class="v-select white">
    <% I18n.with_locale(active_ui_locale) do %>
      <%= select_tag('parent_id', options_for_select(parents, content.try(:parent)&.id), { class: 'single-select select', data: { allow_clear: false }, id: "#{local_assigns.dig(:options, :prefix)}parent_id" }) %>
    <% end %>
  </div>
</div>
