$('#classification-administration li.active').removeClass('active');

<% if @object.is_a?(DataCycleCore::ClassificationTreeLabel) %>
  $('.new-classification-tree-label form')
    .replaceWith('<%= escape_javascript(render 'classification_tree_label_form', classification_tree_label: DataCycleCore::ClassificationTreeLabel.new) %>');

  $('.new-classification-tree-label')
    .before($('<%= escape_javascript(render 'classification_tree_label', tree_label: @object) %>'));

  $('#classification-administration li.active').removeClass('active');
<% elsif @object.is_a?(DataCycleCore::ClassificationTree) && @parent_classification_tree %>
  $('#<%= @parent_classification_tree.id %> form.new_classification_alias')
    .replaceWith('<%= escape_javascript(render 'classification_alias_form', classification_tree_label: @classification_tree_label, classification_tree: @parent_classification_tree, classification_alias: DataCycleCore::ClassificationAlias.new) %>');

  $('#<%= @parent_classification_tree.id %> > ul.children > li:last')
    .before('<%= escape_javascript(render 'classification_tree', classification_tree_label: @classification_tree_label, classification_tree: @object, ancestors: @object.present? ? @object.ancestors.pluck(:id).reverse : []) %>');
<% elsif @object.is_a?(DataCycleCore::ClassificationTree) %>
  $('#<%= @classification_tree_label.id %> form.new_classification_alias')
    .replaceWith('<%= escape_javascript(render 'classification_alias_form', classification_tree_label: @classification_tree_label, classification_tree: @parent_classification_tree, classification_alias: DataCycleCore::ClassificationAlias.new) %>');

  $('#<%= @classification_tree_label.id %> > ul.children > li:last')
    .before('<%= escape_javascript(render 'classification_tree', classification_tree_label: @classification_tree_label, classification_tree: @object, ancestors: @object.present? ? @object.ancestors.pluck(:id).reverse : []) %>');
<% else %>
  <% raise 'Something unexpected has happend' %>
<% end %>
