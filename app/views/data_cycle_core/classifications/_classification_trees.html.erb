<%= render partial: 'classification_tree', collection: classification_trees.includes(sub_classification_alias: [:sub_classification_trees, :classifications, :external_source]), locals: { classification_tree_label: classification_tree_label, ancestors: classification_tree.present? ? classification_tree.ancestors.pluck(:id).reverse + [classification_tree.id] : [] } %>

<%= render partial: 'mapped_classification_alias', collection: mapped_classification_aliases, as: :mapped_classification_alias, locals: { classification_tree_label: classification_tree_label } %>

<% if @classification_trees.any? && !@last_direct_page %>
  <li class="load-more-link">
    <span class="inner-item">
      <% id_param = classification_tree.present? ? { classification_tree_id: classification_tree&.id } : { classification_tree_label_id: classification_tree_label&.id } %>

      <%= link_to t('common.load_all_direct', locale: active_ui_locale), classifications_path(*({ load_all_direct: true, direct_page: (@direct_page + 1) }.merge(id_param))), data: { remote: true, disable_with: "<i class='fa fa-spinner fa-spin'></i> #{t('common.loading', locale: active_ui_locale)}" }, class: 'button small secondary' %>

      <%= link_to t('common.load_more', locale: active_ui_locale), classifications_path(*({ direct_page: (@direct_page + 1) }.merge(id_param))), data: {remote: true, disable_with: "<i class='fa fa-spinner fa-spin'></i> #{t('common.loading', locale: active_ui_locale)}"}, class: 'button small secondary' %>
    </span>
  </li>
<% end %>

<% if can?(:create, classification_tree_label) && type != DataCycleCore::ClassificationAlias %>
  <li class="new-button">
    <div class="new-button-spacer"><a href="#" class="button-prime small create success"><i class="fa fa-plus"></i></a></div>

    <%= tag.div(class: 'remote-render inverted classification-alias-form-container new', data: { remote_path: 'data_cycle_core/classifications/classification_alias_form', remote_options: to_query_params(classification_tree_label: classification_tree_label, classification_tree: classification_tree, classification_alias: DataCycleCore::ClassificationAlias.new).to_json }) %>
  </li>
<% end %>
