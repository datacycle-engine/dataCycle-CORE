<%= form_for(classification_tree_label, url: classifications_path, namespace: classification_tree_label&.id, remote: true) do |f| %>

  <div class="ca-buttons">
    <button class="button-prime small success update" data-disable-with='<i class="fa fa-circle-o-notch fa-spin fa-3x fa-fw"></i>'><i aria-hidden="true" class="fa fa-check"></i></button>
    <button class="button-prime small discard"><i aria-hidden="true" class="fa fa-times"></i></button>
  </div>

  <%= f.hidden_field :id %>

  <div class="ca-input">
    <%= f.label :name, class: 'ca-label' %>
    <%= f.text_field :name, class: 'ca-input-field' %>
  </div>

  <div class="ca-input checkbox">
    <span class="ca-checkbox">
      <%= f.label :internal do |l| %>
          <%= f.check_box :internal %>
          <%= l.translation %>
      <% end %>
    </span>
  </div>

  <%= f.submit class: 'success button' %>
<% end %>
