<% if @classification_type %>
  <% if @classification_type.is_a?(DataCycleCore::ClassificationAlias) %>
    <% if @type == 'direct' && @page > 1 %>
      $('#<%= @html_id %> > ul.children > li.load-more-link.direct').remove();
    <% end %>

    <% if @type != 'mapped' %>
      $('<%= escape_javascript(render 'mapped_classification_aliases', classification_tree_label: @classification_tree_label, mapped_classification_aliases: @classification_trees, classification_type: @classification_type, type: 'direct', last_page: @classification_trees.last_page?, page: @page, html_id: @html_id) %>').appendTo('#<%= @html_id %> > ul.children.direct');
    <% end %>

    <% if @type == 'mapped' && @page > 1 %>
      $('#<%= @html_id %> > ul.children > li.load-more-link.mapped').remove();
    <% end %>

    <% if @type != 'direct' %>
      $('<%= escape_javascript(render 'mapped_classification_aliases', classification_tree_label: @classification_tree_label, mapped_classification_aliases: @mapped_classification_aliases, classification_type: @classification_type, type: 'mapped', last_page: @mapped_classification_aliases.last_page?, page: @page, html_id: @html_id) %>').appendTo('#<%= @html_id %> > ul.children.mapped');
    <% end %>

    $('#<%= @html_id %> > .inner-item > a.name').addClass('loaded');
  <% else %>
    <% if @type == 'direct' && @page > 1 %>
      $('#<%= @classification_type.id %> > ul.children > li.new-button, #<%= @classification_type.id %> > ul.children > li.load-more-link.direct').remove();
    <% end %>

    <% if @type != 'mapped' %>
      $('<%= escape_javascript(render 'classification_trees', classification_tree_label: @classification_tree_label, classification_tree: @classification_tree, classification_trees: @classification_trees, classification_type: @classification_type, last_page: @classification_trees.last_page?, page: @page, type: 'direct') %>').appendTo('#<%= @classification_type.id %> > ul.children.direct');
    <% end %>

    <% if @type == 'mapped' && @page > 1 %>
      $('#<%= @classification_type.id %> > ul.children > li.load-more-link.mapped').remove();
    <% end %>

    <% if @type != 'direct' %>
      $('<%= escape_javascript(render 'mapped_classification_aliases', classification_tree_label: @classification_tree_label, mapped_classification_aliases: @mapped_classification_aliases, classification_type: @classification_type, type: 'mapped', last_page: @mapped_classification_aliases.last_page?, page: @page, html_id: @html_id) %>').appendTo('#<%= @classification_type.id %> > ul.children.mapped');
    <% end %>

    $('#<%= @classification_type.id %> > .inner-item > a.name').addClass('loaded');
  <% end %>
<% else %>
  <% raise 'Something unexpected has happend' %>
<% end %>
