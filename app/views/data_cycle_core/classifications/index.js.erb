<% if c_type = @classification_tree || @classification_tree_label %>
  $('#<%= c_type.id %> > ul.children > li.new-button, #<%= c_type.id %> > ul.children > li.load-more-link').remove();
  $('#<%= c_type.id %> > ul.children')
    .append('<%= escape_javascript(render 'classification_trees', classification_tree_label: @classification_tree_label, classification_tree: @classification_tree, classification_trees: @classification_trees, page: @page, total_pages: @total_pages) %>');
<% else %>
  <% raise 'Something unexpected has happend' %>
<% end %>
