<% if c_type = @mapped_classification_alias || @classification_tree || @classification_tree_label %>
  $('#<%= c_type.id %> > ul.children > li.new-button, #<%= c_type.id %> > ul.children > li.load-more-link').remove();

  $('<%= escape_javascript(render 'classification_trees', classification_tree_label: @classification_tree_label, classification_tree: @classification_tree, classification_trees: @classification_trees, mapped_classification_aliases: @mapped_classification_aliases, type: c_type.class) %>').appendTo('#<%= c_type.id %> > ul.children');

  $('#<%= c_type.id %> > .inner-item > a.name').addClass('loaded');
<% else %>
  <% raise 'Something unexpected has happend' %>
<% end %>
