# frozen_string_literal: true

source 'https://rubygems.org'

ruby '>= 3.3'

git_source(:github) do |repo_name|
  repo_name = "#{repo_name}/#{repo_name}" unless repo_name.include?('/')
  "https://github.com/#{repo_name}.git"
end

# Excel Generator
gem 'caxlsx'
gem 'caxlsx_rails'

gem 'rgeo'
gem 'rgeo-proj4'

# Windows does not include zoneinfo files, so bundle the tzinfo-data gem
gem 'tzinfo-data', platforms: [:windows, :jruby]

gem 'dotenv-rails'

gem 'jb'

# OmniAuth Authentication
gem 'omniauth'
gem 'omniauth-entra-id'

# OAuth2 Provider
gem 'doorkeeper'
gem 'doorkeeper-openid_connect' # has issues as dependency in data_cycle_core.gemspec

group :test do
  gem 'minitest'
  gem 'minitest-mock'
  gem 'minitest-hooks'
  gem 'parallel_tests', require: false
end

group :development do
  gem 'better_errors'
  gem 'binding_of_caller'
  gem 'web-console'
  gem 'brakeman', require: false
  gem 'bundler-audit', require: false
  gem 'faker'
  gem 'rubocop', '!= 1.85.0', require: false
  gem 'rubocop-ast'
  gem 'rubocop-minitest', require: false
  gem 'rubocop-rake', require: false
  gem 'rubocop-performance', require: false
  gem 'rubocop-rails', require: false
  gem 'awesome_print'
  gem 'herb', require: false

  gem 'prosopite'
end

group :container do # used in docker container only, to ignore it for local ruby-lsp
  gem 'taglib-ruby', '>= 2.0.0', require: false
end

group :development, :test, :review do
  gem 'seed_dump'
  gem 'listen'

  gem 'pry'
  gem 'pry-byebug'
  gem 'rb-readline'
  gem 'simplecov', require: false
end
