,"width":549,"height":543,"gallery":true}]},"regions":{"region":[{"id":"1036349","type":"commune"},{"id":"1022094","type":"country"},{"id":"1026621","type":"district"},{"id":"1039948","type":"province"},{"id":"8872382","type":"mountainarea"},{"id":"1607063","name":"Nationalparkregion Hohe Tauern","type":"tourismarea"}]},"winterActivity":false,"meta":{"date":{"created":"2011-09-26T16:18:35","lastModified":"2018-08-07T10:15:46","firstPublish":"2011-09-26T16:20:56"},"system":{"createdIn":"12","lastModifiedIn":"11"},"source":{"logo":{"title":"Kärnten Werbung","id":"2006165","logo":true},"id":"1008670","name":"Kärnten Werbung","url":"http://www.kaernten.at"},"workflow":{"state":"published"},"translation":["de"]},"id":"2539577","frontendtype":"poi","ranking":48.0,"countryCode":"A","linkSuggested":true,"destination":false}},"seen_at":{"$date":"2018-11-09T14:48:53.787Z"},"updated_at":{"$date":"2018-11-09T14:48:53.787Z"},"created_at":{"$date":"2018-11-09T14:48:53.787Z"}},{"_id":{"$oid":"5be59e5532c88f05bead5ffa"},"external_id":"13304043","dump":{"de":{"address":{"countryname":"Österreich"},"tourRecommendations":[{"id":"12678452"}],"category":{"id":"1574483","name":"Historischer Stadtkern","iconUrl":"https://res.oastatic.com/icons/alpstein/historicCityCenter/maroon/historicCityCenter.square_vector.svg","iconInactiveUrl":"https://res.oastatic.com/icons/alpstein/historicCityCenter/grey80/historicCityCenter.square_vector.svg","iconMapUrl":"https://res.oastatic.com/icons/alpstein/historicCityCenter/maroon/historicCityCenter.map_vector.svg","iconInactiveMapUrl":"https://res.oastatic.com/icons/alpstein/historicCityCenter/grey80/historicCityCenter.map_vector.svg","iconTransparentUrl":"https://res.oastatic.com/icons/alpstein/historicCityCenter/historicCityCenter.geocontent.png"},"title":"Kloster","longText":"Die Nikolaikirche war einst eine Klosterkirche, der angrenzende Bau Teil des Kapuzinerklosters, das hier 1629 eingerichtet wurde. Der Kapuzinerorden ging aus dem Franziskanerorden hervor. Vor der Kirche erinnert eine Figur des Heiligen Franziskus an die Verwandtschaft der beiden Orden. Die vorbildliche Lebensweise, die feierlichen Gottesdienste und die mitreißenden Predigten der Kapuziner fanden schnell Anklang bei den Bewohnern der Stadt. So wurden die Reformation und der protestantische Glauben, die in Villach sehr stark vertreten waren, allmählich zurückgedrängt. Durch mehrmalige Brände wurde das Kloster sehr in Mitleidenschaft gezogen und zeitweise sogar aufgelöst. Schließlich zog der Franziskanerorden hier ein. Heute leben Franziskanermönche im Kloster und betreuen auch die Nikolaikirche.","primaryImage":{"title":"Franziskus Statue am Nikolaiplatz","author":"Region Villach","id":"13310555"},"geometry":"13.849364,46.615648","altitude":497.0,"images":{"image":[{"title":"Franziskus Statue am Nikolaiplatz","author":"Region Villach","meta":{"date":{"created":"2012-09-17T16:30:24","lastModified":"2015-03-26T14:14:27"},"system":{"createdIn":"12","lastModifiedIn":"12"},"source":{"logo":{"title":"Region Villach Tourismus GmbH","id":"2203943","logo":true},"id":"1479438","name":"Region Villach Tourismus GmbH","url":"http://www.region-villach.at"},"workflow":{"state":"new"},"authorFull":{"id":"1478025","name":"Region Villach"},"author":"Region Villach"},"id":"13310555","width":4252,"height":2835,"primary":true,"gallery":true}]},"media":{"video":[{"title":"Kloster - Mönchisches Leben am Rande der Stadt","url":"http://wivi.region-villach.at/images/videos/vi_moenchisches_leben_de.mp4"}]},"regions":{"region":[{"id":"1032617","type":"commune"},{"id":"1022094","type":"country"},{"id":"1020344","type":"district"},{"id":"1039948","type":"province"},{"id":"8872283","type":"mountainarea"},{"id":"1022046","name":"Villach - Faaker See - Ossiacher See","type":"tourismarea"}]},"winterActivity":false,"meta":{"date":{"created":"2015-03-26T14:00:38","lastModified":"2015-12-02T07:32:23","firstPublish":"2015-03-26T14:13:07"},"system":{"createdIn":"12","lastModifiedI