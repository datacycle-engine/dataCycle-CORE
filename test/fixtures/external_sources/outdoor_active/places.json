"1029784","type":"commune"},{"id":"1022094","type":"country"},{"id":"1040199","type":"district"},{"id":"1039948","type":"province"},{"id":"1039889","name":"Lavanttal","type":"tourismarea"}]},"winterActivity":false,"meta":{"date":{"created":"2011-07-05T12:25:34","lastModified":"2018-05-10T01:31:32","firstPublish":"2011-07-05T12:28:00"},"system":{"createdIn":"11","lastModifiedIn":"12"},"source":{"logo":{"title":"Tourismusbüro Wolfsberg","id":"29458162","logo":true},"id":"1479535","name":"Tourismusbüro Wolfsberg","url":"http://www.wolfsberg.at"},"workflow":{"state":"published"},"translation":["de"]},"id":"1703944","frontendtype":"lodging","ranking":70.0,"countryCode":"A","linkSuggested":true,"destination":false}},"seen_at":{"$date":"2018-11-09T14:48:53.232Z"},"updated_at":{"$date":"2018-11-09T14:48:53.233Z"},"created_at":{"$date":"2018-11-09T14:48:53.233Z"}},{"_id":{"$oid":"5be59e5532c88f05bead5ff6"},"external_id":"9519238","dump":{"de":{"phone":"+43 (0)4712/553 od. +43 (0)676/8772-8302 ","email":"berg@kath-pfarre-kaernten.at","homepage":"http://www.kath-kirche-kaernten.at/berg","address":{"street":"Berg ","housenumber":"3","zipcode":"9771","town":"Berg im Drautal","countryname":"Österreich"},"tourRecommendations":[{"id":"9299675"}],"category":{"id":"1574485","name":"Kirche","iconUrl":"https://res.oastatic.com/icons/alpstein/church/maroon/church.square_vector.svg","iconInactiveUrl":"https://res.oastatic.com/icons/alpstein/church/grey80/church.square_vector.svg","iconMapUrl":"https://res.oastatic.com/icons/alpstein/church/maroon/church.map_vector.svg","iconInactiveMapUrl":"https://res.oastatic.com/icons/alpstein/church/grey80/church.map_vector.svg","iconTransparentUrl":"https://res.oastatic.com/icons/alpstein/church/church.geocontent.png"},"title":"Filialkirche St. Athanas","longText":"\u003cp\u003eBerg i. Drautal, Filialkirche hl. Athanasius\u003c/p\u003e\r\n\u003cp\u003e \u003c/p\u003e\r\n\u003cp\u003eDie 1443 erstmals urkundlich erwähnte, ehemalige Wallfahrtskirche wurde 1485 vom Bischof von Caorle, dem heiligen Nonnosus geweiht. Das Patrozinium des heiligen Athanasius wird erstmals 1782 erwähnt.\u003c/p\u003e\r\n\u003cp\u003eDas ungewöhnliche Aussehen der Kirche ergibt sich durch den sehr hohen spätgotischen Chor mit Dachreiter und Spitzgiebelhelm, der östlich an ein niedriges, breites, romanisches Langhaus mit einer noch niedrigeren, östlichen, offenen Vorlaube in Schiffbreite anschließt.  Der 2-jochige Chor mit 5/8 Schluss wird von zweifach gestuften Strebepfeilern gestützt.  Im Norden ist an den Chor eine barocke Sakristei angebaut. Das an der Nordwand fragmentarisch erhaltene Christophorusfresko wurde um 1400 gemalt.\u003c/p\u003e\r\n\u003cp\u003eIm Inneren besitzt das Langhaus eine flache Holzdecke. Die Kassettendecke des 17. Jhs. wurde 1994 in ihrer ursprünglichen Form wiederhergestellt. Die dreiseitige, hölzerne, barocke Orgelempore ist mit 1687 bezeichnet. Ein eingezogener spitzbogiger Triumphbogen verbindet das Langhaus mit dem Chor. Im 1481 datierten Chor ruht das Netzrippengewölbe auf Wandvorlagen mit Runddiensten und Kapitellringen. An der Südwand des Chores befindet sich eine Sakramentsnische.\u003c/p\u003e\r\n\u003cp\u003eAn der Nordwand des Langhauses haben sich Reste zweier ursprünglich übereinander gelegener (zeitlich unterschiedlicher) monumentaler Standfigurenzyklen erhalten, die jeweils Jesus Christus mit den zwölf Aposteln zeigen. Der untere (ältere) Bildzyklus wird teilweise von der Orgelempore überdeckt. Die Figuren stellen einen hl. Bischof und die Apostel Thomas, Judas Thaddäus, Jakobus der Jüngere, Paulus, Matthäus, Jesus Christus und die Apostel Petrus und Andreas dar. Diese Apostelreihe ist unmittelbar verwandt mit dem Fresko des Nikolaus Kentner in der Pfarrkirche Kötschach aus dem Jahre 1499, sie ist jedoch stilistisch älter. Die darüber stehende (spätere) Apostelreihe stammt aus dem späten 16. Jh. und wiederholt die Komposition der darunter stehenden Apostel.\u003c/p\u003e\r\n\u003cp\u003eAuf dem Chorschlussstern im Chorgewölbe ist das Christushaupt wiedergegeben, auf den runden Schlusssteinen Sonne, Mond, Sterne und Wappen. In den Gewölbefeldern sind in vertieften Vier- und Fünfpässen Halbfiguren der Apostel und anderer Heiliger dargestellt. In den Dreipasszwickeln sind die Vierzehn Nothelfer zu sehen. Die Fresken im Chor wurden um 1481 von einer der Pacherschule nahestehenden Tiroler Werkstätte geschaffen und 1965 freigelegt.\u003c/p\u003e\r\n\u003cp\u003eGeorg Andre Freiherr von und zu Kronegg, der damalige Kärntner Landeshauptmann, stiftete 1666 gemeinsam mit seiner Gattin den Hochaltar. Die Mittelnische des Altares birgt die Skulpturen der hll. Athanasius, Georg und Andreas. Seitlich stehen zwei Bischofsfiguren. Das Aufsatzbild stellt die Heilige Familie dar.\u003c/p\u003e\r\n\u003cp\u003eDer vom Ende des 17. Jhs. stammende Wandaltar mit kräftigem Akanthusdekor trägt in der breiten Mittelnische die gotische Statue des heiligen Nonnosus aus dem 3. V. d. 15. Jhs., sowie vier Bischofsfiguren. Die Schnitzgruppe im Aufsatzmedaillon stellt die Heilige Dreifaltigkeit dar.\u003c/p\u003e\r\n\u003cp\u003eAm Korb der aus der 1. H. d. 18. Jhs. stammenden Kanzel sind die gemalten Darstellungen der vier Evangelisten und des Guten Hirten. Die Bekrönung des Schalldeckels bildet das Gottesauge im Strahlenkranz.\u003c/p\u003e\r\n\u003cp\u003eZur weiteren Ausstattung der Kirche gehören an der nördlichen Triumphbogenwand eine in der Mondsichel stehende Madonna mit Kind im Strahlenkranz aus dem 17. h., Konsolfiguren der hll. Leonhard und Florian aus dem 18. Jh., unter der Empore eine Statuette des heiligen Athanasius aus dem 16. Jh., ein Fragment einer römerzeitlichen Grabinschrift, sowie ein kleiner Bestand origineller Votivbilder.\u003c/p\u003e\r\n\u003cp\u003e \u003c/p\u003e\r\n\u003cp\u003eLiteraturnachweis:\u003c/p\u003e\r\n\u003cp\u003eDehio-Handbuch. Die Kunstdenkmäler Österreichs. Kärnten. Anton Schroll, Wien 2001, S. 53f.\u003c/p\u003e\r\n\u003cp\u003e \u003c/p\u0